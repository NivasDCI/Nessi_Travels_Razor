@using Transport.Repository.Resource;
@{
    Layout = "";
}

<!DOCTYPE html>
<html>
<head>
    <script>
        $('body').on('click', function (e) {
            if ($(e.target).data('toggle') !== 'popover' && $(e.target).parents('.popover.in').length === 0) {
                $('.popover').popover('hide');
            }
        });

        document.onkeydown = function (evt) {
            var keyCode = evt ? (evt.which ? evt.which : evt.keyCode) : event.keyCode;
            if (keyCode == 13) {
                VehicleSearch();
                return false;
            }
        }

        ShowCommonBack();
        var GrdVehicleMaster;
        var VehicleStatus;       
        LoadStatus(0);       

        function LoadStatus(VehicleStatus) {

            $.ajax({
                type: "GET",
                url: BaseURL + "Common/Load_Status",
                datatype: "Json",
                success: function (data) {
                    $("#DdlsearchVehicleStatus option").remove();
                    $.each(data, function (index, value) {
                        $('#DdlsearchVehicleStatus').append('<option value="' + value.ID + '">' + value.Name + '</option>');
                    });
                }
            }).done(function (result) {
                if (VehicleStatus == 0 || VehicleStatus == 1) {
                    $("#DdlsearchVehicleStatus").val(VehicleStatus);
                }
                else {
                    $("#DdlsearchVehicleStatus").val(-1);
                }
            });
        }

        renderer = function (value, record, $cell, $displayEl, id) {

            var HTMLContent = '<table style=width:100%><tr>';
                HTMLContent += '<td style="border:0px solid #FFF;"><a tabindex="-1" onclick="EditVehicle(' + record.VehicleCode + ')" style="cursor:pointer"><i class="fas fa-edit Form-GridEditButton"></i></a></td>';
            $displayEl.html("</tr></table>");
            $displayEl.append(HTMLContent);

        }
        var tstamp = (new Date()).getTime();

         GrdVehicleMaster = $("#GrdVehicleMaster").grid({
            primaryKey: "VehicleCode",
            uiLibrary: "bootstrap4",
            autoLoad: true,
            dataSource: '@Url.Action("VehicleMaster_FindAll", "ProjectMaster")',
            columns: [
                    { field: 'VehicleCode', title: "Code", width: 75, align: "center", editor: false, sortable: true },
                    { field: "VehicleName", title: "Vehicle No", sortable: true },
                    { field: '@PROPageModel.Common_Status', width: 75, align: "center", editor: false, sortable: true, renderer: function (value, record) { return record.Status == true ? '<span class="badge badge-success" style=font-size:12px>@Button.Button_Active</span>' : '<span class="badge badge-danger" style=font-size:12px>@Button.Button_Inactive</span>'; } },
                    { field: '@Button.Button_Action', width: 90, align: "center", renderer: renderer }
            ]
            
         });

        $('#btnAddVehicleDetail').click(function () {
            var ParamData = [

                { ParameterName: "VehicleName", ParameterValue: $("#TxtSearchVehicleName").val() },
                { ParameterName: "VehicleStatus", ParameterValue: $("#DdlsearchVehicleStatus").val() }

            ]

            AddBackURLStore(JSON.stringify(ParamData));
            if ($("#HdnDashboardCount").val() == 1) {
                GetMenu('@Url.Action("AddVehicleMaster", "ProjectMaster")' + '?VehicleCode=0');
            }
            else {
                GetMenu('@Url.Action("AddVehicleMaster", "ProjectMaster")' + '?VehicleCode=0' + '&HeaderViewID=' + GetParamValue("HeaderViewID") + '&DetailViewID=' + GetParamValue("DetailViewID"));
            }
        });

        function EditVehicle(VehicleID) {
            var ParamData = [

                { ParameterName: "VehicleName", ParameterValue: $("#TxtSearchVehicleName").val() },
                { ParameterName: "VehicleStatus", ParameterValue: $("#DdlsearchVehicleStatus").val() }

            ]

            AddBackURLStore(JSON.stringify(ParamData));
            if ($("#HdnDashboardCount").val() == 1) {
                GetMenu('@Url.Action("AddVehicleMaster", "ProjectMaster")' + '?VehicleCode=' + VehicleID);
            }
            else {

                GetMenu('@Url.Action("AddVehicleMaster", "ProjectMaster")' + '?VehicleCode=' + VehicleID + '&HeaderViewID=' + GetParamValue("HeaderViewID") + '&DetailViewID=' + GetParamValue("DetailViewID"));
            }
        }

        function VehicleSearch() {
            var searchVehicleName = '';
            var VehicleStatus = null;
            searchVehicleName = $('#TxtSearchVehicleName').val();

            if ($("#DdlsearchVehicleStatus").val() == 0) {
                VehicleStatus = false;
            }
            else if ($("#DdlsearchVehicleStatus").val() == 1) {
                VehicleStatus = true;
            }

            GrdVehicleMaster.reload({ VehicleName: searchVehicleName, Status: VehicleStatus });
        }

        //Search filter methods
        $("#btnVehicleSearch").click(function () {
            VehicleSearch();
        });

        $("#btnVehicleSearchClear").click(function () {
           
            $("#TxtSearchVehicleName").val("");
            $("#DdlsearchVehicleStatus").val(-1);
            GrdVehicleMaster.reload({ VehicleName: '', Status: null });
        });

    </script>

</head>
<body>
    <input type="hidden" id="HtnVehicleUniqID" value="0" />
    <!-- Content Wrapper. Contains page content -->
    <div class="content">
        <!-- Content Header (Page header) -->
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card card-pd">

                        <div class="card-header">
                            <span style="font-size: 18px;" class="m-0"><i class="fa fa-truck"></i></span>
                            <span style="font-size: 18px; border-left: 1px solid #ccc; padding-left: 10px;"> Vehicle Master - View  </span>
                            <div style="float: right;">
                                <span style="border-left: 1px solid #ccc; padding-left: 15px; padding-right: 15px;">
                                    <a href="#" data-toggle="tooltip" data-placement="bottom" title="Add Vehicle" id="btnAddVehicleDetail"><i class="fas fa-plus-circle"></i> </a>
                                </span>
                                <span style="border-left: 1px solid #ccc; padding-left: 15px; padding-right: 15px;">
                                    <a href="#" data-toggle="tooltip" data-placement="bottom" title="Show Form" onclick="showForm()"><i class="fas fa-caret-square-down"></i></a>
                                </span><span style="border-left: 1px solid #ccc; padding-left: 15px; padding-right: 15px;">
                                    <a href="#" data-toggle="tooltip" data-placement="bottom" title="Hide Form" onclick="hideForm()"><i class="fas fa-caret-square-up"></i></a>
                                </span>
                            </div>
                        </div>

                        <div class="card-body">
                            <!-- /hidden_div -->
                            <div id="hidden-form" style="display: none;">
                                <div class="row">
                                   
                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Vehicle Name</label>
                                            <div>
                                                <input type="text" tabindex="1" id="TxtSearchVehicleName"   maxlength="200"  placeholder="Vehicle Name" class="form-control">
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-sm-2">
                                        <div class="form-group">
                                            <label>Status</label>
                                            <div>
                                                @Html.DropDownList("DdlsearchVehicleStatus", new SelectList(string.Empty, "Value", "Text"), new { @class = "form-control select2", @tabindex = 2, @width = "100%" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="pdt-25">
                                            <div class="row">
                                                <div class="col-sm-6">
                                                    <button type="button" tabindex="3" id="btnVehicleSearchClear" class="btn btn-primary btn-block"><i class="fa fa-paint-brush"></i> @Transport.Repository.WEBPAGEBUTTON.CLEAR</button>
                                                </div>
                                                <div class="col-sm-6">
                                                    <button type="button" tabindex="4" id="btnVehicleSearch" class="btn btn-primary btn-block"><i class="fa fa-search"></i> @Transport.Repository.WEBPAGEBUTTON.SEARCH</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-lg-12">
                                    <div class="box-body table-responsive no-padding">
                                        <table id="GrdVehicleMaster" class="table table-hover"></table>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

            </div><!-- /.content-wrapper -->
        </div>
    </div>

    <script type="text/javascript">
        if (ArrParameterData[GetBackURLCount()] != null) {

            var vVehicleStatus;
            if (ArrParameterData[GetBackURLCount()][0].ParameterName == "VehicleName") {
                $('#TxtSearchVehicleName').val(ArrParameterData[0][0].ParameterValue);
            }
            if (ArrParameterData[GetBackURLCount()][1].ParameterName == "VehicleStatus") {
                SupplierUserStatus = ArrParameterData[0][1].ParameterValue;
                $('#DdlsearchVehicleStatus').val(SupplierUserStatus);
                if (VehicleStatus == 0) {
                    vVehicleStatus = false;
                }
                else if (VehicleStatus == 1) {
                    vVehicleStatus = true;
                }
            }
            GrdVehicleMaster.reload({ VehicleName: $('#TxtSearchVehicleName').val(), Status: vVehicleStatus });
        }

    </script>

</body>
</html>

