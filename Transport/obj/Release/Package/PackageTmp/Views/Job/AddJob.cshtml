        function ResetJob() {
            if (GetParamValue("JobCode") != 0) {
                EditJobs();
            }
            else {
                ClearJobs();
            }
        }

        function ClearJobs() {
            $('#ddlVehicleCode').val(0); $('#ddlJobVendorCode').val(0); $('#ddlDrivingBy').val(0); $('#ddlCashInHand').val(0);
            $('#txtJobDate').text(''); $('#txtJobTime').val(''); $('#txtJobFrom').val(''); $('#txtJobTo').val(''); //$('#txtCost').val('');
            $('#txtCredit').val(''); $('#txtCash').val(''); $('#txtOutSourceAmount').val(''); $('#txtOutSourceAmountGiven').val(''); $('#txtRemarks').val('');
            $('#txtContactNo').val(''); $('#txtCustomerName').val(''); $('#txtOutSource').val(''); $("#HdnContactNo").val("");
        }

        $('#txtJobDate').datepicker({
            format: Common_Date_Format, autoclose: true, uiLibrary: 'bootstrap4', iconsLibrary: 'fontawesome', size: 'small', todayHighlight: true
        }).on("change", function () {
            LoadJobs();
        });

        $('input[id="txtJobDate"]').val(TodayDateRange);

        function TodayDateRange() {
            let monthNames = ["Jan", "Feb", "Mar", "Apr",
                "May", "Jun", "Jul", "Aug",
                "Sep", "Oct", "Nov", "Dec"];

            var today = new Date();
            var dd = today.getDate();
            var mm = today.getMonth(); //January is 0!
            var yyyy = today.getFullYear();

            if (dd < 10) {
                dd = '0' + dd
            }

            let monthName = monthNames[mm];

            return dd + '-' + monthName + '-' + yyyy;
        }

        EditJobs();

        function EditJobs() {

            if (GetParamValue("JobCode") != 0) {
                $.ajax({
                    type: "GET",
                    url: BaseURL + "Job/Job_Edit",
                    data: { JobCode: GetParamValue("JobCode") },
                    datatype: "Json",
                    success: function (data) {
                        $('#hdnJobCode').val(GetParamValue("JobCode"));
                        //$("#txtJobDate").val(data.JobDate);
                        $("#txtJobDate").val(GetParseJsonDate(data.JobDate));
                        $("#txtJobTime").val(data.JobTime);
                        $("#txtJobFrom").val(data.JobFrom);
                        $("#txtJobTo").val(data.JobTo);
                        $("#ddlJobVendorCode").val(data.JobVendorCode);
                        $("#ddlVehicleCode").val(data.VehicleCode);
                        $("#ddlDrivingBy").val(data.DrivingBy);
                        $("#ddlCashInHand").val(data.CashInHand);
                        $("#txtOutSource").val(data.OutSource);
                        $("#txtCustomerName").val(data.CustomerName);
                        $("#txtRemarks").val(data.Remarks);
                        $("#txtContactNo").val(data.ContactNo);
                        $("#HdnContactNo").val(data.ContactNo);

                        //$("#txtCost").val(data.Cost);
                        $("#txtCredit").val(data.Credit);
                        $("#txtCash").val(data.Cash);
                        $("#txtOutSourceAmount").val(data.OutSourceAmount);
                        $("#txtOutSourceAmountGiven").val(data.OutSourceAmountGiven);
                        LoadJobVendors(data.JobVendorCode);
                        LoadVehicles(data.VehicleCode);
                        LoadDrivingBy(data.DrivingBy);
                        LoadCashInHand(data.CashInHand);
                        if (data.OutSource) { $('#divcopylink').show(); }
                        $('#btnJobReAssign').show();
                        if (data.JobStatus != "Cancelled") { $('#btnJobCancel').show(); }
                    }
                });
                LoadJobs();
            }
            else {
                $('#divcopylink').hide();
                $('#btnJobReAssign').hide(); $('#btnJobCancel').hide();
                LoadJobVendors(0);
                LoadVehicles(0);
                LoadDrivingBy(0);
                LoadCashInHand(0);
            }

            if (GetParamValue("JobRequestCode") != 0) {
                $('#hdnRequestCode').val(GetParamValue("JobRequestCode"));
                FetchRecord();
                $('#btnJobReAssign').hide(); $('#btnJobCancel').hide();
                LoadJobs();
            }
        }

        function FetchRecord() {
            $.ajax({
                type: "GET",
                url: BaseURL + "Job/GetRequest",
                data: { JobRequestCode: $('#hdnRequestCode').val() },
                datatype: "Json",
                success: function (data) {
                    //$('#hdnRequestCode').val($('#hdnRequestCode').val());
                    $("#txtJobDate").val(GetParseJsonDate(data.JobRequestDate));
                    $("#txtJobTime").val(data.JobRequestTime);
                    $("#txtJobFrom").val(data.JobRequestFrom);
                    $("#txtJobTo").val(data.JobRequestTo);
                    $("#txtCustomerName").val(data.CustomerName);
                    $("#HdnContactNo").val(data.ContactNo);
                    $("#txtContactNo").val(data.ContactNo);
                    $('#txtCash').val(data.Cost);
                }
            });
        }

        function FetchJobRecord() {
            $.ajax({
                type: "GET",
                url: BaseURL + "Job/Job_Edit",
                data: { JobCode: $('#txtJobCode').val() },
                datatype: "Json",
                success: function (data) {
                    $("#txtJobDate").val(GetParseJsonDate(data.JobDate));
                    $("#txtJobTime").val(data.JobTime);
                    $("#txtJobFrom").val(data.JobFrom);
                    $("#txtJobTo").val(data.JobTo);
                    $("#txtCustomerName").val(data.CustomerName);
                    $("#txtRemarks").val(data.Remarks);
                    $('#ddlJobVendorCode').val(data.JobVendorCode);
                    $('#txtOutSource').val(data.OutSource);
                    $("#txtOutSourceAmount").val(data.OutSourceAmount);
                    $('#ddlVehicleCode').val(data.VehicleCode);
                    $('#ddlDrivingBy').val(data.DrivingBy);
                    //$('#txtCost').val(data.Cost);
                    $('#txtCredit').val(data.Credit);
                    $('#txtCash').val(data.Cash);
                    $("#HdnContactNo").val(data.ContactNo);
                    $("#txtContactNo").val(data.ContactNo);
                }
            });
        }

        $('[data-widget="pushmenu"]').PushMenu("collapse");

        $(function () {
            $('#txtJobTime').timepicker({
                'scrollDefault': 'now',
                'step': 10,
                'forceRoundTime': true,
                //'timeFormat': 'h:i A'
                'timeFormat': 'H:i'
            });
        });

        function LoadJobs() {
            GrdJobAddJob.clear();
            GrdJobAddJob.reload({ StartDate: $('#txtJobDate').val(), EndDate: $('#txtJobDate').val(), JobVendorCode: null, DrivingBy: null, VehicleCode: null });
        }
       
    </script>

</head>
