            //    ErrorAlert("Please Select Driving By");
            //    Result = false;
            //    return false
            //}
            //if ($("#ddlJobVendorCode").val() == 0 || $("#ddlJobVendorCode").val() == null) {
            //    ErrorAlert("Please Select Job Given By");
            //    Result = false;
            //    return false
            //}

            if ($("#txtContactNo").val() == "") {
                ErrorAlert("Please Enter Contact No");
                Result = false;
                return false
            }

            return Result;
        }

        $('#btnSaveJobs').click(function (e) {
            if ($(this).hasClass("unclickable")) {
                e.preventDefault();
            } else {

                if (FormValidate() == true) {

                    var fileData = new FormData();

                    fileData.append("JobCode", $('#hdnJobCode').val());
                    fileData.append("JobDate", $('#txtJobDate').val());
                    fileData.append("JobTime", $('#txtJobTime').val());
                    fileData.append("JobFrom", titleCase($('#txtJobFrom').val()));
                    fileData.append("JobTo", titleCase($('#txtJobTo').val()));
                    fileData.append("JobVendorCode", $('#ddlJobVendorCode').val());
                    fileData.append("JobRequestCode", $('#hdnRequestCode').val());
                    fileData.append("VehicleCode", $('#ddlVehicleCode').val());
                    fileData.append("DrivingBy", $('#ddlDrivingBy').val());
                    fileData.append("OutSource", titleCase(($('#txtOutSource').val() || "").toUpperCase()));
                    fileData.append("CustomerName", titleCase(($('#txtCustomerName').val() || "").toUpperCase()));
                    fileData.append("ContactNo", $("#HdnContactNo").val());
                    //fileData.append("Cost", $('#txtCost').val());
                    fileData.append("Credit", $('#txtCredit').val());
                    fileData.append("Cash", $('#txtCash').val());
                    fileData.append("OutSourceAmount", $('#txtOutSourceAmount').val());
                    fileData.append("OutSourceAmountGiven", $('#txtOutSourceAmountGiven').val());
                    fileData.append("Remarks", $('#txtRemarks').val());
                    fileData.append("CashInHand", $('#ddlCashInHand').val());

                    $.ajax({
                        url: BaseURL + "Job/Job_Save", type: "POST",
                        contentType: false, // Not to set any content header
                        processData: false,
                        data: fileData

                    }).done(function (result) {
                        if (result.Result == true) {
                            SucessAlert(result.Message);
                            ClearJobs();
                            GetMenu('@Url.Action("ListJobs", "Job")' + '?HeaderViewID=PURCMASTER6 & DetailViewID=18UG35XQZNWT');
                            //BackFunction();
                        }
                        else if (result.Result == false) {
                            ErrorAlert(result.Message);
                        }
                    })
                    .fail(function (result) {
                        ErrorAlert(result.Message);
                    });
                }
            }
        });

