                                    <div class="form-group required">
                                        <label class="control-label">Contact No</label>
                                        <input type="text" tabindex="6" class="form-control" id="txtContactNo" name="txtContactNo" autocomplete="off">
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group required">
                                        <label class="control-label">From</label>
                                        <input type="text" tabindex="7" class="form-control" style="text-transform: capitalize" id="txtJobFrom">
                                    </div>
                                </div>
                                <div class="col-sm-4">
                                    <div class="form-group required">
                                        <label class="control-label">To</label>
                                        <input type="text" tabindex="8" class="form-control" style="text-transform: capitalize" id="txtJobTo">
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-sm-2">
                                    <div class="form-group">
                                        <label class="control-label">Vehicle</label>
                                        @Html.DropDownList("ddlVehicleCode", new SelectList(string.Empty, "Value", "Text"), new { @tabindex = 9, @class = "form-control select2", @width = "100%" })
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        <label class="control-label">Driving By</label>
                                        @Html.DropDownList("ddlDrivingBy", new SelectList(string.Empty, "Value", "Text"), new { @tabindex = 10, @class = "form-control select2", @width = "100%" })
                                    </div>
                                </div>
                                <div class="col-sm-2" style="display:none">
                                    <div class="form-group">
                                        <label class="control-label">Cost</label>
                                        <input type="text" tabindex="11" class="form-control" id="txtCost">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group">
                                        <label class="control-label">Credit</label>
                                        <input type="text" tabindex="11" class="form-control" id="txtCredit">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group ">
                                        <label class="control-label">Cash</label>
                                        <input type="text" tabindex="12" class="form-control" id="txtCash">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group ">
                                        <label class="control-label">OutSource Amt</label>
                                        <input type="text" tabindex="12" class="form-control" id="txtOutSourceAmount">
                                    </div>
                                </div>
                            </div>

                            <div class="row">

                                <div class="col-sm-2">
                                    <div class="form-group">
                                        <label>Cash In Hand</label>
                                        @Html.DropDownList("ddlCashInHand", new SelectList(string.Empty, "Value", "Text"), new { @tabindex = 13, @class = "form-control select2", @width = "100%" })
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group">
                                        <label>Remarks</label>
                                        <input type="text" tabindex="14" class="form-control" id="txtRemarks">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group ">
                                        <label class="control-label">OutSource Amt Given</label>
                                        <input type="text" tabindex="15" class="form-control" id="txtOutSourceAmountGiven">
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="pdt-25">
                                        <div class="row">
                                            <div class="col-sm-2">
                                                <button type="button" tabindex="16" id="btnSaveJobs" class="btn btn-primary btn-block"><i class="fa fa-save"></i> Save</button>
                                            </div>
                                            <div class="col-sm-2">
                                                <button type="button" tabindex="17" id="btnJobReset" class="btn btn-secondary btn-block"><i class="fa fa-undo"></i> @Transport.Repository.WEBPAGEBUTTON.RESET</button>
                                            </div>
                                            <div class="col-sm-2">
                                            </div>
                                            <div class="col-sm-3">
                                                <button type="button" tabindex="18" id="btnJobReAssign" class="btn btn-warning btn-block"><i class="fa fa-undo"></i> Re Assign Job</button>
                                            </div>
                                            <div class="col-sm-3">
                                                <button type="button" tabindex="19" id="btnJobCancel" class="btn btn-danger btn-block"><i class="fa fa-trash"></i> Cancel Job</button>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
                <!-- /.col-md-12 -->
            </div>
            <!-- /.row -->
            <br />
            <div class="row">
                <div class="col-lg-12">
                    <div class="box-body table-responsive no-padding">
                        <table id="GrdJobAddJob" class="table table-hover"></table>
                    </div>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </div>
    <!-- /.content -->

</body>

</html>

