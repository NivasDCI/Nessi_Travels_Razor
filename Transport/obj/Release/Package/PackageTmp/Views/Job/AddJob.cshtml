        $('#btnJobReAssign').click(function (e) {
            if ($(this).hasClass("unclickable")) {
                e.preventDefault();
            } else {
                var _errorMsg = "";
                if ($('#hdnJobCode').val() == 0) {
                    _errorMsg += '<br />' + "Job Code Empty!";
                }
                if (_errorMsg.length > 0) {
                    ErrorAlert(_errorMsg);
                    return false;
                }

                $.confirm({
                    title: "Re Assign?",
                    content: ConfirmAlert_Message_Content.replace("{0}", "Re Assign will clear all the history and Set the Job Status to Assigned. Do you want to Continue?"),
                    animation: 'zoom',
                    closeAnimation: 'zoom',
                    buttons: {
                        'confirm': {
                            text: Alert_YesMessage,
                            btnClass: Alert_Button_Style,
                            keys: ['enter'],
                            action: function () {
                                $.ajax({
                                    url: '@Url.Content("~/Job/ReAssignJobStatus")',
                                    type: 'POST',
                                    data: JSON.stringify({ JobCode: $('#hdnJobCode').val() }),
                                    dataType: 'json',
                                    contentType: 'application/json',
                                    success: function (result) {
                                        if (result.success === true) {
                                            SucessAlert("Re Assign completed. Make your Changes and Save the Job!");
                                        }
                                        if (result.success === false) {
                                            ErrorAlert(result.response);
                                        }
                                    }
                                });
                            },
