        function FormValidate() {
            var Result = true;

            if ($("#txtJobDate").val() == "") {
                ErrorAlert("Please Select Job Date");
                Result = false;
                return false
            }
            if ($("#txtJobTime").val() == "") {
                ErrorAlert("Please Select Job Time");
                Result = false;
                return false
            }
            if ($("#txtJobFrom").val() == "") {
                ErrorAlert("Please Select Job From");
                Result = false;
                return false
            }
            if ($("#txtJobTo").val() == "") {
                ErrorAlert("Please Select Job To");
                Result = false;
                return false
            }

            if ($("#txtCash").val()) {
                if ($("#ddlCashInHand").val() == 0 || $("#ddlCashInHand").val() == null) {
                    ErrorAlert("CashInHand is required!");
                    Result = false;
                    return false
                }
            }

            if ($("#ddlVehicleCode").val() != 0) {
                if ($("#ddlDrivingBy").val() == 0 || $("#ddlDrivingBy").val() == null) {
                    ErrorAlert("DrivingBy is required!");
                    Result = false;
                    return false
                }
            }
            console.log($("#ddlVehicleCode").val());
            if ($("#ddlVehicleCode").val() != 0) {
                if ($("#ddlVehicleCode :selected").text() == "OUTSOURCE") {
                    if ($("#txtOutSource").val() == "" || $("#txtOutSourceAmount").val() == "") {
