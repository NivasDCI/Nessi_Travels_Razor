    <div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="myModalLabel">Cash In Hand</h5>
                    <input type="hidden" id="jobidmodal" name="jobidmodal" />
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        @Html.DropDownList("ddlCashInHand", new SelectList(string.Empty, "Value", "Text"), new { @class = "form-control select2", @width = "100%" })<br />
                        <button type="button" class="btn btn-info" id="btnupdatecashinhand" onclick="SaveCashInHand();">Update</button>
                    </div>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title" id="myModalLabel">Driver Log Trip Events</h5>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <button type="button" id="btnjobstarted" onclick="SaveStatus(this);" class="btn-info">Job Started</button>
                    </div>
                    <div class="form-group">
                        <button type="button" id="btnwaitingforcustomer" onclick="SaveStatus(this);" class="btn-primary">Waiting for Customer</button>
                    </div>
                    <div class="form-group">
                        <button type="button" id="btnpassengeronboard" onclick="SaveStatus(this);" class="btn-secondary">Passenger on board</button>
                    </div>
                    <div class="form-group">

                    </div>

                    <div class="form-group">
                        <button type="button" id="btnjobcompleted" onclick="SaveStatus(this);" class="btn-success">Job Completed</button>
                    </div>
                    <div class="form-group">
                        <button type="button" id="btnnoshow" onclick="SaveStatus(this);" class="btn-danger">No Show</button>
                    </div>

                </div>
                <div class="modal-header">
                    <h5 class="modal-title" id="myModalLabel">TRANSFER DETAILS</h5>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Job Given By:</label>
                        <p id="JobGivenBy"></p>
                    </div>
                    <div class="form-group">
                        <label>PickUp Date:</label>
                        <p id="PickupDate"></p>
                    </div>
                    <div class="form-group">
                        <label>PickUp Time:</label>
                        <p id="PickupTime"></p>
                    </div>
                    <div class="form-group">
                        <label>PickUp From:</label>
                        <p id="PickupFrom"></p>
                    </div>
                    <div class="form-group">
                        <label>Drop To:</label>
                        <p id="DropTo"></p>
                    </div>
                    <div class="form-group">
                        <label style="color:#FF0000">Remarks:</label>
                        <p style="color: #FF0000" id="Remarks"></p>
                    </div>
                    <div class="form-group">
                        <label>Vehicle:</label>
                        <p id="Vehicle"></p>
                    </div>
                    <div class="form-group">
                        <label>No. of Passengers:</label>
                        <p id="NoofPassengers"></p>
                    </div>
                    <div class="form-group">
                        <label>No. of Luggages:</label>
                        <p id="NoofLuggages"></p>
                    </div>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title" id="myModalLabel">CUSTOMER DETAILS</h5>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Customer Name:</label>
                        <p id="CustomerName"></p>
                    </div>
                    <div class="form-group">
                        <label>Customer Mobile Number:</label>
                        <div id="phone-details" class="widget-text">
                            <i class="fab fa-whatsapp"></i>
                            <a id="CustomerMobileNumber" href=""></a>
                        </div>
                    </div>

                    @*<div id="phone-details" class="widget-text">
                            <i class="fa fa-whatsapp"></i>
