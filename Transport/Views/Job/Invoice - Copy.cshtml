@{
    Layout = null;
}

<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>Nissi Travels Invoice</title>
    <style type="text/css">
        * {
            margin: 0;
            padding: 0;
            text-indent: 0;
        }

        h1 {
            color: #F00;
            font-family: Arial, sans-serif;
            font-style: normal;
            font-weight: bold;
            text-decoration: none;
            font-size: 20pt;
        }

        p {
            color: black;
            font-family: Arial, sans-serif;
            font-style: normal;
            font-weight: normal;
            text-decoration: none;
            font-size: 10pt;
            margin: 0pt;
        }

        a {
            color: black;
            font-family: Arial, sans-serif;
            font-style: normal;
            font-weight: normal;
            text-decoration: none;
            font-size: 10pt;
        }

        .s1 {
            color: black;
            font-family: Arial, sans-serif;
            font-style: normal;
            font-weight: bold;
            text-decoration: none;
            font-size: 10pt;
        }

        .s2 {
            color: black;
            font-family: Arial, sans-serif;
            font-style: normal;
            font-weight: bold;
            text-decoration: none;
            font-size: 12pt;
        }

        .s3 {
            color: black;
            font-family: Arial, sans-serif;
            font-style: normal;
            font-weight: normal;
            text-decoration: none;
            font-size: 10pt;
        }

        .s4 {
            color: black;
            font-family: "Times New Roman", serif;
            font-style: normal;
            font-weight: normal;
            text-decoration: none;
            font-size: 10pt;
        }

        .s5 {
            color: black;
            font-family: Arial, sans-serif;
            font-style: normal;
            font-weight: bold;
            text-decoration: none;
            font-size: 11pt;
        }

        table, tbody {
            vertical-align: top;
            overflow: visible;
        }
    </style>
</head>
<body>
    <p style="text-indent: 0pt;text-align: left;"><span>
        <table border="0" cellspacing="0" cellpadding="0">
            <tr>
                <td>
                    <img width="103" height="106" src="data:image/jpg;base64," />
                </td>
                <td>
                    <h1 style="padding-top: 2pt;padding-left: 112pt;text-indent: 0pt;text-align: left;">
                        NISSI TOURS AND TRAVELS PTE. LTD
                    </h1>
                    <p style="padding-left: 75pt;text-indent: 0pt;text-align: center;">291 SERANGOON ROAD, SINGAPORE 218107</p>
                    <p style="padding-top: 2pt;padding-left: 75pt;text-indent: 0pt;text-align: center;">TEL NO +65 62920521, HP NO. +65 90686384</p>
                    <p style="padding-top: 2pt;padding-left: 75pt;text-indent: 0pt;text-align: center;">
                        <a href="mailto:Booking@nissitravels.com">Booking@nissitravels.com</a>
                    </p>
                </td>
            </tr>
        </table>
        </span>
    </p>
    
    <p style="padding-top: 9pt;text-indent: 0pt;text-align: left;"><br /></p>
    <table style="border-collapse:collapse;margin-left:6.9895pt" cellspacing="0">
        <tr style="height:21pt">
            <td style="width:315pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt" colspan="3" rowspan="2">
                <p class="s1" style="padding-top: 5pt;padding-left: 16pt;text-indent: 0pt;text-align: left;">
                    @ViewBag.CustomerName
                </p>
            </td>
            <td style="width:185pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt" colspan="3">
                <p class="s2" style="padding-top: 3pt;padding-left: 74pt;text-indent: 0pt;text-align: left;">INVOICE</p>
            </td>
        </tr>

        <tr style="height:65pt">
            <td style="width:37pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt">
                <p class="s3" style="padding-top: 4pt;padding-left: 14pt;text-indent: 0pt;line-height: 123%;text-align: left;"></p>
            </td>
            <td style="width:43pt;border-top-style:solid;border-top-width:1pt;border-bottom-style:solid;border-bottom-width:1pt">
                <p class="s3" style="padding-top: 4pt;padding-right: 5pt;text-indent: 0pt;text-align: left;">Invoice No:</p>
                <p class="s3" style="padding-top: 2pt; padding-right: 5pt; text-indent: 0pt; text-align: left;">Date:</p>
                <p class="s3" style="padding-top: 2pt; padding-right: 5pt; text-indent: 0pt; text-align: left;">Staff:</p>
                <p class="s3" style="padding-top: 2pt; padding-right: 5pt; text-indent: 0pt; text-align: left;">Terms:</p>
            </td>
            <td style="width: 43pt; border-top-style: solid; border-top-width: 1pt; border-bottom-style: solid; border-bottom-width: 1pt; border-right-style: solid; border-right-width: 1pt">
                <p class="s3" style="padding-top: 4pt; padding-right: 5pt; text-indent: 0pt; text-align: left;">@ViewBag.InvoiceNo</p>
                <p class="s3" style="padding-top: 2pt; padding-right: 5pt; text-indent: 0pt; text-align: left;">@ViewBag.InvoiceDate</p>
                <p class="s3" style="padding-top: 2pt; padding-right: 5pt; text-indent: 0pt; text-align: left;">@HttpContext.Current.Session["USER_NAME"]</p>
                <p class="s3" style="padding-top: 2pt; padding-right: 5pt; text-indent: 0pt; text-align: left;">Credit</p>
            </td>
            @*<td style="width:105pt;border-top-style:solid;border-top-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt">
                <p class="s1" style="padding-top: 4pt;padding-left: 5pt;padding-right: 36pt;text-indent: 0pt;line-height: 123%;text-align: left;">NTT-C5025 <span class="s3">24 May 2024 ADMIN</span></p>
                <p class="s3" style="padding-left: 5pt;text-indent: 0pt;text-align: left;">Credit</p>
            </td>*@
        </tr>
        <tr style="height:22pt">
            <td style="width:32pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt">
                <p class="s3" style="padding-top: 4pt;padding-left: 5pt;text-indent: 0pt;text-align: left;">S.No</p>
            </td>
            <td style="width:49pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt">
                <p class="s3" style="padding-top: 4pt;padding-left: 5pt;text-indent: 0pt;text-align: left;">Job Date</p>
            </td>
            <td style="width:41pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt">
                <p class="s3" style="padding-top: 4pt;padding-left: 5pt;text-indent: 0pt;text-align: left;">Job Time</p>
            </td>
            <td style="width:73pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt">
                <p class="s3" style="padding-top: 4pt;padding-left: 5pt;text-indent: 0pt;text-align: left;">Pickup</p>
            </td>
            <td style="width:78pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt">
                <p class="s3" style="padding-top: 4pt;padding-left: 5pt;text-indent: 0pt;text-align: left;">Dropoff</p>
            </td>
            <td style="width:57pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt">
                <p class="s3" style="padding-top: 4pt;padding-right: 5pt;text-indent: 0pt;text-align: right;">Amount</p>
            </td>
        </tr>
        @{int idx = 1;}
        @foreach (Transport.Model.JobModel mod in ViewBag.details)
        {
            <tr style="height:18pt">
                <td style="width:32pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-right-style:solid;border-right-width:1pt">
                    <p class="s3" style="padding-top: 4pt;padding-left: 5pt;text-indent: 0pt;text-align: left;">@idx</p>
                </td>
                <td style="width:49pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-right-style:solid;border-right-width:1pt">
                    <p class="s3" style="padding-top: 4pt;padding-left: 5pt;text-indent: 0pt;text-align: left;">@mod.JobDate</p>
                </td>
                <td style="width:41pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-right-style:solid;border-right-width:1pt">
                    <p class="s3" style="padding-top: 4pt;padding-left: 5pt;text-indent: 0pt;text-align: left;">@mod.JobTime</p>
                </td>
                <td style="width:73pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-right-style:solid;border-right-width:1pt">
                    <p class="s3" style="padding-top: 4pt; padding-right: 4pt; text-indent: 0pt; text-align: left;">@mod.JobFrom</p>
                </td>
                <td style="width:78pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-right-style:solid;border-right-width:1pt">
                    <p class="s3" style="padding-top: 4pt; padding-right: 4pt; text-indent: 0pt; text-align: left;">@mod.JobTo</p>
                </td>
                <td style="width:57pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-right-style:solid;border-right-width:1pt">
                    <p class="s3" style="padding-top: 4pt; padding-right: 4pt; text-indent: 0pt; text-align: left;">@mod.Credit</p>
                </td>
            </tr>
            idx++;
        }


            <tr style="height:82pt">
                <td style="width:352pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt" colspan="3" rowspan="2">
                    <p class="s1" style="padding-top: 4pt;padding-left: 8pt;text-indent: 0pt;text-align: left;">Amount in words :</p>
                    <p class="s3" style="padding-top: 8pt;padding-left: 16pt;text-indent: 0pt;text-align: left;">@ViewBag.AmountinWords</p>
                    <p class="s1" style="padding-top: 8pt;padding-left: 8pt;text-indent: 0pt;text-align: left;">Payment transfer to :</p>
                    <p class="s3" style="padding-top: 2pt;padding-left: 16pt;text-indent: 0pt;text-align: left;">Paynow: 201710306R</p>
                    <p class="s3" style="padding-top: 2pt;padding-left: 16pt;text-indent: 0pt;text-align: left;">DBS current Account: 107 - 903506 - 0</p>
                </td>
                <td style="width:91pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt" colspan="2">
                    <p class="s3" style="padding-top: 4pt;padding-left: 8pt;text-indent: 0pt;text-align: left;">Gross Amount</p>
                </td>
                <td style="width:57pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt">
                    <p class="s3" style="padding-top: 4pt;padding-right: 4pt;text-indent: 0pt;text-align: right;">$ @String.Format("{0:n}", ViewBag.GrossAmount)</p>
                </td>
            </tr>
            <tr style="height:22pt">
                <td style="width:91pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt" colspan="2">
                    <p class="s1" style="padding-top: 4pt;padding-left: 8pt;text-indent: 0pt;text-align: left;">NET Amount</p>
                </td>
                <td style="width:57pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt">
                    <p class="s1" style="padding-top: 4pt;padding-right: 4pt;text-indent: 0pt;text-align: right;">$ @String.Format("{0:n}", ViewBag.NetAmount)</p>
                </td>
            </tr>
            <tr style="height:114pt">
                <td style="width:500pt;border-top-style:solid;border-top-width:1pt;border-left-style:solid;border-left-width:1pt;border-bottom-style:solid;border-bottom-width:1pt;border-right-style:solid;border-right-width:1pt" colspan="6">
                    <p class="s5" style="padding-top: 11pt;padding-left: 259pt;text-indent: 0pt;text-align: left;">for NISSI TOURS AND TRAVELS PTE. LTD</p>
                    <p style="text-indent: 0pt;text-align: left;"><br /></p>
                    <p class="s3" style="padding-left: 87pt;text-indent: 0pt;text-align: left;">This is computer generated invoice signature not required.</p>
                </td>
            </tr>
        </table>
</body>
</html>

