                        <div class="card-header">
                            <span style="font-size: 18px;" class="m-0"><i class="fab fa-hornbill"></i></span>
                            <span style="font-size: 18px; border-left: 1px solid #ccc; padding-left: 10px;"> My Jobs</span>
                        </div>

                        <div class="card-body">
                            <div class="row">
