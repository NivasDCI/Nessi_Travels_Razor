@using Transport.Repository.Resource;
@{
    Layout = "";
}
<head>
    <style>
        .wallet-card {
            border-radius: 10px;
            color: #fff;
            padding: 18px 20px;
            margin-bottom: 12px;
        }

        .wc-earned {
            background: linear-gradient(135deg,#27ae60,#2ecc71);
        }

        .wc-handover {
            background: linear-gradient(135deg,#2980b9,#3498db);
        }

        .wc-expense {
            background: linear-gradient(135deg,#e67e22,#f39c12);
        }

        .wc-balance {
            background: linear-gradient(135deg,#8e44ad,#9b59b6);
        }

        .wallet-card .wc-label {
            font-size: 12px;
            opacity: .85;
        }

        .wallet-card .wc-amount {
            font-size: 24px;
            font-weight: 700;
        }

        .balance-negative .wc-amount {
            color: #ffe0e0 !important;
        }
    </style>
    <script>
    var GrdAdminWallet, GrdDayDetail, GrdAllHandovers;
    var selectedDriverID = 0;

    // ── Load drivers dropdown ────────────────────────────────────────────────
    $.ajax({
        type:"GET", url: BaseURL + "Common/Load_SystemUserDetail", datatype:"Json",
        success: function(data) {
            $("#ddlDriver option").remove();
            $.each(data, function(i,v) {
                $('#ddlDriver').append('<option value="'+v.ID+'">'+v.Name+'</option>');
            });
        }
    });

    // Load "Handed To" dropdown
    $.ajax({
        type:"GET", url: BaseURL + "Common/Load_SystemUserDetail", datatype:"Json",
        success: function(data) {
            $("#ddlHandedTo option").remove();
            $.each(data, function(i,v) {
                $('#ddlHandedTo').append('<option value="'+v.ID+'">'+v.Name+'</option>');
            });
        }
    });

    // Date pickers
    $("#TxtFromDate").datepicker({ format:Common_Date_Format, autoclose:true, uiLibrary:'bootstrap4', iconsLibrary:'fontawesome', size:'small' });
    $("#TxtToDate").datepicker({   format:Common_Date_Format, autoclose:true, uiLibrary:'bootstrap4', iconsLibrary:'fontawesome', size:'small' });
    $("#TxtHandoverDate").datepicker({ format:Common_Date_Format, autoclose:true, uiLibrary:'bootstrap4', iconsLibrary:'fontawesome', size:'small' });
    $("#TxtHOFromDate").datepicker({ format:Common_Date_Format, autoclose:true, uiLibrary:'bootstrap4', iconsLibrary:'fontawesome', size:'small' });
    $("#TxtHOToDate").datepicker({   format:Common_Date_Format, autoclose:true, uiLibrary:'bootstrap4', iconsLibrary:'fontawesome', size:'small' });

    // ── Summary cards ────────────────────────────────────────────────────────
    function LoadSummaryCards(summary) {
        var bal = parseFloat(summary.RunningBalance || 0);
        $("#CardEarned").text('$ ' + parseFloat(summary.TotalEarned     ||0).toFixed(2));
        $("#CardHandover").text('$ '+parseFloat(summary.TotalHandedOver ||0).toFixed(2));
        $("#CardExpense").text('$ ' +parseFloat(summary.TotalExpenses   ||0).toFixed(2));
        $("#CardBalance").text('$ ' +bal.toFixed(2));
        if(bal<0) $("#WcBalance").addClass("balance-negative");
        else      $("#WcBalance").removeClass("balance-negative");
    }

    // ── Admin wallet grid (for selected driver) ──────────────────────────────
    GrdAdminWallet = $("#GrdAdminWallet").grid({
        primaryKey: "WalletID",
        uiLibrary: "bootstrap4",
        responsive: true,
        dataSource: '',
        columns: [
            { field:"DisplayWalletDate", width:110, title:"DATE",          sortable:false, align:"left" },
            { field:"TotalRides",        width:60,  title:"RIDES",         sortable:false, align:"center" },
            { field:"TotalEarned",       width:100, title:"CASH EARNED",   sortable:false, align:"right",
              renderer:function(v){ return '<span style="color:#27ae60;font-weight:bold;">$ '+parseFloat(v).toFixed(2)+'</span>'; } },
            { field:"TotalHandedOver",   width:110, title:"HANDED OVER",   sortable:false, align:"right",
              renderer:function(v){ return v>0?'<span style="color:#2980b9;font-weight:bold;">$ '+parseFloat(v).toFixed(2)+'</span>':'-'; } },
            { field:"TotalExpenses",     width:100, title:"EXPENSES",      sortable:false, align:"right",
              renderer:function(v){ return v>0?'<span style="color:#e67e22;font-weight:bold;">$ '+parseFloat(v).toFixed(2)+'</span>':'-'; } },
            { field:"ClosingBalance",    width:110, title:"DAY BAL.",      sortable:false, align:"right",
              renderer:function(v){ var c=parseFloat(v)>=0?'#27ae60':'#e74c3c'; return '<span style="color:'+c+';font-weight:bold;">$ '+parseFloat(v).toFixed(2)+'</span>'; } },
            { field:"RunningBalance",    width:120, title:"RUNNING BALANCE",sortable:false, align:"right",
              renderer:function(v){ var c=parseFloat(v)>=0?'#8e44ad':'#e74c3c'; return '<strong style="color:'+c+';">$ '+parseFloat(v).toFixed(2)+'</strong>'; } },
            { field:"DisplayWalletDate", width:80,  title:"DETAILS",       sortable:false, align:"center",
              renderer:function(v,rec){ return '<button onclick="OpenDayDetails(\''+rec.DriverUserID+'\',\''+v+'\',\''+rec.DisplayWalletDate+'\')" class="badge badge-info" style="cursor:pointer;"><i class="fa fa-list"></i> Rides</button>'; } }
        ],
        pager: { enable:true, limit:30, sizes:ArrPaging }
    });

    GrdAdminWallet.on('dataBound', function(e, records, summary) {
        // summary comes from the server response — update cards
    });

    function LoadDriverWallet() {
        selectedDriverID = parseInt($('#ddlDriver').val()) || 0;
        if (!selectedDriverID) { alert('Please select a driver.'); return; }
        $.ajax({
            url: '@Url.Content("~/DriverWallet/WalletSummary_FindAll")',
            type: 'GET', dataType: 'json',
            data: { DriverUserID: selectedDriverID, FromDate: $('#TxtFromDate').val(), ToDate: $('#TxtToDate').val() },
            success: function(r) {
                if (r.summary) LoadSummaryCards(r.summary);
                GrdAdminWallet.reload({ DriverUserID: selectedDriverID, FromDate: $('#TxtFromDate').val(), ToDate: $('#TxtToDate').val() });
            }
        });
    }

    function ClearWalletFilter() {
        $('#TxtFromDate').val(''); $('#TxtToDate').val('');
        if (selectedDriverID) GrdAdminWallet.reload({ DriverUserID: selectedDriverID });
    }

    // ── Day drill-down ────────────────────────────────────────────────────────
    GrdDayDetail = $("#GrdDayDetail").grid({
        primaryKey: "JobCode", uiLibrary: "bootstrap4", responsive: true, dataSource: '',
        columns: [
            { field:"JobTime",      width:55,  title:"TIME",     sortable:false },
            { field:"JobFrom",      width:140, title:"FROM",     sortable:false },
            { field:"JobTo",        width:140, title:"TO",       sortable:false },
            { field:"CustomerName", width:110, title:"CUSTOMER", sortable:false },
            { field:"VehicleName",  width:75,  title:"VEHICLE",  sortable:false },
            { field:"Cash",         width:80,  title:"CASH",     sortable:false, align:"right",
              renderer:function(v){ return v>0?'<strong style="color:#27ae60;">$ '+parseFloat(v).toFixed(2)+'</strong>':'—'; } },
            { field:"Credit",       width:80,  title:"CREDIT",   sortable:false, align:"right",
              renderer:function(v){ return v>0?'<span style="color:#e74c3c;">$ '+parseFloat(v).toFixed(2)+'</span>':'—'; } }
        ]
    });
    GrdDayDetail.on('dataBound', function(e,records){
        var totalCash=0; $.each(records, function(){ totalCash+=parseFloat(this.Cash||0); });
        var tf=GrdDayDetail.children('tfoot'); tf.children('tr[data-role="summary"]').remove();
        tf.prepend('<tr data-role="summary" style="font-weight:bold;background:#f0f0f0;"><td colspan="5" style="text-align:right;padding:8px;">Total</td><td style="text-align:right;padding:8px;color:#27ae60;">$ '+totalCash.toFixed(2)+'</td><td></td></tr>');
    });

    function OpenDayDetails(driverID, dateVal, dateLabel) {
        $('#ModalDayLabel').text('Rides — ' + dateLabel);
        GrdDayDetail.loadData('@Url.Content("~/DriverWallet/DayDetails_FindAll")?DriverUserID='+driverID+'&WalletDate='+encodeURIComponent(dateVal));
        $('#modalDayDetail').modal('show');
    }

    // ── All Handovers grid (admin overview) ───────────────────────────────────
    GrdAllHandovers = $("#GrdAllHandovers").grid({
        primaryKey: "HandoverID", uiLibrary: "bootstrap4", responsive: true,
        dataSource: '@Url.Action("Handover_FindAll","DriverWallet")',
        columns: [
            { field:"DisplayHandoverDate", width:100, title:"DATE",       sortable:false },
            { field:"DriverName",          width:120, title:"DRIVER",     sortable:false },
            { field:"Amount",              width:90,  title:"AMOUNT(SGD)",sortable:false, align:"right",
              renderer:function(v){ return '<strong style="color:#2980b9;">$ '+parseFloat(v).toFixed(2)+'</strong>'; } },
            { field:"HandedToName",        width:120, title:"HANDED TO",  sortable:false },
            { field:"Remarks",             width:160, title:"REMARKS",    sortable:false },
            { field:"DisplayCreatedDate",  width:130, title:"RECORDED",   sortable:false },
            { field:"HandoverID",          width:60,  title:"Del",        sortable:false, align:"center",
              renderer:function(v){ return '<button onclick="DeleteHandover('+v+')" class="badge badge-danger" style="cursor:pointer;"><i class="fa fa-trash"></i></button>'; } }
        ],
        pager: { enable:true, limit:25, sizes:ArrPaging }
    });

    function HandoverSearch() {
        var uid = parseInt($('#ddlHODriver').val()) || 0;
        GrdAllHandovers.reload({ DriverUserID: uid||null, FromDate: $('#TxtHOFromDate').val(), ToDate: $('#TxtHOToDate').val() });
    }

    // ── Save Handover (Admin records driver handing over) ────────────────────
    $('#btnSaveHandover').click(function(){
        var driverID = parseInt($('#ddlHandoverDriver').val()) || 0;
        var amt      = parseFloat($('#TxtHandoverAmount').val());
        if (!driverID)     { alert('Please select a driver.'); return; }
        if (!amt || amt<=0){ alert('Please enter a valid amount.'); return; }
        if (!$('#TxtHandoverDate').val()){ alert('Please select a date.'); return; }

        $(this).prop('disabled',true).text('Saving...');
        $.ajax({
            url: '@Url.Content("~/DriverWallet/Handover_Save")',
            type: 'POST',
            data: JSON.stringify({
                DriverUserID:   driverID,
                HandoverDate:   $('#TxtHandoverDate').val(),
                Amount:         amt,
                HandedToUserID: parseInt($('#ddlHandedTo').val()) || 0,
                HandedToName:   $('#ddlHandedTo option:selected').text(),
                Remarks:        $('#TxtHandoverRemarks').val()
            }),
            dataType:'json', contentType:'application/json',
            success: function(r){
                $('#btnSaveHandover').prop('disabled',false).text('Save Handover');
                if(r.success){
                    $('#modalHandover').modal('hide');
                    GrdAllHandovers.reload({});
                    if(selectedDriverID===driverID) GrdAdminWallet.reload({DriverUserID:driverID});
                    $('#TxtHandoverAmount').val(''); $('#TxtHandoverDate').val(''); $('#TxtHandoverRemarks').val('');
                } else { alert('Error: '+r.message); }
            },
            error: function(){ $('#btnSaveHandover').prop('disabled',false).text('Save Handover'); alert('Server error.'); }
        });
    });

    function DeleteHandover(id){
        if(!confirm('Delete this handover record?')) return;
        $.ajax({
            url:'@Url.Content("~/DriverWallet/Handover_Delete")', type:'POST',
            data:JSON.stringify({HandoverID:id}), dataType:'json', contentType:'application/json',
            success:function(r){ if(r.success){ GrdAllHandovers.reload({}); if(selectedDriverID) GrdAdminWallet.reload({DriverUserID:selectedDriverID}); } }
        });
    }
    </script>
</head>
<body>
    <div class="content">
        <div class="container-fluid">

            <!-- ══ DRIVER SELECTOR ════════════════════════════════════════════════════ -->
            <div class="card card-pd mb-3">
                <div class="card-header" style="background:#2c3e50;color:#fff;">
                    <i class="fa fa-user-tie"></i>&nbsp; Driver Wallet Overview (Admin)
                </div>
                <div class="card-body">
                    <div class="row align-items-end">
                        <div class="col-sm-3">
                            <label>Select Driver</label>
                            @Html.DropDownList("ddlDriver", new SelectList(string.Empty, "Value", "Text"), new { @class = "form-control select2", @id = "ddlDriver" })
                        </div>
                        <div class="col-sm-2">
                            <label>From Date</label>
                            <input type="text" id="TxtFromDate" class="form-control">
                        </div>
                        <div class="col-sm-2">
                            <label>To Date</label>
                            <input type="text" id="TxtToDate" class="form-control">
                        </div>
                        <div class="col-sm-2">
                            <button type="button" class="btn btn-primary btn-block" onclick="LoadDriverWallet()"><i class="fa fa-search"></i> Load Wallet</button>
                        </div>
                        <div class="col-sm-2">
                            <button type="button" class="btn btn-secondary btn-block" onclick="ClearWalletFilter()"><i class="fa fa-paint-brush"></i> Clear Filter</button>
                        </div>
                        <div class="col-sm-1">
                            <button type="button" class="btn btn-success btn-block" data-toggle="modal" data-target="#modalHandover" title="Record handover"><i class="fa fa-hand-holding-usd"></i></button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ══ SUMMARY CARDS ══════════════════════════════════════════════════════ -->
            <div class="row mb-3" id="SummaryCards" style="display:none;">
                <div class="col-sm-3"><div class="wallet-card wc-earned">   <div class="wc-label"><i class="fa fa-dollar-sign"></i> Total Earned</div>  <div class="wc-amount" id="CardEarned">$ 0.00</div></div></div>
                <div class="col-sm-3"><div class="wallet-card wc-handover"> <div class="wc-label"><i class="fa fa-hand-holding-usd"></i> Handed Over</div><div class="wc-amount" id="CardHandover">$ 0.00</div></div></div>
                <div class="col-sm-3"><div class="wallet-card wc-expense">  <div class="wc-label"><i class="fa fa-receipt"></i> Expenses</div>           <div class="wc-amount" id="CardExpense">$ 0.00</div></div></div>
                <div class="col-sm-3"><div class="wallet-card wc-balance" id="WcBalance"><div class="wc-label"><i class="fa fa-wallet"></i> Wallet Balance</div><div class="wc-amount" id="CardBalance">$ 0.00</div></div></div>
            </div>
            <script>// Show cards when driver is selected
        $('#ddlDriver').change(function(){ if($(this).val()!='0') $('#SummaryCards').show(); });</script>

            <!-- ══ DRIVER WALLET DAILY GRID ══════════════════════════════════════════ -->
            <div class="card card-pd mb-3">
                <div class="card-header"><i class="fa fa-calendar-alt"></i>&nbsp; Daily Wallet Summary</div>
                <div class="card-body">
                    <div class="box-body table-responsive no-padding">
                        <table id="GrdAdminWallet" class="table table-hover"></table>
                    </div>
                </div>
            </div>

            <!-- ══ ALL HANDOVERS ═════════════════════════════════════════════════════ -->
            <div class="card card-pd mb-3">
                <div class="card-header">
                    <i class="fa fa-exchange-alt"></i>&nbsp; All Handover Records
                    <div style="float:right;">
                        <button type="button" class="btn btn-primary btn-sm mr-2" data-toggle="modal" data-target="#modalHandover">
                            <i class="fa fa-plus"></i> Record Handover
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-sm-3">
                            <label>Driver</label>
                            @Html.DropDownList("ddlHODriver", new SelectList(string.Empty, "Value", "Text"), new { @class = "form-control select2", @id = "ddlHODriver" })
                        </div>
                        <div class="col-sm-2">
                            <label>From</label>
                            <input type="text" id="TxtHOFromDate" class="form-control">
                        </div>
                        <div class="col-sm-2">
                            <label>To</label>
                            <input type="text" id="TxtHOToDate" class="form-control">
                        </div>
                        <div class="col-sm-2 pdt-25">
                            <button type="button" class="btn btn-secondary btn-block" onclick="HandoverSearch()"><i class="fa fa-search"></i> Filter</button>
                        </div>
                    </div>
                    <script>$.ajax({ type:"GET", url: BaseURL + "Common/Load_SystemUserDetail", datatype:"Json",
                    success: function(data) {
                        $("#ddlHODriver option").remove();
                        $('#ddlHODriver').append('<option value="0">All Drivers</option>');
                        $.each(data, function(i,v){ if(v.ID!=0) $('#ddlHODriver').append('<option value="'+v.ID+'">'+v.Name+'</option>'); });
                    }
                });</script>
                    <div class="box-body table-responsive no-padding">
                        <table id="GrdAllHandovers" class="table table-hover"></table>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- ══ MODAL: Day Detail ═══════════════════════════════════════════════════════ -->
    <div class="modal fade" id="modalDayDetail" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background:#2c3e50;color:#fff;">
                    <h5 class="modal-title" id="ModalDayLabel"><i class="fa fa-list"></i> Rides</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="box-body table-responsive no-padding">
                        <table id="GrdDayDetail" class="table table-hover"></table>
                    </div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button></div>
            </div>
        </div>
    </div>

    <!-- ══ MODAL: Record Handover (Admin) ════════════════════════════════════════ -->
    <div class="modal fade" id="modalHandover" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background:#2980b9;color:#fff;">
                    <h5 class="modal-title"><i class="fa fa-hand-holding-usd"></i> Record Cash Handover</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Driver <span style="color:red">*</span></label>
                        @Html.DropDownList("ddlHandoverDriver", new SelectList(string.Empty, "Value", "Text"), new { @class = "form-control select2", @id = "ddlHandoverDriver" })
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Handover Date <span style="color:red">*</span></label>
                                <input type="text" id="TxtHandoverDate" class="form-control">
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Amount (SGD) <span style="color:red">*</span></label>
                                <input type="number" id="TxtHandoverAmount" class="form-control" placeholder="0.00" step="0.01" min="0">
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Handed To</label>
                        @Html.DropDownList("ddlHandedTo", new SelectList(string.Empty, "Value", "Text"), new { @class = "form-control select2", @id = "ddlHandedTo" })
                    </div>
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea id="TxtHandoverRemarks" class="form-control" rows="2" placeholder="Optional notes..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnSaveHandover" class="btn btn-primary"><i class="fa fa-save"></i> Save Handover</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
    <script>// Populate driver dropdown in the handover modal from the already-loaded select
    $('#modalHandover').on('show.bs.modal', function(){
        var opts = $('#ddlDriver option').clone();
        $('#ddlHandoverDriver').empty().append(opts);
        if(selectedDriverID) $('#ddlHandoverDriver').val(selectedDriverID);
    });</script>
</body>
