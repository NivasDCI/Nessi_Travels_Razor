@using Transport.Repository.Resource;
@{
    Layout = "";
}
<head>
    <style>
        .wcard {
            border-radius: 10px;
            color: #fff;
            padding: 16px 18px;
            margin-bottom: 14px;
        }

        .wc-earn {
            background: linear-gradient(135deg,#1a9e6e,#27ae60);
        }

        .wc-over {
            background: linear-gradient(135deg,#1a6fa3,#2980b9);
        }

        .wc-exp {
            background: linear-gradient(135deg,#a93226,#e74c3c);
        }

        .wc-bal {
            background: linear-gradient(135deg,#6c3483,#8e44ad);
        }

        .wcard .wc-lbl {
            font-size: 11px;
            opacity: .85;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .wcard .wc-amt {
            font-size: 22px;
            font-weight: 700;
            margin-top: 4px;
        }

        .wcard .wc-sub {
            font-size: 11px;
            opacity: .7;
        }

        .bal-neg .wc-amt {
            color: #ffcccc !important;
        }
    </style>
    <script>var SEL_DRIVER = 0;
    var dpOpts = { format: Common_Date_Format, autoclose: true, uiLibrary: 'bootstrap4', iconsLibrary: 'fontawesome', size: 'small' };
    $('#TxtFrom').datepicker(dpOpts);
    $('#TxtTo').datepicker(dpOpts);
    $('#TxtHODate').datepicker(dpOpts);
    $('#TxtHOFrom').datepicker(dpOpts);
    $('#TxtHOTo').datepicker(dpOpts);
    $('#TxtExpFrom').datepicker(dpOpts);
    $('#TxtExpTo').datepicker(dpOpts);

    // Load all dropdowns
    function loadUsers(ids, addBlank) {
        $.ajax({ type: 'GET', url: BaseURL + 'Common/Load_SystemUserDetail', datatype: 'Json',
            success: function (data) {
                $.each(ids, function (i, id) {
                    var $el = $('#' + id);
                    $el.empty();
                    if (addBlank) $el.append('<option value="0">-- Select Driver --</option>');
                    $.each(data, function (j, v) {
                        if (v.ID > 0) $el.append('<option value="' + v.ID + '">' + v.Name + '</option>');
                    });
                });
            }
        });
    }
    loadUsers(['ddlDriver', 'ddlHODriver', 'ddlHandedTo'], true);

    // Balance cards
    function LoadBalance(uid) {
        $.ajax({ url: BaseURL + 'Wallet/DriverWallet_FindAll', type: 'GET', dataType: 'json',
            data: { DriverUserID: uid, FromDate: '', ToDate: '' },
            success: function (r) {
                if (r.balance) {
                    $('#CardEarned').text('$ ' + parseFloat(r.balance.TotalEarned || 0).toFixed(2));
                    $('#CardHandover').text('$ ' + parseFloat(r.balance.TotalHandedOver || 0).toFixed(2));
                    $('#CardExpense').text('$ ' + parseFloat(r.balance.TotalExpenses || 0).toFixed(2));
                    var bal = parseFloat(r.balance.WalletBalance || 0);
                    $('#CardBalance').text('$ ' + bal.toFixed(2));
                    if (bal < 0) $('#WcBal').addClass('bal-neg'); else $('#WcBal').removeClass('bal-neg');
                }
            }
        });
    }

    // Daily wallet summary grid
    var GrdWallet = $('#GrdWallet').grid({
        primaryKey: 'WalletID', uiLibrary: 'bootstrap4', responsive: true, dataSource: '',
        columns: [
            { field: 'DisplayWalletDate', width: 100, title: 'DATE',         sortable: false },
            { field: 'TotalRides',        width: 55,  title: 'RIDES',        sortable: false, align: 'center' },
            { field: 'TotalEarned', width: 95, title: 'EARNED', sortable: false, align: 'right',
              renderer: function (v) { return '<span style="color:#27ae60;font-weight:bold;">$ ' + parseFloat(v).toFixed(2) + '</span>'; } },
            { field: 'TotalHandedOver', width: 100, title: 'HANDED OVER', sortable: false, align: 'right',
              renderer: function (v) { return parseFloat(v) > 0 ? '<span style="color:#2980b9;font-weight:bold;">$ ' + parseFloat(v).toFixed(2) + '</span>' : '&mdash;'; } },
            { field: 'TotalExpenses', width: 90, title: 'EXPENSES', sortable: false, align: 'right',
              renderer: function (v) { return parseFloat(v) > 0 ? '<span style="color:#e74c3c;font-weight:bold;">$ ' + parseFloat(v).toFixed(2) + '</span>' : '&mdash;'; } },
            { field: 'ClosingBalance', width: 100, title: 'DAY BAL.', sortable: false, align: 'right',
              renderer: function (v) { var c = parseFloat(v) >= 0 ? '#27ae60' : '#e74c3c'; return '<strong style="color:' + c + ';">$ ' + parseFloat(v).toFixed(2) + '</strong>'; } },
            { field: 'RunningBalance', width: 110, title: 'RUNNING BAL.', sortable: false, align: 'right',
              renderer: function (v) { var c = parseFloat(v) >= 0 ? '#8e44ad' : '#e74c3c'; return '<strong style="color:' + c + ';">$ ' + parseFloat(v).toFixed(2) + '</strong>'; } }
        ],
        pager: { enable: true, limit: 30, sizes: ArrPaging }
    });

    // Cash history grid
    var GrdCash = $('#GrdCash').grid({
        primaryKey: 'JobCode', uiLibrary: 'bootstrap4', responsive: true, dataSource: '',
        columns: [
            { field: 'DisplayJobDate', width: 100, title: 'DATE',     sortable: false },
            { field: 'JobTime',        width: 55,  title: 'TIME',     sortable: false },
            { field: 'JobFrom',        width: 130, title: 'FROM',     sortable: false },
            { field: 'JobTo',          width: 130, title: 'TO',       sortable: false },
            { field: 'CustomerName',   width: 110, title: 'CUSTOMER', sortable: false },
            { field: 'Cash', width: 85, title: 'CASH (SGD)', sortable: false, align: 'right',
              renderer: function (v) { return parseFloat(v) > 0 ? '<strong style="color:#27ae60;">$ ' + parseFloat(v).toFixed(2) + '</strong>' : '&mdash;'; } }
        ],
        pager: { enable: true, limit: 30, sizes: ArrPaging }
    });

    // Handover grid
    var GrdHO = $('#GrdHO').grid({
        primaryKey: 'HandoverID', uiLibrary: 'bootstrap4', responsive: true, dataSource: '',
        columns: [
            { field: 'DisplayHandoverDate', width: 100, title: 'DATE',      sortable: false },
            { field: 'Amount', width: 100, title: 'AMOUNT (SGD)', sortable: false, align: 'right',
              renderer: function (v) { return '<strong style="color:#2980b9;">$ ' + parseFloat(v).toFixed(2) + '</strong>'; } },
            { field: 'HandedToName',        width: 120, title: 'HANDED TO', sortable: false },
            { field: 'Remarks',             width: 160, title: 'REMARKS',   sortable: false },
            { field: 'DisplayCreatedDate',  width: 110, title: 'RECORDED',  sortable: false },
            { field: 'HandoverID', width: 55, title: '', sortable: false, align: 'center',
              renderer: function (v) { return '<button onclick="DelHO(' + v + ')" class="badge badge-danger" style="cursor:pointer;border:none;padding:4px 8px;"><i class="fa fa-trash"></i></button>'; } }
        ],
        pager: { enable: true, limit: 20, sizes: ArrPaging }
    });

    // Expense grid
    var GrdExp = $('#GrdExp').grid({
        primaryKey: 'DriverExpenseID', uiLibrary: 'bootstrap4', responsive: true, dataSource: '',
        columns: [
            { field: 'DisplayExpenseDate', width: 100, title: 'DATE',     sortable: false },
            { field: 'Category',           width: 110, title: 'CATEGORY', sortable: false },
            { field: 'Amount', width: 100, title: 'AMOUNT (SGD)', sortable: false, align: 'right',
              renderer: function (v) { return '<strong style="color:#e74c3c;">$ ' + parseFloat(v).toFixed(2) + '</strong>'; } },
            { field: 'Remarks',            width: 160, title: 'REMARKS',  sortable: false },
            { field: 'DisplayCreatedDate', width: 110, title: 'RECORDED', sortable: false }
        ],
        pager: { enable: true, limit: 20, sizes: ArrPaging }
    });

    function LoadDriver() {
        SEL_DRIVER = parseInt($('#ddlDriver').val()) || 0;
        if (SEL_DRIVER <= 0) { alert('Please select a driver.'); return; }
        $('#summaryCards').show();
        LoadBalance(SEL_DRIVER);
        GrdWallet.reload({ DriverUserID: SEL_DRIVER, FromDate: $('#TxtFrom').val(), ToDate: $('#TxtTo').val() });
        GrdCash.reload({ DriverUserID: SEL_DRIVER });
        GrdHO.reload({ DriverUserID: SEL_DRIVER });
        GrdExp.reload({ DriverUserID: SEL_DRIVER });
    }

    function WalletSearch() {
        if (SEL_DRIVER <= 0) return;
        GrdWallet.reload({ DriverUserID: SEL_DRIVER, FromDate: $('#TxtFrom').val(), ToDate: $('#TxtTo').val() });
    }
    function WalletClear() {
        $('#TxtFrom,#TxtTo').val('');
        if (SEL_DRIVER > 0) GrdWallet.reload({ DriverUserID: SEL_DRIVER });
    }

    // Save handover on behalf of driver
    $('#btnSaveHO').click(function () {
        var driverUID = parseInt($('#ddlHODriver').val()) || 0;
        var amt = parseFloat($('#TxtHOAmount').val());
        var dt  = $('#TxtHODate').val();
        if (driverUID <= 0) { alert('Please select a driver.'); return; }
        if (!dt)            { alert('Please select a date.');   return; }
        if (!amt || amt <= 0) { alert('Please enter a valid amount.'); return; }

        $(this).prop('disabled', true).text('Saving...');
        $.ajax({
            url: BaseURL + 'Wallet/Handover_Save', type: 'POST',
            dataType: 'json', contentType: 'application/json',
            data: JSON.stringify({
                DriverUserID:   driverUID,
                HandoverDate:   dt,
                Amount:         amt,
                HandedToUserID: parseInt($('#ddlHandedTo').val()) || 0,
                HandedToName:   $('#ddlHandedTo option:selected').text(),
                Remarks:        $('#TxtHORemarks').val()
            }),
            success: function (r) {
                $('#btnSaveHO').prop('disabled', false).text('Save');
                if (r.success) {
                    $('#modalHO').modal('hide');
                    if (SEL_DRIVER === driverUID) { LoadBalance(SEL_DRIVER); GrdHO.reload({ DriverUserID: SEL_DRIVER }); GrdWallet.reload({ DriverUserID: SEL_DRIVER }); }
                    $('#TxtHODate,#TxtHOAmount,#TxtHORemarks').val('');
                } else { alert('Error: ' + (r.message || 'Failed.')); }
            },
            error: function () { $('#btnSaveHO').prop('disabled', false).text('Save'); alert('Server error.'); }
        });
    });

    function DelHO(id) {
        if (!confirm('Delete this handover?')) return;
        $.ajax({
            url: BaseURL + 'Wallet/Handover_Delete', type: 'POST',
            dataType: 'json', contentType: 'application/json',
            data: JSON.stringify({ HandoverID: id }),
            success: function (r) { if (r.success && SEL_DRIVER > 0) { LoadBalance(SEL_DRIVER); GrdHO.reload({ DriverUserID: SEL_DRIVER }); GrdWallet.reload({ DriverUserID: SEL_DRIVER }); } }
        });
    }

    $('#summaryCards').hide();</script>
</head>
<body>
    <div class="content">
        <div class="container-fluid">

            <!-- DRIVER SELECTOR -->
            <div class="card card-pd mb-3">
                <div class="card-header">
                    <span style="font-size:18px;"><i class="fa fa-id-card"></i></span>
                    <span style="font-size:18px; border-left:1px solid #ccc; padding-left:10px;"> Driver Wallet — Admin View</span>
                    <div style="float:right;">
                        <button type="button" class="btn btn-primary btn-sm mr-2" data-toggle="modal" data-target="#modalHO">
                            <i class="fa fa-hand-holding-usd"></i> Record Handover
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row align-items-end">
                        <div class="col-sm-3">
                            <label>Select Driver <span class="text-danger">*</span></label>
                            @Html.DropDownList("ddlDriver", new SelectList(string.Empty, "Value", "Text"), new { @class = "form-control select2", @id = "ddlDriver" })
                        </div>
                        <div class="col-sm-2">
                            <label>From Date</label>
                            <input type="text" id="TxtFrom" class="form-control" />
                        </div>
                        <div class="col-sm-2">
                            <label>To Date</label>
                            <input type="text" id="TxtTo" class="form-control" />
                        </div>
                        <div class="col-sm-2 pdt-25">
                            <button type="button" class="btn btn-primary btn-block" onclick="LoadDriver()"><i class="fa fa-search"></i> Load</button>
                        </div>
                        <div class="col-sm-2 pdt-25">
                            <button type="button" class="btn btn-secondary btn-block" onclick="WalletClear()"><i class="fa fa-paint-brush"></i> Clear</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BALANCE CARDS -->
            <div class="row mb-3" id="summaryCards">
                <div class="col-sm-3">
                    <div class="wcard wc-earn"><div class="wc-lbl"><i class="fa fa-dollar-sign"></i> Total Earned</div><div class="wc-amt" id="CardEarned">$ 0.00</div><div class="wc-sub">from cash rides</div></div>
                </div>
                <div class="col-sm-3">
                    <div class="wcard wc-over"><div class="wc-lbl"><i class="fa fa-hand-holding-usd"></i> Handed Over</div><div class="wc-amt" id="CardHandover">$ 0.00</div><div class="wc-sub">submitted to admin</div></div>
                </div>
                <div class="col-sm-3">
                    <div class="wcard wc-exp"><div class="wc-lbl"><i class="fa fa-receipt"></i> Expenses</div><div class="wc-amt" id="CardExpense">$ 0.00</div><div class="wc-sub">personal expenses</div></div>
                </div>
                <div class="col-sm-3">
                    <div class="wcard wc-bal" id="WcBal"><div class="wc-lbl"><i class="fa fa-wallet"></i> Balance</div><div class="wc-amt" id="CardBalance">$ 0.00</div><div class="wc-sub">remaining with driver</div></div>
                </div>
            </div>

            <!-- DAILY SUMMARY -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header"><i class="fa fa-calendar-alt"></i>&nbsp; Daily Wallet Summary</div>
                        <div class="card-body">
                            <div class="box-body table-responsive no-padding">
                                <table id="GrdWallet" class="table table-hover"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CASH COLLECTION HISTORY -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header"><i class="fa fa-money-bill-wave"></i>&nbsp; Cash Collection History</div>
                        <div class="card-body">
                            <div class="box-body table-responsive no-padding">
                                <table id="GrdCash" class="table table-hover"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- HANDOVER RECORDS -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header"><i class="fa fa-exchange-alt"></i>&nbsp; Handover Records</div>
                        <div class="card-body">
                            <div class="box-body table-responsive no-padding">
                                <table id="GrdHO" class="table table-hover"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- DRIVER EXPENSES -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header"><i class="fa fa-receipt"></i>&nbsp; Driver Expenses</div>
                        <div class="card-body">
                            <div class="box-body table-responsive no-padding">
                                <table id="GrdExp" class="table table-hover"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- MODAL: Record Handover -->
    <div class="modal fade" id="modalHO" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background:#2980b9;color:#fff;">
                    <h5 class="modal-title"><i class="fa fa-hand-holding-usd"></i> Record Handover</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Driver <span class="text-danger">*</span></label>
                        @Html.DropDownList("ddlHODriver", new SelectList(string.Empty, "Value", "Text"), new { @class = "form-control select2", @id = "ddlHODriver" })
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Date <span class="text-danger">*</span></label>
                                <input type="text" id="TxtHODate" class="form-control" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Amount (SGD) <span class="text-danger">*</span></label>
                                <input type="number" id="TxtHOAmount" class="form-control" placeholder="0.00" step="0.01" min="0" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Received By</label>
                        @Html.DropDownList("ddlHandedTo", new SelectList(string.Empty, "Value", "Text"), new { @class = "form-control select2", @id = "ddlHandedTo" })
                    </div>
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea id="TxtHORemarks" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnSaveHO" class="btn btn-primary"><i class="fa fa-save"></i> Save</button>
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</body>
