@using Transport.Repository.Resource
@{
    Layout = "";
    string uidStr = (ViewBag.CurrentUID != null) ? ViewBag.CurrentUID.ToString() : "0";
}
<head>
    <style>
        .wcard {
            border-radius: 10px;
            color: #fff;
            padding: 16px 18px;
            margin-bottom: 14px;
        }

        .wc-earn {
            background: linear-gradient(135deg,#1a9e6e,#27ae60);
        }

        .wc-hand {
            background: linear-gradient(135deg,#1a6fa3,#2980b9);
        }

        .wc-dexp {
            background: linear-gradient(135deg,#d68910,#f39c12);
        }

        .wc-bal {
            background: linear-gradient(135deg,#6c3483,#8e44ad);
        }

        .wc-recv {
            background: linear-gradient(135deg,#117a8b,#17a2b8);
        }

        .wcard .wc-lbl {
            font-size: 11px;
            opacity: .85;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .wcard .wc-amt {
            font-size: 22px;
            font-weight: 700;
            margin-top: 4px;
        }

        .wcard .wc-sub {
            font-size: 11px;
            opacity: .7;
        }

        /* Transaction History */
        .tx-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

            .tx-table th {
                background: #2c3e50;
                color: #fff;
                padding: 8px 10px;
                text-align: left;
            }

            .tx-table td {
                padding: 8px 10px;
                border-bottom: 1px solid #f0f0f0;
            }

            .tx-table tr:hover td {
                background: #fafafa;
            }

        .tx-credit {
            color: #27ae60;
            font-weight: 700;
        }

        .tx-debit {
            color: #e74c3c;
            font-weight: 700;
        }

        .tx-badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 600;
        }

        .tx-badge-credit {
            background: #d4edda;
            color: #155724;
        }

        .tx-badge-debit {
            background: #f8d7da;
            color: #721c24;
        }

        .tx-source {
            font-size: 11px;
            color: #888;
        }
    </style>

    <script>
        var CURRENT_UID = @uidStr;
        var dpOpts = { format: Common_Date_Format, autoclose: true, uiLibrary: 'bootstrap4', iconsLibrary: 'fontawesome', size: 'small' };

        // Modal datepicker options — zIndex modal (1050) விட அதிகமா வேணும்
        var dpOptsModal = $.extend({}, dpOpts, { zIndex: 1100 });

        // ── 1. WALLET SUMMARY CARDS + DAILY TABLE ─────────────────────────────
        function LoadWallet() {
            $.ajax({
                url: BaseURL + 'Wallet/MyWallet_FindAll',
                type: 'GET',
                data: { FromDate: $('#TxtWFrom').val(), ToDate: $('#TxtWTo').val() },
                dataType: 'json',
                success: function (r) {
                    if (r.balance) {
                        var b       = r.balance;
                        var earned  = parseFloat(b.TotalEarned    || 0);
                        var handed  = parseFloat(b.TotalHandedOver || 0);
                        var expense = parseFloat(b.TotalExpenses   || 0);
                        var bal     = earned - handed - expense;
                        $('#CardEarned').text('$ ' + earned.toFixed(2));
                        $('#CardHanded').text('$ ' + handed.toFixed(2));
                        $('#CardDExp'  ).text('$ ' + expense.toFixed(2));
                        $('#CardBal'   ).text('$ ' + bal.toFixed(2));
                        if (bal < 0) $('#WcBal').css('background','linear-gradient(135deg,#c0392b,#e74c3c)');
                        else         $('#WcBal').css('background','linear-gradient(135deg,#6c3483,#8e44ad)');
                    }
                    var tbody = $('#tblWallet');
                    tbody.empty();
                    if (r.records && r.records.length > 0) {
                        $.each(r.records, function (i, d) {
                            var rows = r.records.slice().reverse();
                            var run = 0; var runMap = {};
                            $.each(rows, function(i, x) {
                                run += parseFloat(x.TotalEarned) - parseFloat(x.TotalHandedOver) - parseFloat(x.TotalExpenses);
                                runMap[x.DisplayWalletDate] = run;
                            });
                            var balColor = runMap[d.DisplayWalletDate] >= 0 ? '#8e44ad' : '#e74c3c';
                            tbody.append(
                                '<tr>' +
                                '<td>' + d.DisplayWalletDate + '</td>' +
                                '<td style="text-align:center;">' + d.TotalRides + '</td>' +
                                '<td style="text-align:right;color:#27ae60;font-weight:bold;">$ ' + parseFloat(d.TotalEarned).toFixed(2) + '</td>' +
                                '<td style="text-align:right;color:#2980b9;font-weight:bold;">$ ' + parseFloat(d.TotalHandedOver).toFixed(2) + '</td>' +
                                '<td style="text-align:right;color:#f39c12;font-weight:bold;">$ ' + parseFloat(d.TotalExpenses).toFixed(2) + '</td>' +
                                '<td style="text-align:right;color:' + balColor + ';font-weight:bold;">$ ' + runMap[d.DisplayWalletDate].toFixed(2) + '</td>' +
                                '</tr>'
                            );
                        });
                    } else {
                        tbody.append('<tr><td colspan="6" style="text-align:center;color:#999;padding:20px;">No wallet records found.</td></tr>');
                    }
                }
            });
        }

        // ── 2. WALLET TRANSACTION HISTORY ─────────────────────────────────────
        function todayStr() {
            var d = new Date();
            var mn = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
            return ('0'+d.getDate()).slice(-2) + '-' + mn[d.getMonth()] + '-' + d.getFullYear();
        }

        function LoadTxHistory(from, to) {
            from = from || todayStr();
            to   = to   || todayStr();

            if (from === to) {
                $('#TxDateLabel').text(from === todayStr() ? 'Today' : from);
            } else {
                $('#TxDateLabel').html(from + ' &rarr; ' + to);
            }

            $('#tblTxBody').html(
                '<tr><td colspan="5" style="text-align:center;padding:20px;color:#aaa;">' +
                '<i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>'
            );

            $.ajax({
                url: BaseURL + 'Wallet/WalletHistory_FindAll',
                type: 'GET',
                data: { UserID: CURRENT_UID, FromDate: from, ToDate: to },
                dataType: 'json',
                success: function (r) {
                    var tbody = $('#tblTxBody');
                    tbody.empty();
                    if (!r.records || r.records.length === 0) {
                        tbody.html(
                            '<tr><td colspan="5" style="text-align:center;padding:30px;color:#999;">' +
                            '<i class="fa fa-inbox fa-2x"></i><br/>No transactions for this period.</td></tr>'
                        );
                        return;
                    }
                    $.each(r.records, function (i, t) {
                        var isCredit = (t.TxType || '').toUpperCase() === 'CREDIT';
                        var badge    = isCredit
                            ? '<span class="tx-badge tx-badge-credit"><i class="fa fa-arrow-up"></i> CREDIT</span>'
                            : '<span class="tx-badge tx-badge-debit"><i class="fa fa-arrow-down"></i> DEBIT</span>';
                        var amtCls = isCredit ? 'tx-credit' : 'tx-debit';
                        var sign   = isCredit ? '+' : '&minus;';

                        var srcDetail = '<strong>' + (t.SourceLabel || t.Source || '') + '</strong>';
                        if (t.Source === 'Job' && t.JobFrom) {
                            srcDetail += '<br><span class="tx-source"><i class="fa fa-map-marker-alt"></i> ' +
                                t.JobFrom + ' → ' + (t.JobTo || '') +
                                (t.CustomerName ? ' &nbsp;|&nbsp; ' + t.CustomerName : '') + '</span>';
                        }
                        if (t.Remarks && t.Remarks.trim()) {
                            srcDetail += '<br><span class="tx-source" style="color:#bbb;"><i class="fa fa-comment"></i> ' + t.Remarks + '</span>';
                        }

                        tbody.append(
                            '<tr>' +
                            '<td style="white-space:nowrap;color:#666;font-size:11px;">' + (t.DisplayDate || '') + '</td>' +
                            '<td>' + badge + '</td>' +
                            '<td>' + srcDetail + '</td>' +
                            '<td style="text-align:right;" class="' + amtCls + '">' + sign + ' $' + parseFloat(t.Amount).toFixed(2) + '</td>' +
                            '<td style="text-align:right;color:#555;font-weight:600;font-size:12px;">$' + parseFloat(t.BalanceAfter).toFixed(2) + '</td>' +
                            '</tr>'
                        );
                    });
                },
                error: function () {
                    $('#tblTxBody').html(
                        '<tr><td colspan="5" style="text-align:center;padding:20px;color:#e74c3c;">' +
                        '<i class="fa fa-exclamation-circle"></i> Error loading history.</td></tr>'
                    );
                }
            });
        }

        function ApplyTxFilter() {
            var from = $('#TxtTxModalFrom').val();
            var to   = $('#TxtTxModalTo').val();
            if (!from || !to) { alert('Please select both dates.'); return; }
            $('#modalTxFilter').modal('hide');
            LoadTxHistory(from, to);
        }

        function TxPill(type) {
            var mn = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
            var now = new Date();
            var from, to;
            if (type === 'today') {
                from = to = todayStr();
            } else if (type === 'week') {
                var start = new Date(now); start.setDate(now.getDate() - 6);
                from = ('0'+start.getDate()).slice(-2)+'-'+mn[start.getMonth()]+'-'+start.getFullYear();
                to   = todayStr();
            } else if (type === 'month') {
                from = '01-' + mn[now.getMonth()] + '-' + now.getFullYear();
                to   = todayStr();
            }
            $('#modalTxFilter').modal('hide');
            LoadTxHistory(from, to);
        }

        // ── 3. CASH HISTORY GRID ──────────────────────────────────────────────
        var GrdCash;
        function InitCashGrid() {
            GrdCash = $('#GrdCash').grid({
                primaryKey: 'JobCode', uiLibrary: 'bootstrap4', responsive: true,
                dataSource: BaseURL + 'Wallet/MyCashHistory_FindAll',
                columns: [
                    { field: 'DisplayJobDate', width:100, title:'DATE',     sortable:false },
                    { field: 'JobTime',        width:80,  title:'TIME',     sortable:false },
                    { field: 'CustomerName',   width:140, title:'CUSTOMER', sortable:false },
                    { field: 'JobFrom',        width:130, title:'FROM',     sortable:false },
                    { field: 'JobTo',          width:130, title:'TO',       sortable:false },
                    { field: 'VehicleName',    width:100, title:'VEHICLE',  sortable:false },
                    { field: 'Cash', width:100, title:'CASH (SGD)', sortable:false, align:'right',
                      renderer: function(v) { return '<strong style="color:#27ae60;">$ ' + parseFloat(v).toFixed(2) + '</strong>'; }
                    },
                    { field: 'JobStatus', width:110, title:'STATUS', sortable:false,
                      renderer: function(v) { return '<span class="badge badge-success">' + v + '</span>'; }
                    }
                ],
                pager: { enable:true, limit:25, sizes:ArrPaging }
            });
        }

        // ── 4. HANDOVER HISTORY GRID ──────────────────────────────────────────
        var GrdHandover;
        function InitHandoverGrid() {
            GrdHandover = $('#GrdHandover').grid({
                primaryKey: 'HandoverID', uiLibrary: 'bootstrap4', responsive: true,
                dataSource: BaseURL + 'Wallet/Handover_FindAll?DriverUserID=' + CURRENT_UID,
                columns: [
                    { field: 'DisplayHandoverDate', width:110, title:'DATE',      sortable:false },
                    { field: 'HandedToName',        width:140, title:'HANDED TO', sortable:false },
                    { field: 'Amount', width:110, title:'AMOUNT (SGD)', sortable:false, align:'right',
                      renderer: function(v) { return '<strong style="color:#2980b9;">$ ' + parseFloat(v).toFixed(2) + '</strong>'; }
                    },
                    { field: 'Remarks', width:180, title:'REMARKS', sortable:false,
                      renderer: function(v) { return v && v.trim() ? v : '&mdash;'; }
                    },
                    { field: 'DisplayCreatedDate', width:120, title:'RECORDED', sortable:false }
                ],
                pager: { enable:true, limit:25, sizes:ArrPaging }
            });
        }

        // ── 5. MY EXPENSES GRID ───────────────────────────────────────────────
        var GrdExp;
        function InitExpGrid() {
            GrdExp = $('#GrdExp').grid({
                primaryKey: 'DriverExpenseID', uiLibrary: 'bootstrap4', responsive: true,
                dataSource: BaseURL + 'Wallet/DriverExpense_FindAll?DriverUserID=' + CURRENT_UID,
                columns: [
                    { field: 'DisplayExpenseDate', width:100, title:'DATE',     sortable:false },
                    { field: 'Category',           width:120, title:'CATEGORY', sortable:false },
                    { field: 'Amount', width:110, title:'AMOUNT (SGD)', sortable:false, align:'right',
                      renderer: function(v) { return '<strong style="color:#e74c3c;">$ ' + parseFloat(v).toFixed(2) + '</strong>'; }
                    },
                    { field: 'JobCode', width:70, title:'JOB #', sortable:false,
                      renderer: function(v) { return v ? '#' + v : '&mdash;'; }
                    },
                    { field: 'Remarks',            width:180, title:'REMARKS',  sortable:false },
                    { field: 'DisplayCreatedDate', width:120, title:'RECORDED', sortable:false },
                    { field: 'DriverExpenseID', width:55, title:'', sortable:false, align:'center',
                      renderer: function(v) {
                          return '<button onclick="DelExp(' + v + ')" class="badge badge-danger" style="cursor:pointer;border:none;padding:4px 8px;"><i class="fa fa-trash"></i></button>';
                      }
                    }
                ],
                pager: { enable:true, limit:25, sizes:ArrPaging }
            });
        }

        // ── Save Expense ──────────────────────────────────────────────────────
        function SaveExpense() {
            var amt = parseFloat($('#TxtExpAmount').val());
            var dt  = $('#TxtExpDate').val();
            var cat = $('#ddlExpCat').val();
            if (!dt)              { alert('Please select a date.');        return; }
            if (!cat)             { alert('Please select a category.');    return; }
            if (!amt || amt <= 0) { alert('Please enter a valid amount.'); return; }

            $('#btnSaveExp').prop('disabled', true).text('Saving...');
            $.ajax({
                url: BaseURL + 'Wallet/DriverExpense_Save',
                type: 'POST', dataType: 'json', contentType: 'application/json',
                data: JSON.stringify({
                    DriverUserID: CURRENT_UID,
                    ExpenseDate:  dt,
                    Category:     cat,
                    Amount:       amt,
                    Remarks:      $('#TxtExpRemarks').val(),
                    JobCode:      parseInt($('#TxtExpJobCode').val()) || 0
                }),
                success: function (r) {
                    $('#btnSaveExp').prop('disabled', false).text('Save Expense');
                    if (r.success) {
                        $('#modalExp').modal('hide');
                        LoadWallet(); LoadTxHistory();
                        GrdExp.reload({ DriverUserID: CURRENT_UID });
                        $('#TxtExpDate,#TxtExpAmount,#TxtExpRemarks,#TxtExpJobCode').val('');
                        $('#ddlExpCat').val('');
                    } else { alert('Error: ' + (r.message || 'Failed.')); }
                },
                error: function () {
                    $('#btnSaveExp').prop('disabled', false).text('Save Expense');
                    alert('Server error. Please try again.');
                }
            });
        }

        function DelExp(id) {
            if (!confirm('Delete this expense?')) return;
            $.ajax({
                url: BaseURL + 'Wallet/DriverExpense_Delete',
                type: 'POST', dataType: 'json', contentType: 'application/json',
                data: JSON.stringify({ DriverExpenseID: id }),
                success: function (r) {
                    if (r.success) { LoadWallet(); LoadTxHistory(); GrdExp.reload({ DriverUserID: CURRENT_UID }); }
                    else alert('Failed to delete.');
                }
            });
        }

        // ── Add Handover ──────────────────────────────────────────────────────
        function SaveHandover() {
            var amt = parseFloat($('#TxtHOAmount').val());
            var dt  = $('#TxtHODate').val();
            var sel = $('#ddlHOReceiver').val();
            if (!dt)              { alert('Please select a date.');            return; }
            if (!sel)             { alert('Please select who receives cash.'); return; }
            if (!amt || amt <= 0) { alert('Please enter a valid amount.');     return; }

            var parts   = sel.split('|');
            var rcvID   = parseInt(parts[0]);
            var rcvName = parts[1];

            $('#btnSaveHO').prop('disabled', true).text('Saving...');
            $.ajax({
                url: BaseURL + 'Wallet/Handover_Save',
                type: 'POST', dataType: 'json', contentType: 'application/json',
                data: JSON.stringify({
                    DriverUserID:   CURRENT_UID,
                    HandoverDate:   dt,
                    Amount:         amt,
                    HandedToUserID: rcvID,
                    HandedToName:   rcvName,
                    Remarks:        $('#TxtHORemarks').val()
                }),
                success: function (r) {
                    $('#btnSaveHO').prop('disabled', false).text('Save Handover');
                    if (r.success) {
                        $('#modalHO').modal('hide');
                        LoadWallet(); LoadTxHistory();
                        GrdHandover.reload({ DriverUserID: CURRENT_UID });
                        $('#TxtHODate,#TxtHOAmount,#TxtHORemarks').val('');
                        $('#ddlHOReceiver').val('');
                    } else { alert('Error: ' + (r.message || 'Failed.')); }
                },
                error: function () {
                    $('#btnSaveHO').prop('disabled', false).text('Save Handover');
                    alert('Server error. Please try again.');
                }
            });
        }

        $(document).ready(function () {

            // ── Non-modal datepickers (wallet filter + tx filter modal inputs)
            $('#TxtWFrom,#TxtWTo,#TxtTxModalFrom,#TxtTxModalTo').datepicker(dpOpts);

            // ── FIX: Modal datepickers — shown.bs.modal event-ல init பண்ணு
            // Bootstrap modal focus trap-ஆல் calendar உடனே hide ஆகுது.
            // zIndex: 1100 → modal (1050) மேல காட்டும்; flag → ஒருமுறை மட்டும் init.

            $('#modalHO').on('shown.bs.modal', function () {
                if (!$('#TxtHODate').data('dp-ready')) {
                    $('#TxtHODate').datepicker(dpOptsModal);
                    $('#TxtHODate').data('dp-ready', true);
                }
            });

            $('#modalExp').on('shown.bs.modal', function () {
                if (!$('#TxtExpDate').data('dp-ready')) {
                    $('#TxtExpDate').datepicker(dpOptsModal);
                    $('#TxtExpDate').data('dp-ready', true);
                }
            });

            // Load all users for handover receiver dropdown
            $.ajax({ type:'GET', url: BaseURL + 'Common/Load_SystemUserDetail', dataType:'json',
                success: function(data) {
                    $('#ddlHOReceiver').empty().append('<option value="">-- Select Receiver --</option>');
                    $.each(data, function(i, v) {
                        if (v.ID > 0 && v.ID !== CURRENT_UID)
                            $('#ddlHOReceiver').append('<option value="' + v.ID + '|' + v.Name + '">' + v.Name + ' (' + (v.Role || '') + ')</option>');
                    });
                }
            });

            InitCashGrid();
            InitHandoverGrid();
            InitExpGrid();
            LoadWallet();
            LoadTxHistory(); // Today only by default
        });
    </script>
</head>
<body>
    <div class="content">
        <div class="container-fluid">

            <!-- ── SUMMARY CARDS ──────────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-sm-3">
                    <div class="wcard wc-earn">
                        <div class="wc-lbl"><i class="fa fa-car"></i> Total Earned</div>
                        <div class="wc-amt" id="CardEarned">$ 0.00</div>
                        <div class="wc-sub">cash collected from jobs</div>
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="wcard wc-hand">
                        <div class="wc-lbl"><i class="fa fa-hand-holding-usd"></i> Handed Over</div>
                        <div class="wc-amt" id="CardHanded">$ 0.00</div>
                        <div class="wc-sub">submitted to admin / company</div>
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="wcard wc-dexp">
                        <div class="wc-lbl"><i class="fa fa-receipt"></i> My Expenses</div>
                        <div class="wc-amt" id="CardDExp">$ 0.00</div>
                        <div class="wc-sub">fuel, toll, parking etc.</div>
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="wcard wc-bal" id="WcBal">
                        <div class="wc-lbl"><i class="fa fa-wallet"></i> Balance With Me</div>
                        <div class="wc-amt" id="CardBal">$ 0.00</div>
                        <div class="wc-sub">earned &minus; handed &minus; expenses</div>
                    </div>
                </div>
            </div>

            <!-- ── WALLET TRANSACTION HISTORY ───────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px;">
                            <span>
                                <i class="fa fa-history"></i>&nbsp; Wallet Transaction History
                                &nbsp;<span class="badge badge-secondary" id="TxDateLabel" style="font-size:12px;font-weight:500;">Today</span>
                            </span>
                            <div style="display:flex;align-items:center;gap:6px;">
                                <button class="btn btn-sm btn-outline-primary" onclick="TxPill('today')" style="font-size:11px;padding:3px 10px;">Today</button>
                                <button class="btn btn-sm btn-outline-secondary" onclick="TxPill('week')" style="font-size:11px;padding:3px 10px;">This Week</button>
                                <button class="btn btn-sm btn-outline-secondary" onclick="TxPill('month')" style="font-size:11px;padding:3px 10px;">This Month</button>
                                <button class="btn btn-sm btn-outline-dark" onclick="$('#modalTxFilter').modal('show')" title="Custom date range" style="font-size:11px;padding:3px 10px;">
                                    <i class="fa fa-calendar-alt"></i> Custom
                                </button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive" style="max-height:350px;overflow-y:auto;">
                                <table class="tx-table">
                                    <thead>
                                        <tr>
                                            <th style="width:140px;">DATE</th>
                                            <th style="width:80px;">TYPE</th>
                                            <th>SOURCE / DETAILS</th>
                                            <th style="width:120px;text-align:right;">AMOUNT (SGD)</th>
                                            <th style="width:130px;text-align:right;">BALANCE AFTER</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblTxBody">
                                        <tr><td colspan="5" style="text-align:center;padding:20px;color:#999;">Loading...</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── DAILY WALLET TABLE ────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header">
                            <i class="fa fa-calendar-alt"></i>&nbsp; My Wallet &mdash; Daily Summary
                            <div style="float:right;">
                                <input type="text" id="TxtWFrom" class="form-control form-control-sm d-inline-block" style="width:130px;" placeholder="From Date" />
                                &nbsp;
                                <input type="text" id="TxtWTo" class="form-control form-control-sm d-inline-block" style="width:130px;" placeholder="To Date" />
                                &nbsp;
                                <button class="btn btn-primary btn-sm" onclick="LoadWallet()"><i class="fa fa-search"></i></button>
                                <button class="btn btn-secondary btn-sm" onclick="$('#TxtWFrom,#TxtWTo').val('');LoadWallet();"><i class="fa fa-times"></i></button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover table-bordered mb-0" style="font-size:13px;">
                                    <thead style="background:#2c3e50;color:#fff;">
                                        <tr>
                                            <th>DATE</th>
                                            <th style="text-align:center;">RIDES</th>
                                            <th style="text-align:right;">EARNED (SGD)</th>
                                            <th style="text-align:right;">HANDED OVER (SGD)</th>
                                            <th style="text-align:right;">EXPENSES (SGD)</th>
                                            <th style="text-align:right;">CLOSING BALANCE (SGD)</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblWallet">
                                        <tr><td colspan="6" style="text-align:center;padding:20px;color:#999;">Loading...</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── CASH HISTORY ───────────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header"><i class="fa fa-money-bill-wave"></i>&nbsp; Cash Job History</div>
                        <div class="card-body">
                            <div class="box-body table-responsive no-padding">
                                <table id="GrdCash" class="table table-hover"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── HANDOVER HISTORY ───────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header">
                            <i class="fa fa-hand-holding-usd"></i>&nbsp; My Handover History
                            <div style="float:right;">
                                <button type="button" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#modalHO">
                                    <i class="fa fa-plus"></i> Add Handover
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="box-body table-responsive no-padding">
                                <table id="GrdHandover" class="table table-hover"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── MY EXPENSES ────────────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header">
                            <i class="fa fa-receipt"></i>&nbsp; My Expenses
                            <div style="float:right;">
                                <button type="button" class="btn btn-warning btn-sm" data-toggle="modal" data-target="#modalExp">
                                    <i class="fa fa-plus"></i> Add Expense
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="box-body table-responsive no-padding">
                                <table id="GrdExp" class="table table-hover"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- ── MODAL: Tx Date Filter ────────────────────────────────────────── -->
    <div class="modal fade" id="modalTxFilter" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-sm" role="document" style="margin-top:80px;">
            <div class="modal-content">
                <div class="modal-header" style="background:#2c3e50;color:#fff;padding:10px 16px;">
                    <h6 class="modal-title mb-0"><i class="fa fa-calendar-alt"></i> Select Date Range</h6>
                    <button type="button" class="close text-white" data-dismiss="modal" style="font-size:18px;">&times;</button>
                </div>
                <div class="modal-body" style="padding:16px;">
                    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;">
                        <button class="btn btn-sm btn-primary" onclick="TxPill('today')" style="font-size:11px;">Today</button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="TxPill('week')" style="font-size:11px;">This Week</button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="TxPill('month')" style="font-size:11px;">This Month</button>
                    </div>
                    <hr style="margin:8px 0;" />
                    <div class="form-group mb-2">
                        <label style="font-size:12px;font-weight:600;color:#555;">From Date</label>
                        <input type="text" id="TxtTxModalFrom" class="form-control form-control-sm" placeholder="dd-MMM-yyyy" />
                    </div>
                    <div class="form-group mb-0">
                        <label style="font-size:12px;font-weight:600;color:#555;">To Date</label>
                        <input type="text" id="TxtTxModalTo" class="form-control form-control-sm" placeholder="dd-MMM-yyyy" />
                    </div>
                </div>
                <div class="modal-footer" style="padding:10px 16px;">
                    <button class="btn btn-primary btn-sm btn-block" onclick="ApplyTxFilter()">
                        <i class="fa fa-search"></i> Show Transactions
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── MODAL: Add Handover ────────────────────────────────────────────── -->
    <div class="modal fade" id="modalHO" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background:#2980b9;color:#fff;">
                    <h5 class="modal-title"><i class="fa fa-hand-holding-usd"></i> Add Handover</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Date <span class="text-danger">*</span></label>
                                <input type="text" id="TxtHODate" class="form-control" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Amount (SGD) <span class="text-danger">*</span></label>
                                <input type="number" id="TxtHOAmount" class="form-control" placeholder="0.00" step="0.01" min="0" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Hand Over To <span class="text-danger">*</span></label>
                        <select id="ddlHOReceiver" class="form-control">
                            <option value="">-- Select Receiver --</option>
                        </select>
                        <small class="text-muted">
                            Admin &rarr; Admin wallet &nbsp;|&nbsp;
                            Staff &rarr; Company wallet &nbsp;|&nbsp;
                            Driver &rarr; Driver wallet
                        </small>
                    </div>
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea id="TxtHORemarks" class="form-control" rows="2" placeholder="e.g. Cash for 12-Apr jobs"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnSaveHO" class="btn btn-primary" onclick="SaveHandover()">
                        <i class="fa fa-save"></i> Save Handover
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── MODAL: Add Expense ─────────────────────────────────────────────── -->
    <div class="modal fade" id="modalExp" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background:#d68910;color:#fff;">
                    <h5 class="modal-title"><i class="fa fa-receipt"></i> Add My Expense</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Date <span class="text-danger">*</span></label>
                                <input type="text" id="TxtExpDate" class="form-control" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Category <span class="text-danger">*</span></label>
                                <select id="ddlExpCat" class="form-control">
                                    <option value="">-- Select --</option>
                                    <option value="Fuel">Fuel</option>
                                    <option value="Toll">Toll</option>
                                    <option value="Parking">Parking</option>
                                    <option value="Food">Food</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Amount (SGD) <span class="text-danger">*</span></label>
                                <input type="number" id="TxtExpAmount" class="form-control" placeholder="0.00" step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Job Code <small class="text-muted">(optional)</small></label>
                                <input type="number" id="TxtExpJobCode" class="form-control" placeholder="Job number" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea id="TxtExpRemarks" class="form-control" rows="2" placeholder="e.g. Shell petrol, ERP charge"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnSaveExp" class="btn btn-warning" onclick="SaveExpense()">
                        <i class="fa fa-save"></i> Save Expense
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</body>
