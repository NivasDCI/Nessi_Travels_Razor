@using Transport.Repository.Resource
@{
    Layout = "";
    string uidStr = (ViewBag.CurrentUID != null) ? ViewBag.CurrentUID.ToString() : "0";
}
<head>
    <style>
        .wcard {
            border-radius: 10px;
            color: #fff;
            padding: 16px 18px;
            margin-bottom: 14px;
        }

        .wc-earn {
            background: linear-gradient(135deg,#1a9e6e,#27ae60);
        }

        .wc-hand {
            background: linear-gradient(135deg,#1a6fa3,#2980b9);
        }

        .wc-dexp {
            background: linear-gradient(135deg,#d68910,#f39c12);
        }

        .wc-bal {
            background: linear-gradient(135deg,#6c3483,#8e44ad);
        }

        .wcard .wc-lbl {
            font-size: 11px;
            opacity: .85;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .wcard .wc-amt {
            font-size: 22px;
            font-weight: 700;
            margin-top: 4px;
        }

        .wcard .wc-sub {
            font-size: 11px;
            opacity: .7;
        }
    </style>

    <script>
        var CURRENT_UID = @uidStr;
        var dpOpts = { format: Common_Date_Format, autoclose: true, uiLibrary: 'bootstrap4', iconsLibrary: 'fontawesome', size: 'small' };

        // ── 1. WALLET SUMMARY CARDS + DAILY TABLE ─────────────────────────────
        function LoadWallet() {
            $.ajax({
                url: BaseURL + 'Wallet/MyWallet_FindAll',
                type: 'GET',
                data: { FromDate: $('#TxtWFrom').val(), ToDate: $('#TxtWTo').val() },
                dataType: 'json',
                success: function (r) {
                    if (r.balance) {
                        var b = r.balance;
                        $('#CardEarned').text('$ ' + parseFloat(b.TotalEarned   || 0).toFixed(2));
                        $('#CardHanded').text('$ ' + parseFloat(b.TotalHandedOver || 0).toFixed(2));
                        $('#CardDExp'  ).text('$ ' + parseFloat(b.TotalExpenses  || 0).toFixed(2));
                        var bal = parseFloat(b.WalletBalance || 0);
                        $('#CardBal').text('$ ' + bal.toFixed(2));
                        if (bal < 0) $('#WcBal').css('background','linear-gradient(135deg,#c0392b,#e74c3c)');
                        else         $('#WcBal').css('background','linear-gradient(135deg,#6c3483,#8e44ad)');
                    }
                    var tbody = $('#tblWallet tbody');
                    tbody.empty();
                    if (r.records && r.records.length > 0) {
                        $.each(r.records, function (i, d) {
                            var balColor = parseFloat(d.ClosingBalance) >= 0 ? '#8e44ad' : '#e74c3c';
                            tbody.append(
                                '<tr>' +
                                '<td>' + d.DisplayWalletDate + '</td>' +
                                '<td style="text-align:center;">' + d.TotalRides + '</td>' +
                                '<td style="text-align:right;color:#27ae60;font-weight:bold;">$ ' + parseFloat(d.TotalEarned).toFixed(2) + '</td>' +
                                '<td style="text-align:right;color:#2980b9;font-weight:bold;">$ ' + parseFloat(d.TotalHandedOver).toFixed(2) + '</td>' +
                                '<td style="text-align:right;color:#f39c12;font-weight:bold;">$ ' + parseFloat(d.TotalExpenses).toFixed(2) + '</td>' +
                                '<td style="text-align:right;color:' + balColor + ';font-weight:bold;">$ ' + parseFloat(d.ClosingBalance).toFixed(2) + '</td>' +
                                '</tr>'
                            );
                        });
                    } else {
                        tbody.append('<tr><td colspan="6" style="text-align:center;color:#999;padding:20px;">No wallet records found.</td></tr>');
                    }
                }
            });
        }

        // ── 2. CASH HISTORY GRID ──────────────────────────────────────────────
        var GrdCash;
        function InitCashGrid() {
            GrdCash = $('#GrdCash').grid({
                primaryKey: 'JobCode', uiLibrary: 'bootstrap4', responsive: true,
                dataSource: BaseURL + 'Wallet/MyCashHistory_FindAll',
                columns: [
                    { field: 'DisplayJobDate', width: 100, title: 'DATE',     sortable: false },
                    { field: 'JobTime',        width: 80,  title: 'TIME',     sortable: false },
                    { field: 'CustomerName',   width: 140, title: 'CUSTOMER', sortable: false },
                    { field: 'JobFrom',        width: 130, title: 'FROM',     sortable: false },
                    { field: 'JobTo',          width: 130, title: 'TO',       sortable: false },
                    { field: 'VehicleName',    width: 100, title: 'VEHICLE',  sortable: false },
                    {
                        field: 'Cash', width: 100, title: 'CASH (SGD)', sortable: false, align: 'right',
                        renderer: function (v) { return '<strong style="color:#27ae60;">$ ' + parseFloat(v).toFixed(2) + '</strong>'; }
                    },
                    { field: 'JobStatus', width: 110, title: 'STATUS', sortable: false,
                      renderer: function (v) { return '<span class="badge badge-success">' + v + '</span>'; }
                    }
                ],
                pager: { enable: true, limit: 25, sizes: ArrPaging }
            });
        }

        // ── 3. HANDOVER HISTORY GRID ──────────────────────────────────────────
        var GrdHandover;
        function InitHandoverGrid() {
            GrdHandover = $('#GrdHandover').grid({
                primaryKey: 'HandoverID', uiLibrary: 'bootstrap4', responsive: true,
                dataSource: BaseURL + 'Wallet/Handover_FindAll?DriverUserID=' + CURRENT_UID,
                columns: [
                    { field: 'DisplayHandoverDate', width: 110, title: 'DATE',      sortable: false },
                    { field: 'HandedToName',        width: 140, title: 'HANDED TO', sortable: false },
                    {
                        field: 'Amount', width: 110, title: 'AMOUNT (SGD)', sortable: false, align: 'right',
                        renderer: function (v) { return '<strong style="color:#2980b9;">$ ' + parseFloat(v).toFixed(2) + '</strong>'; }
                    },
                    { field: 'Remarks',            width: 180, title: 'REMARKS',   sortable: false,
                      renderer: function (v) { return v && v.trim() ? v : '&mdash;'; }
                    },
                    { field: 'DisplayCreatedDate', width: 120, title: 'RECORDED',  sortable: false }
                ],
                pager: { enable: true, limit: 25, sizes: ArrPaging }
            });
        }

        // ── 4. MY EXPENSES GRID ───────────────────────────────────────────────
        var GrdExp;
        function InitExpGrid() {
            GrdExp = $('#GrdExp').grid({
                primaryKey: 'DriverExpenseID', uiLibrary: 'bootstrap4', responsive: true,
                dataSource: BaseURL + 'Wallet/DriverExpense_FindAll?DriverUserID=' + CURRENT_UID,
                columns: [
                    { field: 'DisplayExpenseDate', width: 100, title: 'DATE',     sortable: false },
                    { field: 'Category',           width: 120, title: 'CATEGORY', sortable: false },
                    {
                        field: 'Amount', width: 110, title: 'AMOUNT (SGD)', sortable: false, align: 'right',
                        renderer: function (v) { return '<strong style="color:#e74c3c;">$ ' + parseFloat(v).toFixed(2) + '</strong>'; }
                    },
                    { field: 'JobCode', width: 70, title: 'JOB #', sortable: false,
                      renderer: function (v) { return v ? '#' + v : '&mdash;'; }
                    },
                    { field: 'Remarks',            width: 180, title: 'REMARKS',  sortable: false },
                    { field: 'DisplayCreatedDate', width: 120, title: 'RECORDED', sortable: false },
                    {
                        field: 'DriverExpenseID', width: 55, title: '', sortable: false, align: 'center',
                        renderer: function (v) {
                            return '<button onclick="DelExp(' + v + ')" class="badge badge-danger" style="cursor:pointer;border:none;padding:4px 8px;"><i class="fa fa-trash"></i></button>';
                        }
                    }
                ],
                pager: { enable: true, limit: 25, sizes: ArrPaging }
            });
        }

        // ── Load System Users into Handed To dropdown ─────────────────────────
        function LoadSystemUsers() {
            $.ajax({
                type: 'GET',
                url: BaseURL + 'Common/Load_SystemUserDetail',
                dataType: 'json',
                success: function (data) {
                    $('#ddlHOTo').empty();
                    $('#ddlHOTo').append('<option value="0">-- Select Person --</option>');
                    $.each(data, function (i, v) {
                        if (v.ID > 0)
                            $('#ddlHOTo').append('<option value="' + v.ID + '">' + v.Name + '</option>');
                    });
                },
                error: function () {
                    $('#ddlHOTo').empty();
                    $('#ddlHOTo').append('<option value="0">-- Failed to load --</option>');
                }
            });
        }

        // ── Save Expense ──────────────────────────────────────────────────────
        function SaveExpense() {
            var amt = parseFloat($('#TxtExpAmount').val());
            var dt  = $('#TxtExpDate').val();
            var cat = $('#ddlExpCat').val();
            if (!dt)              { alert('Please select a date.');        return; }
            if (!cat)             { alert('Please select a category.');    return; }
            if (!amt || amt <= 0) { alert('Please enter a valid amount.'); return; }

            $('#btnSaveExp').prop('disabled', true).text('Saving...');
            $.ajax({
                url: BaseURL + 'Wallet/DriverExpense_Save',
                type: 'POST', dataType: 'json', contentType: 'application/json',
                data: JSON.stringify({
                    DriverUserID: CURRENT_UID,
                    ExpenseDate:  dt,
                    Category:     cat,
                    Amount:       amt,
                    Remarks:      $('#TxtExpRemarks').val(),
                    JobCode:      parseInt($('#TxtExpJobCode').val()) || 0
                }),
                success: function (r) {
                    $('#btnSaveExp').prop('disabled', false).text('Save Expense');
                    if (r.success) {
                        $('#modalExp').modal('hide');
                        LoadWallet();
                        GrdExp.reload({ DriverUserID: CURRENT_UID });
                        $('#TxtExpDate,#TxtExpAmount,#TxtExpRemarks,#TxtExpJobCode').val('');
                        $('#ddlExpCat').val('');
                    } else { alert('Error: ' + (r.message || 'Failed.')); }
                },
                error: function () {
                    $('#btnSaveExp').prop('disabled', false).text('Save Expense');
                    alert('Server error. Please try again.');
                }
            });
        }

        function DelExp(id) {
            if (!confirm('Delete this expense?')) return;
            $.ajax({
                url: BaseURL + 'Wallet/DriverExpense_Delete',
                type: 'POST', dataType: 'json', contentType: 'application/json',
                data: JSON.stringify({ DriverExpenseID: id }),
                success: function (r) {
                    if (r.success) { LoadWallet(); GrdExp.reload({ DriverUserID: CURRENT_UID }); }
                    else alert('Failed to delete.');
                }
            });
        }

        // ── Save Handover ─────────────────────────────────────────────────────
        function SaveHandover() {
            var amt    = parseFloat($('#TxtHOAmount').val());
            var dt     = $('#TxtHODate').val();
            var hoTo   = parseInt($('#ddlHOTo').val()) || 0;
            var hoName = $('#ddlHOTo option:selected').text();

            if (!dt)              { alert('Please select a date.');                    return; }
            if (!amt || amt <= 0) { alert('Please enter a valid amount.');             return; }
            if (hoTo <= 0)        { alert('Please select who you are handing to.');   return; }

            $('#btnSaveHO').prop('disabled', true).text('Saving...');
            $.ajax({
                url: BaseURL + 'Wallet/Handover_Save',
                type: 'POST', dataType: 'json', contentType: 'application/json',
                data: JSON.stringify({
                    DriverUserID:   CURRENT_UID,
                    HandoverDate:   dt,
                    Amount:         amt,
                    HandedToUserID: hoTo,
                    HandedToName:   hoName,
                    Remarks:        $('#TxtHORemarks').val()
                }),
                success: function (r) {
                    $('#btnSaveHO').prop('disabled', false).text('Save Handover');
                    if (r.success) {
                        $('#modalHO').modal('hide');
                        LoadWallet();
                        GrdHandover.reload({ DriverUserID: CURRENT_UID });
                        $('#TxtHODate,#TxtHOAmount,#TxtHORemarks').val('');
                        $('#ddlHOTo').val('0');
                    } else { alert('Error: ' + (r.message || 'Failed.')); }
                },
                error: function () {
                    $('#btnSaveHO').prop('disabled', false).text('Save Handover');
                    alert('Server error. Please try again.');
                }
            });
        }

        $(document).ready(function () {
            $('#TxtWFrom,#TxtWTo').datepicker(dpOpts);
            $('#TxtExpDate').datepicker(dpOpts);
            $('#TxtHODate').datepicker(dpOpts);

            LoadSystemUsers();   // ← load Handed To dropdown

            InitCashGrid();
            InitHandoverGrid();
            InitExpGrid();
            LoadWallet();
        });
    </script>
</head>
<body>
    <div class="content">
        <div class="container-fluid">

            <!-- ── SUMMARY CARDS ──────────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-sm-3">
                    <div class="wcard wc-earn">
                        <div class="wc-lbl"><i class="fa fa-car"></i> Total Earned</div>
                        <div class="wc-amt" id="CardEarned">$ 0.00</div>
                        <div class="wc-sub">cash collected from jobs</div>
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="wcard wc-hand">
                        <div class="wc-lbl"><i class="fa fa-hand-holding-usd"></i> Handed Over</div>
                        <div class="wc-amt" id="CardHanded">$ 0.00</div>
                        <div class="wc-sub">submitted to admin</div>
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="wcard wc-dexp">
                        <div class="wc-lbl"><i class="fa fa-receipt"></i> My Expenses</div>
                        <div class="wc-amt" id="CardDExp">$ 0.00</div>
                        <div class="wc-sub">fuel, toll, parking etc.</div>
                    </div>
                </div>
                <div class="col-sm-3">
                    <div class="wcard wc-bal" id="WcBal">
                        <div class="wc-lbl"><i class="fa fa-wallet"></i> Balance With Me</div>
                        <div class="wc-amt" id="CardBal">$ 0.00</div>
                        <div class="wc-sub">earned &minus; handed &minus; expenses</div>
                    </div>
                </div>
            </div>

            <!-- ── DAILY WALLET TABLE ────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header">
                            <i class="fa fa-calendar-alt"></i>&nbsp; My Wallet — Daily Summary
                            <div style="float:right;">
                                <input type="text" id="TxtWFrom" class="form-control form-control-sm d-inline-block" style="width:130px;" placeholder="From Date" />
                                &nbsp;
                                <input type="text" id="TxtWTo" class="form-control form-control-sm d-inline-block" style="width:130px;" placeholder="To Date" />
                                &nbsp;
                                <button class="btn btn-primary btn-sm" onclick="LoadWallet()"><i class="fa fa-search"></i></button>
                                <button class="btn btn-secondary btn-sm" onclick="$('#TxtWFrom,#TxtWTo').val('');LoadWallet();"><i class="fa fa-times"></i></button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover table-bordered mb-0" style="font-size:13px;">
                                    <thead style="background:#2c3e50;color:#fff;">
                                        <tr>
                                            <th>DATE</th>
                                            <th style="text-align:center;">RIDES</th>
                                            <th style="text-align:right;">EARNED (SGD)</th>
                                            <th style="text-align:right;">HANDED OVER (SGD)</th>
                                            <th style="text-align:right;">EXPENSES (SGD)</th>
                                            <th style="text-align:right;">CLOSING BALANCE (SGD)</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblWallet">
                                        <tr><td colspan="6" style="text-align:center;padding:20px;color:#999;">Loading...</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── CASH HISTORY ───────────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header">
                            <i class="fa fa-money-bill-wave"></i>&nbsp; Cash Job History
                        </div>
                        <div class="card-body">
                            <div class="box-body table-responsive no-padding">
                                <table id="GrdCash" class="table table-hover"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── HANDOVER HISTORY ───────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header">
                            <i class="fa fa-hand-holding-usd"></i>&nbsp; My Handover History
                            <div style="float:right;">
                                <button type="button" class="btn btn-primary btn-sm"
                                        data-toggle="modal" data-target="#modalHO">
                                    <i class="fa fa-plus"></i> Add Handover
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="box-body table-responsive no-padding">
                                <table id="GrdHandover" class="table table-hover"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── MY EXPENSES ────────────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header">
                            <i class="fa fa-receipt"></i>&nbsp; My Expenses
                            <div style="float:right;">
                                <button type="button" class="btn btn-warning btn-sm"
                                        data-toggle="modal" data-target="#modalExp">
                                    <i class="fa fa-plus"></i> Add Expense
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="box-body table-responsive no-padding">
                                <table id="GrdExp" class="table table-hover"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- ── MODAL: Add Handover ────────────────────────────────────────────── -->
    <div class="modal fade" id="modalHO" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background:#2980b9;color:#fff;">
                    <h5 class="modal-title"><i class="fa fa-hand-holding-usd"></i> Add Handover</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Date <span class="text-danger">*</span></label>
                                <input type="text" id="TxtHODate" class="form-control" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Amount (SGD) <span class="text-danger">*</span></label>
                                <input type="number" id="TxtHOAmount" class="form-control" placeholder="0.00" step="0.01" min="0" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Handed To <span class="text-danger">*</span></label>
                        <select id="ddlHOTo" class="form-control">
                            <option value="0">-- Select Person --</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea id="TxtHORemarks" class="form-control" rows="2" placeholder="e.g. Cash for 12-Apr jobs"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnSaveHO" class="btn btn-primary" onclick="SaveHandover()">
                        <i class="fa fa-save"></i> Save Handover
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── MODAL: Add Expense ─────────────────────────────────────────────── -->
    <div class="modal fade" id="modalExp" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background:#d68910;color:#fff;">
                    <h5 class="modal-title"><i class="fa fa-receipt"></i> Add My Expense</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Date <span class="text-danger">*</span></label>
                                <input type="text" id="TxtExpDate" class="form-control" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Category <span class="text-danger">*</span></label>
                                <select id="ddlExpCat" class="form-control">
                                    <option value="">-- Select --</option>
                                    <option value="Fuel">Fuel</option>
                                    <option value="Toll">Toll</option>
                                    <option value="Parking">Parking</option>
                                    <option value="Food">Food</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Amount (SGD) <span class="text-danger">*</span></label>
                                <input type="number" id="TxtExpAmount" class="form-control" placeholder="0.00" step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Job Code <small class="text-muted">(optional)</small></label>
                                <input type="number" id="TxtExpJobCode" class="form-control" placeholder="Job number" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea id="TxtExpRemarks" class="form-control" rows="2" placeholder="e.g. Shell petrol, ERP charge"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnSaveExp" class="btn btn-warning" onclick="SaveExpense()">
                        <i class="fa fa-save"></i> Save Expense
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</body>
