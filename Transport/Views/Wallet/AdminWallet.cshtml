@model Transport.Model.AdminWalletViewModel
@{
    ViewBag.Title = "Company Wallet";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3>Company / Admin Wallet</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="alert alert-success">
                                <h5>Current Balance</h5>
                                <h2>@Model.CurrentBalance.ToString("C")</h2>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="alert alert-info">
                                <h5>Last Updated</h5>
                                <h5>@Model.LastUpdated.ToString("dd-MM-yyyy HH:mm:ss")</h5>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-md-6">
                            <div class="card bg-success text-white">
                                <div class="card-body">
                                    <h6>Total Cash Received from Drivers</h6>
                                    <h3>@Model.TotalCashReceived.ToString("C")</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-danger text-white">
                                <div class="card-body">
                                    <h6>Total Company Expenses</h6>
                                    <h3>@Model.TotalExpenses.ToString("C")</h3>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-md-12">
                            <div class="alert alert-warning">
                                <h5>Net Balance: @Model.NetBalance.ToString("C")</h5>
                                <small>= Total Received - Total Expenses</small>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-12 text-center">
                            <a href="@Url.Action("CompanyExpense")" class="btn btn-danger">Add Company Expense</a>
                            <a href="@Url.Action("TransactionHistory")" class="btn btn-info">View All Transactions</a>
                            <a href="@Url.Action("Dashboard")" class="btn btn-secondary">Back to Dashboard</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>