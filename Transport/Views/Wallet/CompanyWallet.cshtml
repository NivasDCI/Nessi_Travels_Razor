@using Transport.Repository.Resource;
@{
    Layout = "";
}
<head>
    <style>
        .wcard {
            border-radius: 10px;
            color: #fff;
            padding: 16px 18px;
            margin-bottom: 14px;
        }

        .wc-earn {
            background: linear-gradient(135deg,#1a9e6e,#27ae60);
        }

        .wc-hand {
            background: linear-gradient(135deg,#1a6fa3,#2980b9);
        }

        .wc-dexp {
            background: linear-gradient(135deg,#d68910,#f39c12);
        }

        .wc-cexp {
            background: linear-gradient(135deg,#a93226,#e74c3c);
        }

        .wc-with {
            background: linear-gradient(135deg,#5d6d7e,#7f8c8d);
        }

        .wc-bal {
            background: linear-gradient(135deg,#6c3483,#8e44ad);
        }

        .wcard .wc-lbl {
            font-size: 11px;
            opacity: .85;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .wcard .wc-amt {
            font-size: 20px;
            font-weight: 700;
            margin-top: 4px;
        }

        .wcard .wc-sub {
            font-size: 11px;
            opacity: .7;
        }

        .driver-row {
            cursor: pointer;
            transition: background .15s;
        }

            .driver-row:hover td {
                background: #eaf4fb !important;
            }

        .tx-tbl {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

            .tx-tbl th {
                background: #2c3e50;
                color: #fff;
                padding: 7px 10px;
                text-align: left;
                white-space: nowrap;
            }

            .tx-tbl td {
                padding: 7px 10px;
                border-bottom: 1px solid #f0f0f0;
                vertical-align: top;
            }

            .tx-tbl tr:hover td {
                background: #fafafa;
            }

        .tx-credit {
            color: #27ae60;
            font-weight: 700;
        }

        .tx-debit {
            color: #e74c3c;
            font-weight: 700;
        }

        .tx-badge {
            display: inline-block;
            padding: 2px 7px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 600;
            white-space: nowrap;
        }

        .tx-badge-c {
            background: #d4edda;
            color: #155724;
        }

        .tx-badge-d {
            background: #f8d7da;
            color: #721c24;
        }

        .tx-src {
            font-size: 11px;
            color: #999;
        }

        .ch-tbl {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

            .ch-tbl th {
                background: #34495e;
                color: #fff;
                padding: 7px 10px;
                text-align: left;
            }

            .ch-tbl td {
                padding: 7px 10px;
                border-bottom: 1px solid #f0f0f0;
            }

            .ch-tbl tr:hover td {
                background: #fafafa;
            }
    </style>
</head>
<body>
    <div class="content">
        <div class="container-fluid">

            <!-- ── SUMMARY CARDS ─────────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-sm-2"><div class="wcard wc-earn"><div class="wc-lbl"><i class="fa fa-car"></i> Driver Earnings</div><div class="wc-amt" id="CardTotalEarned">$ 0.00</div><div class="wc-sub">total cash collected</div></div></div>
                <div class="col-sm-2"><div class="wcard wc-hand"><div class="wc-lbl"><i class="fa fa-hand-holding-usd"></i> Handed Over</div><div class="wc-amt" id="CardHandedOver">$ 0.00</div><div class="wc-sub">received by admin</div></div></div>
                <div class="col-sm-2"><div class="wcard wc-dexp"><div class="wc-lbl"><i class="fa fa-gas-pump"></i> Driver Expenses</div><div class="wc-amt" id="CardDrvExp">$ 0.00</div><div class="wc-sub">fuel, toll, parking</div></div></div>
                <div class="col-sm-2"><div class="wcard wc-cexp"><div class="wc-lbl"><i class="fa fa-building"></i> Company Expenses</div><div class="wc-amt" id="CardCmpExp">$ 0.00</div><div class="wc-sub">salary, ops, maintenance</div></div></div>
                <div class="col-sm-2"><div class="wcard wc-with"><div class="wc-lbl"><i class="fa fa-user-clock"></i> With Drivers</div><div class="wc-amt" id="CardWithDrv">$ 0.00</div><div class="wc-sub">not yet handed over</div></div></div>
                <div class="col-sm-2"><div class="wcard wc-bal" id="WcBal"><div class="wc-lbl"><i class="fa fa-landmark"></i> Company Balance</div><div class="wc-amt" id="CardBal">$ 0.00</div><div class="wc-sub">received &minus; company exp</div></div></div>
            </div>

            <!-- ── DRIVER BREAKDOWN ──────────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px;">
                            <span>
                                <i class="fa fa-users"></i>&nbsp; Per-Driver Breakdown
                                <small class="text-muted" style="font-size:11px;"><i class="fa fa-mouse-pointer"></i> Click row for history</small>
                            </span>
                            <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                                <input type="text" id="TxtCWFrom" class="form-control form-control-sm" style="width:130px;" placeholder="From Date" />
                                <input type="text" id="TxtCWTo" class="form-control form-control-sm" style="width:130px;" placeholder="To Date" />
                                <button class="btn btn-primary btn-sm" onclick="LoadCompanyData()"><i class="fa fa-search"></i></button>
                                <button class="btn btn-secondary btn-sm" onclick="ClearCW()"><i class="fa fa-times"></i></button>
                                <button type="button" class="btn btn-success btn-sm" data-toggle="modal" data-target="#modalTransfer"><i class="fa fa-exchange-alt"></i> Give Cash to Driver</button>
                                <button type="button" class="btn btn-danger btn-sm" data-toggle="modal" data-target="#modalCE"><i class="fa fa-plus"></i> Add Company Expense</button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover table-bordered mb-0" style="font-size:13px;">
                                    <thead style="background:#2c3e50;color:#fff;">
                                        <tr>
                                            <th>DRIVER</th>
                                            <th style="text-align:right;">EARNED (SGD)</th>
                                            <th style="text-align:right;">HANDED OVER (SGD)</th>
                                            <th style="text-align:right;">EXPENSES (SGD)</th>
                                            <th style="text-align:right;">BALANCE (SGD)</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblDriverBreakdown">
                                        <tr><td colspan="5" style="text-align:center;padding:20px;color:#999;">Loading...</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── COMPANY WALLET HISTORY ────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px;">
                            <span>
                                <i class="fa fa-history"></i>&nbsp; Company Wallet History
                                <span id="chSummary" style="font-size:12px;margin-left:10px;"></span>
                            </span>
                            <div style="display:flex;align-items:center;gap:6px;">
                                <input type="text" id="TxtChFrom" class="form-control form-control-sm" style="width:130px;" placeholder="From" />
                                <input type="text" id="TxtChTo" class="form-control form-control-sm" style="width:130px;" placeholder="To" />
                                <button class="btn btn-primary btn-sm" onclick="LoadCompanyHistory()"><i class="fa fa-search"></i></button>
                                <button class="btn btn-secondary btn-sm" onclick="ClearCH()"><i class="fa fa-times"></i></button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive" style="max-height:340px;overflow-y:auto;">
                                <table class="ch-tbl">
                                    <thead>
                                        <tr>
                                            <th style="width:140px;">DATE</th>
                                            <th style="width:70px;">TYPE</th>
                                            <th>SOURCE / DETAILS</th>
                                            <th style="width:120px;text-align:right;">AMOUNT (SGD)</th>
                                            <th style="width:130px;text-align:right;">BALANCE AFTER</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblChBody">
                                        <tr><td colspan="5" style="text-align:center;padding:20px;color:#999;">Loading...</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── COMPANY EXPENSE GRID ──────────────────────────────────── -->
            <div class="row mb-3">
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header">
                            <i class="fa fa-receipt"></i>&nbsp; Company Expense Records
                            <div style="float:right;">
                                <span style="border-left:1px solid #ccc;padding:0 15px;"><a href="#" onclick="showForm()"><i class="fas fa-caret-square-down"></i></a></span>
                                <span style="border-left:1px solid #ccc;padding:0 15px;"><a href="#" onclick="hideForm()"><i class="fas fa-caret-square-up"></i></a></span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div id="hidden-form">
                                <div class="row mb-2">
                                    <div class="col-sm-2"><div class="form-group"><label>From Date</label><input type="text" id="TxtExpFrom" class="form-control" /></div></div>
                                    <div class="col-sm-2"><div class="form-group"><label>To Date</label><input type="text" id="TxtExpTo" class="form-control" /></div></div>
                                    <div class="col-sm-2">
                                        <div class="form-group">
                                            <label>Category</label>
                                            <select id="ddlCEFilter" class="form-control">
                                                <option value="">-- All --</option>
                                                <option>Driver Salary</option>
                                                <option>Fuel</option>
                                                <option>Vehicle Maintenance</option>
                                                <option>Office</option>
                                                <option>Insurance</option>
                                                <option>Other</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-sm-2 pdt-25"><button type="button" class="btn btn-primary btn-block" onclick="CESearch()"><i class="fa fa-search"></i> Search</button></div>
                                    <div class="col-sm-2 pdt-25"><button type="button" class="btn btn-secondary btn-block" onclick="CEClear()"><i class="fa fa-paint-brush"></i> Clear</button></div>
                                </div>
                            </div>
                            <div class="box-body table-responsive no-padding">
                                <table id="GrdCmpExp" class="table table-hover"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- ── MODAL: Driver History ─────────────────────────────────────── -->
    <div class="modal fade" id="modalDrvHist" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header" style="background:#2c3e50;color:#fff;padding:12px 18px;">
                    <h6 class="modal-title mb-0"><i class="fa fa-history"></i> <span id="modalDrvHistTitle"></span></h6>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body p-0">
                    <div id="drvHistBalance" style="padding:10px 16px;background:#f8f9fa;border-bottom:1px solid #eee;font-size:12px;"></div>
                    <div style="max-height:420px;overflow-y:auto;">
                        <table class="tx-tbl">
                            <thead>
                                <tr>
                                    <th style="width:140px;">DATE</th>
                                    <th style="width:80px;">TYPE</th>
                                    <th>SOURCE / DETAILS</th>
                                    <th style="width:110px;text-align:right;">AMOUNT</th>
                                    <th style="width:120px;text-align:right;">BALANCE AFTER</th>
                                </tr>
                            </thead>
                            <tbody id="tblDrvHistBody">
                                <tr><td colspan="5" style="text-align:center;padding:24px;color:#999;">Select a driver to view history.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer" style="padding:10px 16px;">
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── MODAL: Give Cash to Driver ───────────────────────────────── -->
    <div class="modal fade" id="modalTransfer" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header" style="background:#27ae60;color:#fff;">
                    <h5 class="modal-title"><i class="fa fa-exchange-alt"></i> Give Cash to Driver</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info" style="font-size:12px;padding:8px 12px;">
                        <i class="fa fa-info-circle"></i> Company Wallet DEBIT → Driver Wallet CREDIT.
                    </div>
                    <div class="row">
                        <div class="col-sm-6"><div class="form-group"><label>Date <span class="text-danger">*</span></label><input type="text" id="TxtTransferDate" class="form-control" /></div></div>
                        <div class="col-sm-6"><div class="form-group"><label>Amount (SGD) <span class="text-danger">*</span></label><input type="number" id="TxtTransferAmt" class="form-control" placeholder="0.00" step="0.01" min="0" /></div></div>
                    </div>
                    <div class="form-group">
                        <label>Driver <span class="text-danger">*</span></label>
                        <select id="ddlTransferDriver" class="form-control"><option value="0">-- Select Driver --</option></select>
                    </div>
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea id="TxtTransferRemarks" class="form-control" rows="2" placeholder="e.g. Cash advance, Salary"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnSaveTransfer" class="btn btn-success" onclick="SaveCompanyTransfer()"><i class="fa fa-paper-plane"></i> Transfer Cash</button>
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── MODAL: Add Company Expense ───────────────────────────────── -->
    <div class="modal fade" id="modalCE" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header" style="background:#c0392b;color:#fff;">
                    <h5 class="modal-title"><i class="fa fa-building"></i> Add Company Expense</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-sm-6"><div class="form-group"><label>Date <span class="text-danger">*</span></label><input type="text" id="TxtCEDate" class="form-control" /></div></div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Category <span class="text-danger">*</span></label>
                                <select id="ddlCECategory" class="form-control">
                                    <option value="">-- Select --</option>
                                    <option>Driver Salary</option>
                                    <option>Fuel</option>
                                    <option>Vehicle Maintenance</option>
                                    <option>Office</option>
                                    <option>Insurance</option>
                                    <option>Other</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6"><div class="form-group"><label>Amount (SGD) <span class="text-danger">*</span></label><input type="number" id="TxtCEAmount" class="form-control" placeholder="0.00" step="0.01" min="0" /></div></div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Linked Driver <small class="text-muted">(optional)</small></label>
                                <select id="ddlCEDriver" class="form-control"><option value="0">-- None --</option></select>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea id="TxtCERemarks" class="form-control" rows="2" placeholder="e.g. May salary, Insurance premium"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnSaveCE" class="btn btn-danger"><i class="fa fa-save"></i> Save</button>
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════
         ALL JS inside document.ready — datepickers initialize correctly
         ════════════════════════════════════════════════════════════════ -->
    <script>
        $(document).ready(function () {

            // ── Datepicker options ─────────────────────────────────────────
            var dpOpts = {
                format: Common_Date_Format,
                autoclose: true,
                uiLibrary: 'bootstrap4',
                iconsLibrary: 'fontawesome',
                size: 'small'
            };

            // ── Initialize ALL datepickers here (inside ready) ─────────────
            $('#TxtCWFrom').datepicker(dpOpts);
            $('#TxtCWTo').datepicker(dpOpts);
            $('#TxtChFrom').datepicker(dpOpts);
            $('#TxtChTo').datepicker(dpOpts);
            $('#TxtExpFrom').datepicker(dpOpts);
            $('#TxtExpTo').datepicker(dpOpts);
            $('#TxtCEDate').datepicker(dpOpts);
            $('#TxtTransferDate').datepicker(dpOpts);

            // ── Default dates (current month) ──────────────────────────────
            var now = new Date();
            var mn = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
            function pad(n) { return n < 10 ? '0' + n : n; }
            var firstDay = '01-' + mn[now.getMonth()] + '-' + now.getFullYear();
            var lastDay = pad(new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate()) + '-' + mn[now.getMonth()] + '-' + now.getFullYear();
            var today = pad(now.getDate()) + '-' + mn[now.getMonth()] + '-' + now.getFullYear();

            $('#TxtCWFrom').val(firstDay); $('#TxtCWTo').val(lastDay);
            $('#TxtChFrom').val(firstDay); $('#TxtChTo').val(lastDay);
            $('#TxtTransferDate').val(today);

            // ── Load users dropdown ────────────────────────────────────────
            $.ajax({
                type: 'GET', url: BaseURL + 'Common/Load_SystemUserDetail', dataType: 'json',
                success: function (data) {
                    $('#ddlCEDriver,#ddlTransferDriver').empty().append('<option value="0">-- None --</option>');
                    $.each(data, function (i, v) {
                        if (v.ID > 0) {
                            var label = v.Name + (v.Role ? ' (' + v.Role + ')' : '');
                            $('#ddlCEDriver').append('<option value="' + v.ID + '">' + v.Name + '</option>');
                            $('#ddlTransferDriver').append('<option value="' + v.ID + '">' + label + '</option>');
                        }
                    });
                }
            });

            // ── Expense Grid ───────────────────────────────────────────────
            window.GrdCmpExp = $('#GrdCmpExp').grid({
                primaryKey: 'CompanyExpenseID', uiLibrary: 'bootstrap4', responsive: true,
                dataSource: BaseURL + 'Wallet/CompanyExpense_FindAll',
                columns: [
                    { field: 'DisplayExpenseDate', width: 100, title: 'DATE', sortable: false },
                    { field: 'Category', width: 130, title: 'CATEGORY', sortable: false },
                    {
                        field: 'Amount', width: 105, title: 'AMOUNT (SGD)', sortable: false, align: 'right',
                        renderer: function (v) { return '<strong style="color:#e74c3c;">$ ' + parseFloat(v).toFixed(2) + '</strong>'; }
                    },
                    {
                        field: 'DriverName', width: 110, title: 'DRIVER', sortable: false,
                        renderer: function (v) { return v && v.trim() ? v : '&mdash;'; }
                    },
                    { field: 'Remarks', width: 160, title: 'REMARKS', sortable: false },
                    { field: 'CreatedByName', width: 110, title: 'ADDED BY', sortable: false },
                    { field: 'DisplayCreatedDate', width: 110, title: 'RECORDED', sortable: false },
                    {
                        field: 'CompanyExpenseID', width: 55, title: '', sortable: false, align: 'center',
                        renderer: function (v) {
                            return '<button onclick="DelCE(' + v + ')" class="badge badge-danger" style="cursor:pointer;border:none;padding:4px 8px;"><i class="fa fa-trash"></i></button>';
                        }
                    }
                ],
                pager: { enable: true, limit: 25, sizes: ArrPaging }
            });

            // ── Save Company Expense ───────────────────────────────────────
            $('#btnSaveCE').click(function () {
                var amt = parseFloat($('#TxtCEAmount').val());
                var dt = $('#TxtCEDate').val();
                var cat = $('#ddlCECategory').val();
                if (!dt) { alert('Please select a date.'); return; }
                if (!cat) { alert('Please select a category.'); return; }
                if (!amt || amt <= 0) { alert('Please enter a valid amount.'); return; }
                $(this).prop('disabled', true).text('Saving...');
                $.ajax({
                    url: BaseURL + 'Wallet/CompanyExpense_Save', type: 'POST',
                    dataType: 'json', contentType: 'application/json',
                    data: JSON.stringify({
                        ExpenseDate: dt, Category: cat, Amount: amt,
                        Remarks: $('#TxtCERemarks').val(),
                        DriverUserID: parseInt($('#ddlCEDriver').val()) || 0
                    }),
                    success: function (r) {
                        $('#btnSaveCE').prop('disabled', false).text('Save');
                        if (r.success) {
                            $('#modalCE').modal('hide');
                            LoadCompanyData(); LoadCompanyHistory(); GrdCmpExp.reload({});
                            $('#TxtCEDate,#TxtCEAmount,#TxtCERemarks').val('');
                            $('#ddlCECategory').val(''); $('#ddlCEDriver').val('0');
                        } else alert('Error: ' + (r.message || 'Failed.'));
                    },
                    error: function () { $('#btnSaveCE').prop('disabled', false).text('Save'); alert('Server error.'); }
                });
            });

            // ── Initial load ───────────────────────────────────────────────
            LoadCompanyData();
            LoadCompanyHistory();

        }); // END document.ready

        // ════════════════════════════════════════════════════════════════════
        // FUNCTIONS (outside ready is OK — they are called on user action)
        // ════════════════════════════════════════════════════════════════════

        function LoadCompanyData() {
            $.ajax({
                url: BaseURL + 'Wallet/CompanyWallet_FindAll', type: 'GET', dataType: 'json',
                data: { FromDate: $('#TxtCWFrom').val(), ToDate: $('#TxtCWTo').val() },
                success: function (r) {
                    if (r.summary) {
                        var s = r.summary;
                        $('#CardTotalEarned').text('$ ' + parseFloat(s.TotalDriverEarnings || 0).toFixed(2));
                        $('#CardHandedOver').text('$ ' + parseFloat(s.TotalHandedOver || 0).toFixed(2));
                        $('#CardDrvExp').text('$ ' + parseFloat(s.TotalDriverExpenses || 0).toFixed(2));
                        $('#CardCmpExp').text('$ ' + parseFloat(s.TotalCompanyExpenses || 0).toFixed(2));
                        $('#CardWithDrv').text('$ ' + parseFloat(s.WithDrivers || 0).toFixed(2));
                        var bal = parseFloat(s.CompanyBalance || 0);
                        $('#CardBal').text('$ ' + bal.toFixed(2));
                        if (bal < 0) $('#WcBal').css('background', 'linear-gradient(135deg,#c0392b,#e74c3c)');
                        else $('#WcBal').css('background', 'linear-gradient(135deg,#6c3483,#8e44ad)');
                    }
                    var tbody = $('#tblDriverBreakdown');
                    tbody.empty();
                    if (r.records && r.records.length > 0) {
                        $.each(r.records, function (i, d) {
                            var balColor = parseFloat(d.Balance) >= 0 ? '#8e44ad' : '#e74c3c';
                            var safeName = (d.DriverName || '').trim().replace(/\\/g, '\\\\').replace(/'/g, "\\'");
                            tbody.append(
                                '<tr class="driver-row" onclick="LoadDriverHistory(' + d.DriverUserID + ',\'' + safeName + '\')">' +
                                '<td><i class="fa fa-user-circle" style="color:#2980b9;margin-right:5px;"></i>' + d.DriverName +
                                ' <small style="color:#aaa;font-size:10px;"><i class="fa fa-mouse-pointer"></i> history</small></td>' +
                                '<td style="text-align:right;color:#27ae60;font-weight:bold;">$ ' + parseFloat(d.TotalEarned).toFixed(2) + '</td>' +
                                '<td style="text-align:right;color:#2980b9;font-weight:bold;">$ ' + parseFloat(d.TotalHandedOver).toFixed(2) + '</td>' +
                                '<td style="text-align:right;color:#e74c3c;font-weight:bold;">$ ' + parseFloat(d.TotalExpenses).toFixed(2) + '</td>' +
                                '<td style="text-align:right;color:' + balColor + ';font-weight:bold;">$ ' + parseFloat(d.Balance).toFixed(2) + '</td>' +
                                '</tr>'
                            );
                        });
                    } else {
                        tbody.append('<tr><td colspan="5" style="text-align:center;color:#999;padding:20px;">No data found.</td></tr>');
                    }
                }
            });
        }

        function ClearCW() {
            $('#TxtCWFrom,#TxtCWTo').val('');
            LoadCompanyData();
        }

        function LoadDriverHistory(uid, name) {
            var from = $('#TxtCWFrom').val();
            var to = $('#TxtCWTo').val();
            $('#modalDrvHistTitle').text(name + ' — Transaction History');
            $('#drvHistBalance').html('');
            $('#tblDrvHistBody').html('<tr><td colspan="5" style="text-align:center;padding:24px;color:#aaa;"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>');
            $('#modalDrvHist').modal('show');
            $.ajax({
                url: BaseURL + 'Wallet/WalletHistory_FindAll',
                type: 'GET', data: { UserID: uid, FromDate: from, ToDate: to }, dataType: 'json',
                success: function (r) {
                    var tbody = $('#tblDrvHistBody');
                    tbody.empty();
                    if (!r.records || r.records.length === 0) {
                        tbody.html('<tr><td colspan="5" style="text-align:center;padding:24px;color:#999;"><i class="fa fa-inbox fa-2x"></i><br/>No transactions for this period.</td></tr>');
                        return;
                    }
                    var tc = 0, td = 0;
                    $.each(r.records, function (i, t) { if ((t.TxType || '').toUpperCase() === 'CREDIT') tc += parseFloat(t.Amount || 0); else td += parseFloat(t.Amount || 0); });
                    $('#drvHistBalance').html('<span class="tx-credit">+$' + tc.toFixed(2) + ' CREDIT</span>&nbsp;&nbsp;<span class="tx-debit">−$' + td.toFixed(2) + ' DEBIT</span>&nbsp;&nbsp;<strong>Net: $' + (tc - td).toFixed(2) + '</strong>');
                    $.each(r.records, function (i, t) {
                        var isC = (t.TxType || '').toUpperCase() === 'CREDIT';
                        var badge = isC ? '<span class="tx-badge tx-badge-c"><i class="fa fa-arrow-up"></i> CREDIT</span>' : '<span class="tx-badge tx-badge-d"><i class="fa fa-arrow-down"></i> DEBIT</span>';
                        var src = '<strong>' + (t.SourceLabel || t.Source || '') + '</strong>';
                        if (t.Source === 'Job' && t.JobFrom) src += '<br><span class="tx-src">' + t.JobFrom + ' → ' + (t.JobTo || '') + (t.CustomerName ? ' | ' + t.CustomerName : '') + '</span>';
                        if (t.Remarks && t.Remarks.trim()) src += '<br><span class="tx-src" style="color:#ccc;">' + t.Remarks + '</span>';
                        tbody.append('<tr>' +
                            '<td style="white-space:nowrap;font-size:11px;color:#666;">' + (t.DisplayDate || '') + '</td>' +
                            '<td>' + badge + '</td><td>' + src + '</td>' +
                            '<td style="text-align:right;" class="' + (isC ? 'tx-credit' : 'tx-debit') + '">' + (isC ? '+' : '−') + ' $' + parseFloat(t.Amount).toFixed(2) + '</td>' +
                            '<td style="text-align:right;font-weight:600;font-size:12px;">$' + parseFloat(t.BalanceAfter).toFixed(2) + '</td>' +
                            '</tr>');
                    });
                }
            });
        }

        function SaveCompanyTransfer() {
            var uid = parseInt($('#ddlTransferDriver').val());
            var amt = parseFloat($('#TxtTransferAmt').val());
            var dt = $('#TxtTransferDate').val();
            if (!uid || uid <= 0) { alert('Please select a driver.'); return; }
            if (!amt || amt <= 0) { alert('Please enter a valid amount.'); return; }
            if (!dt) { alert('Please select a date.'); return; }
            $('#btnSaveTransfer').prop('disabled', true).text('Transferring...');
            $.ajax({
                url: BaseURL + 'Wallet/CompanyToDriver_Transfer', type: 'POST', dataType: 'json',
                data: { DriverUserID: uid, Amount: amt, Remarks: $('#TxtTransferRemarks').val(), TransferDate: dt },
                success: function (r) {
                    $('#btnSaveTransfer').prop('disabled', false).text('Transfer Cash');
                    if (r.success) {
                        $('#modalTransfer').modal('hide');
                        LoadCompanyData(); LoadCompanyHistory();
                        $('#TxtTransferAmt,#TxtTransferRemarks').val('');
                        $('#ddlTransferDriver').val('0');
                    } else alert('Error: ' + (r.message || 'Failed.'));
                },
                error: function (xhr) { $('#btnSaveTransfer').prop('disabled', false).text('Transfer Cash'); alert('Error: ' + (xhr.responseText || 'Server error.')); }
            });
        }

        function LoadCompanyHistory() {
            $('#tblChBody').html('<tr><td colspan="5" style="text-align:center;padding:24px;color:#aaa;"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>');
            $.ajax({
                url: BaseURL + 'Wallet/CompanyWalletHistory_FindAll',
                type: 'GET', data: { FromDate: $('#TxtChFrom').val(), ToDate: $('#TxtChTo').val() }, dataType: 'json',
                success: function (r) {
                    var tbody = $('#tblChBody');
                    tbody.empty();
                    if (!r.records || r.records.length === 0) {
                        tbody.html('<tr><td colspan="5" style="text-align:center;padding:24px;color:#999;"><i class="fa fa-inbox fa-2x"></i><br/>No transactions for this period.</td></tr>');
                        $('#chSummary').html('');
                        return;
                    }
                    var tc = 0, td = 0;
                    $.each(r.records, function (i, t) {
                        var isC = (t.TxType || '').toUpperCase() === 'CREDIT';
                        if (isC) tc += parseFloat(t.Amount || 0); else td += parseFloat(t.Amount || 0);
                        var badge = isC ? '<span class="tx-badge tx-badge-c"><i class="fa fa-arrow-up"></i> IN</span>' : '<span class="tx-badge tx-badge-d"><i class="fa fa-arrow-down"></i> OUT</span>';
                        var src = '<strong>' + (t.SourceLabel || t.Source || '') + '</strong>';
                        if (t.Remarks && t.Remarks.trim()) src += '<br><span class="tx-src">' + t.Remarks + '</span>';
                        tbody.append('<tr>' +
                            '<td style="white-space:nowrap;font-size:11px;color:#666;">' + (t.DisplayDate || '') + '</td>' +
                            '<td>' + badge + '</td><td>' + src + '</td>' +
                            '<td style="text-align:right;" class="' + (isC ? 'tx-credit' : 'tx-debit') + '">' + (isC ? '+' : '−') + ' $' + parseFloat(t.Amount).toFixed(2) + '</td>' +
                            '<td style="text-align:right;font-weight:600;font-size:12px;">$' + parseFloat(t.BalanceAfter).toFixed(2) + '</td>' +
                            '</tr>');
                    });
                    $('#chSummary').html('<span class="tx-credit">+$' + tc.toFixed(2) + ' IN</span>&nbsp;&nbsp;<span class="tx-debit">−$' + td.toFixed(2) + ' OUT</span>&nbsp;&nbsp;<strong>Net: $' + (tc - td).toFixed(2) + '</strong>');
                }
            });
        }

        function ClearCH() { $('#TxtChFrom,#TxtChTo').val(''); LoadCompanyHistory(); }
        function CESearch() { GrdCmpExp.reload({ FromDate: $('#TxtExpFrom').val(), ToDate: $('#TxtExpTo').val(), Category: $('#ddlCEFilter').val() }); }
        function CEClear() { $('#TxtExpFrom,#TxtExpTo').val(''); $('#ddlCEFilter').val(''); GrdCmpExp.reload({}); }
        function DelCE(id) {
            if (!confirm('Delete this company expense?')) return;
            $.ajax({
                url: BaseURL + 'Wallet/CompanyExpense_Delete', type: 'POST', dataType: 'json', contentType: 'application/json',
                data: JSON.stringify({ CompanyExpenseID: id }),
                success: function (r) { if (r.success) { LoadCompanyData(); GrdCmpExp.reload({}); } else alert('Failed.'); }
            });
        }
    </script>
</body>
