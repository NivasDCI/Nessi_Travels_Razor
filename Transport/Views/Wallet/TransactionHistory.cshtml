@model List<Transport.Model.TransactionHistoryViewModel>
@{
    ViewBag.Title = "Transaction History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h2>Transaction History</h2>
            <hr />
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card mb-4">
        <div class="card-header">
            <h5>Filter Transactions</h5>
        </div>
        <div class="card-body">
            <form method="get" class="form-inline">
                <div class="form-group mr-3">
                    <label class="mr-2">Driver:</label>
                    <select name="userId" class="form-control">
                        <option value="">All Drivers</option>
                        @foreach (var driver in ViewBag.Drivers as List<Transport.Model.DriverDropdownModel>)
                        {
                            <option value="@driver.UserID" @(ViewBag.SelectedDriver == driver.UserID ? "selected" : "")>
                                @driver.DriverName
                            </option>
                        }
                    </select>
                </div>
                <div class="form-group mr-3">
                    <label class="mr-2">From Date:</label>
                    <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
                </div>
                <div class="form-group mr-3">
                    <label class="mr-2">To Date:</label>
                    <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
                </div>
                <button type="submit" class="btn btn-primary">Filter</button>
                <a href="@Url.Action("TransactionHistory")" class="btn btn-secondary ml-2">Reset</a>
            </form>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-bordered" id="transactionsTable">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>User</th>
                            <th>Type</th>
                            <th>Category</th>
                            <th>Amount</th>
                            <th>Balance Before</th>
                            <th>Balance After</th>
                            <th>Description</th>
                            <th>Created By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var trans in Model)
                        {
                            <tr>
                                <td>@trans.TransactionDate.ToString("dd-MM-yyyy HH:mm:ss")</td>
                                <td>@trans.UserName (@trans.UserType)</td>
                                <td>
                                    <span class="badge @(trans.TransactionType == "Credit" ? "badge-success" : "badge-danger")">
                                        @trans.TransactionType
                                    </span>
                                </td>
                                <td>@trans.Category</td>
                                <td class="@(trans.TransactionType == "Credit" ? "text-success" : "text-danger")">
                                    @trans.Amount.ToString("C")
                                </td>
                                <td>@trans.BalanceBefore.ToString("C")</td>
                                <td>@trans.BalanceAfter.ToString("C")</td>
                                <td>@trans.Description</td>
                                <td>@trans.CreatedByName</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#transactionsTable').DataTable({
                "pageLength": 50,
                "order": [[0, "desc"]],
                "language": {
                    "emptyTable": "No transactions found"
                }
            });
        });
    </script>
}