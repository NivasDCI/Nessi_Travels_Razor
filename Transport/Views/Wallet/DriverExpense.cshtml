@model Transport.Model.DriverExpenseViewModel
@{
    ViewBag.Title = "Driver Expense";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4>Driver Expense Entry</h4>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("DriverExpense", "Wallet", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <label>Select Driver</label>
                            @Html.DropDownListFor(m => m.DriverUserID,
                                new SelectList(Model.Drivers, "UserID", "DriverName"),
                                "Select Driver",
                                new { @class = "form-control", required = "required" })
                        </div>

                        <div class="form-group">
                            <label>Expense Category</label>
                            @Html.DropDownListFor(m => m.Category,
                                new SelectList(Model.Categories, "CategoryValue", "CategoryText"),
                                "Select Category",
                                new { @class = "form-control", required = "required" })
                        </div>

                        <div class="form-group">
                            <label>Amount</label>
                            @Html.TextBoxFor(m => m.Amount, new { @class = "form-control", type = "number", step = "0.01", required = "required" })
                        </div>

                        <div class="form-group">
                            <label>Expense Date</label>
                            @Html.TextBoxFor(m => m.ExpenseDate, new { @class = "form-control", type = "date", required = "required" })
                        </div>

                        <div class="form-group">
                            <label>Job Code (Optional)</label>
                            @Html.TextBoxFor(m => m.JobCode, new { @class = "form-control", type = "number" })
                        </div>

                        <div class="form-group">
                            <label>Remarks</label>
                            @Html.TextAreaFor(m => m.Remarks, new { @class = "form-control", rows = 3 })
                        </div>

                        <button type="submit" class="btn btn-info btn-block">Save Expense</button>
                        <a href="@Url.Action("Dashboard")" class="btn btn-secondary btn-block mt-2">Cancel</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>