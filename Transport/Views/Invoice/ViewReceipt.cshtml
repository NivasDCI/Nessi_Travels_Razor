@using Transport.Model
@{
    Layout = null;
    var header = (InvoiceHeaderModel)ViewBag.Header;
    var details = (List<InvoiceDetailModel>)ViewBag.Details;
    decimal totalAmount = details.Sum(d => d.Amount ?? 0);
}
<!DOCTYPE html>
<html>
<head>
    <title>Receipt - @header.InvoiceNo</title>
    <meta charset="utf-8" />
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 11px;
            margin: 15px;
        }

        .title-text {
            font-size: 22px;
            font-weight: 700;
            color: red;
            text-align: center;
            margin: 2px;
        }

        .sub-title-text {
            font-size: 12px;
            font-weight: 300;
            color: #000;
            text-align: center;
            line-height: 15px;
            margin: 2px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-family: Arial;
        }

        th {
            background-color: #2c3e50;
            color: #fff;
            padding: 7px 5px;
            text-align: left;
            font-size: 11px;
        }

        td {
            padding: 5px;
            border-bottom: 1px solid #ddd;
            font-size: 11px;
        }

        tr:nth-child(even) {
            background: #f9f9f9;
        }

        .total-row {
            font-weight: bold;
            background: #ecf0f1 !important;
        }

        .badge-credit {
            background: #e74c3c;
            color: #fff;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 10px;
        }

        .badge-cash {
            background: #27ae60;
            color: #fff;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 10px;
        }

        .print-btn {
            position: fixed;
            top: 10px;
            right: 10px;
            padding: 8px 18px;
            background: #007bff;
            color: #fff;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 13px;
            z-index: 999;
        }

        @@media print {
            .print-btn {
                display: none;
            }
        }
    </style>
</head>
<body>
    <button class="print-btn" onclick="window.print()">Print / Download</button>

    <!-- Logo + Company -->
    <table width="100%">
        <tr>
            <td width="15%">
                <img src="@Url.Content("~/AppImages/logo_nissi_151.png")" width="120px" onerror="this.style.display='none'" />
            </td>
            <td width="85%">
                <h2 class="title-text">NISSI TOURS AND TRAVELS PTE. LTD</h2>
                <p class="sub-title-text">291 SERANGOON ROAD, SINGAPORE 218107</p>
                <p class="sub-title-text">TEL: +65 62920521 | HP: +65 90686384 | booking@nissitravels.com</p>
            </td>
        </tr>
    </table>

    <br />

    <!-- Receipt Header Info -->
    <table style="border:1px solid #ccc; margin-bottom:10px;">
        <tr>
            <td style="padding:5px 10px; width:15%;"><strong>Invoice No</strong></td>
            <td style="padding:5px;">: @header.InvoiceNo</td>
            <td style="padding:5px; width:15%;"><strong>Date</strong></td>
            <td style="padding:5px;">: @header.InvoiceDate.ToString("dd MMM yyyy")</td>
        </tr>
        <tr>
            <td style="padding:5px 10px;"><strong>Period</strong></td>
            <td style="padding:5px;">: @header.DisplayStartDate — @header.DisplayEndDate</td>
            <td style="padding:5px;"><strong>Type</strong></td>
            <td style="padding:5px;">
                :
                @if (header.IsCredit)
                {<span class="badge-credit">Credit</span> }
                else
                { <span class="badge-cash">Cash</span>}
            </td>
        </tr>
        @if (!string.IsNullOrEmpty(header.CustomerName))
        {
            <tr>
                <td style="padding:5px 10px;"><strong>Customer</strong></td>
                <td colspan="3" style="padding:5px;">: @header.CustomerName</td>
            </tr>
        }
        @if (!string.IsNullOrEmpty(header.JobVendorName))
        {
            <tr>
                <td style="padding:5px 10px;"><strong>Job Given By</strong></td>
                <td colspan="3" style="padding:5px;">: @header.JobVendorName</td>
            </tr>
        }
        @if (!string.IsNullOrEmpty(header.DrivingByName))
        {
            <tr>
                <td style="padding:5px 10px;"><strong>Driver</strong></td>
                <td colspan="3" style="padding:5px;">: @header.DrivingByName</td>
            </tr>
        }
        @if (!string.IsNullOrEmpty(header.VehicleName))
        {
            <tr>
                <td style="padding:5px 10px;"><strong>Vehicle</strong></td>
                <td colspan="3" style="padding:5px;">: @header.VehicleName</td>
            </tr>
        }
    </table>

    <!-- Job Details Table (like Screenshot 1) -->
    <table>
        <thead>
            <tr>
                <th style="width:8%">DATE</th>
                <th style="width:7%">TIME</th>
                <th style="width:8%">VEHICLE NO</th>
                <th style="width:22%">FROM</th>
                <th style="width:22%">TO</th>
                <th style="width:8%">GIVEN</th>
                <th style="width:10%">DRIVING BY</th>
                <th style="width:10%">CUSTOMER NAME</th>
                <th style="width:5%; text-align:right;">CREDIT</th>
                <th style="width:5%; text-align:right;">CASH</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in details)
            {
                <tr>
                    <td>@d.DisplayJobDate</td>
                    <td>@d.JobTime</td>
                    <td>@d.VehicleName</td>
                    <td>@d.JobFrom</td>
                    <td>@d.JobTo</td>
                    <td>@d.JobVendorName</td>
                    <td>@d.DrivingByName</td>
                    <td>@d.CustomerName</td>
                    <td style="text-align:right; color:#c0392b; font-weight:bold;">
                        @(d.Credit.HasValue ? d.Credit.Value.ToString("N2") : "")
                    </td>
                    <td style="text-align:right;">
                        @(d.Cash.HasValue ? d.Cash.Value.ToString("N2") : "")
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="total-row">
                <td colspan="8" style="text-align:right; padding:8px;"><strong>Total</strong></td>
                <td style="text-align:right; padding:8px; color:#c0392b;">
                    <strong>@details.Sum(d => d.Credit ?? 0).ToString("N2")</strong>
                </td>
                <td style="text-align:right; padding:8px;">
                    <strong>@details.Sum(d => d.Cash ?? 0).ToString("N2")</strong>
                </td>
            </tr>
            <tr>
                <td colspan="8" style="text-align:right; padding:8px; font-size:12px;"><strong>Grand Total</strong></td>
                <td colspan="2" style="text-align:right; padding:8px; font-size:13px; color:darkgreen;">
                    <strong>SGD @totalAmount.ToString("N2")</strong>
                </td>
            </tr>
        </tfoot>
    </table>

    <br />
    <div style="text-align:center; color:#7f8c8d;">
        <em>This is a computer generated receipt - Invoice Ref: @header.InvoiceNo</em>
    </div>
</body>
</html>
