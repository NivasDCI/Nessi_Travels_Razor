@* @using Transport.Model
@{
    Layout = null;
    var header  = (InvoiceHeaderModel)ViewBag.Header;
    var details = (List<InvoiceDetailModel>)ViewBag.Details;
    decimal creditTotal = details.Sum(d => d.Credit ?? 0);
    decimal cashTotal   = details.Sum(d => d.Cash   ?? 0);
    decimal grandTotal  = details.Sum(d => d.Amount ?? 0);
    string  periodLabel = header.DisplayStartDate + " TO " + header.DisplayEndDate;
    string  vendorName  = string.IsNullOrEmpty(header.JobVendorName) ? header.CustomerName : header.JobVendorName;
}
<!DOCTYPE html>
<html>
<head>
    <title>Job Sheet - @header.InvoiceNo</title>
    <meta charset="utf-8" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family: Arial, Helvetica, sans-serif; font-size: 11px; background:#fff; }
        .page { padding: 18px 22px; }

        /* Header */
        .co-header { display:table; width:100%; border-bottom:2px solid #000; padding-bottom:8px; margin-bottom:10px; }
        .co-logo   { display:table-cell; width:120px; vertical-align:middle; }
        .co-logo img { width:110px; }
        .co-info   { display:table-cell; vertical-align:middle; padding-left:12px; }
        .co-name   { font-size:20px; font-weight:900; color:#c0392b; }
        .co-sub    { font-size:11px; line-height:17px; color:#333; }

        /* Title */
        .sheet-title { text-align:center; font-size:13px; font-weight:bold;
                       border:1px solid #000; padding:5px; margin-bottom:8px;
                       letter-spacing:1px; background:#f5f5f5; }

        /* Table */
        table.jobs { width:100%; border-collapse:collapse; }
        table.jobs th { background:#2c3e50; color:#fff; padding:6px 4px;
                        font-size:10px; border:1px solid #1a252f; text-align:left; }
        table.jobs td { padding:5px 4px; border:1px solid #ccc; font-size:10px;
                        vertical-align:top; }
        table.jobs tr:nth-child(even) td { background:#f9f9f9; }
        table.jobs td.r  { text-align:right; }
        table.jobs td.c  { text-align:center; }
        table.jobs tfoot td { background:#ecf0f1; font-weight:bold;
                              border-top:2px solid #2c3e50; }

        /* Total bar */
        .total-bar { background:#2c3e50; color:#fff; padding:7px 10px;
                     font-size:13px; font-weight:bold; text-align:right; }
        .total-bar span { font-size:15px; }

        /* Footer */
        .footer { text-align:center; font-size:10px; color:#777;
                  border-top:1px dashed #ccc; margin-top:8px; padding-top:6px; }

        /* Print buttons */
        .no-print { position:fixed; top:10px; right:10px; z-index:999; }
        .no-print button { padding:7px 14px; border:none; border-radius:4px;
                           cursor:pointer; font-size:12px; margin-left:5px; color:#fff; }
        .btn-print { background:#2c3e50; }
        .btn-inv   { background:#c0392b; }

        @@media print { .no-print { display:none; } }
    </style>
</head>
<body>

    <div class="no-print">
        <button class="btn-print" onclick="window.print()">&#128438; Print Job Sheet</button>
        <button class="btn-inv"   onclick="OpenInvoice()">&#128196; View Invoice</button>
    </div>

    <div class="page">

        <!-- Company Header -->
        <div class="co-header">
            <div class="co-logo">
                <img src="@Url.Content("~/AppImages/logo_nissi_151.png")" onerror="this.style.display='none'" />
            </div>
            <div class="co-info">
                <div class="co-name">NISSI TRANSPORT PTE.LTD</div>
                <div class="co-sub">
                    291 SERANGOON ROAD, SINGAPORE - 218107<br/>
                    TEL NO +65 91000521, +65 88660521 &nbsp;|&nbsp; Email: nissi_transport@yahoo.com
                </div>
            </div>
        </div>

        <!-- Sheet Title -->
        <div class="sheet-title">
            NISSI TRANSPORT (@periodLabel) - JOB SHEET &nbsp;|&nbsp; Ref: @header.InvoiceNo
        </div>

        <!-- Date-wise Job Table matching PDF 1 -->
        <table class="jobs">
            <thead>
                <tr>
                    <th style="width:8%">DATE</th>
                    <th style="width:6%">TIME</th>
                    <th style="width:7%">VEHICLE NO</th>
                    <th style="width:19%">FROM</th>
                    <th style="width:19%">TO</th>
                    <th style="width:9%">JOB GIVEN BY</th>
                    <th style="width:10%">DRIVING BY</th>
                    <th style="width:16%">CUSTOMER NAME</th>
                    <th style="width:6%;text-align:right;">CREDIT</th>
                    <th style="width:5%;text-align:right;">CASH</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in details)
                {
                <tr>
                    <td>@d.DisplayJobDate</td>
                    <td class="c">@d.JobTime</td>
                    <td class="c">@d.VehicleName</td>
                    <td>@d.JobFrom</td>
                    <td>@d.JobTo</td>
                    <td class="c">@d.JobVendorName</td>
                    <td>@d.DrivingByName</td>
                    <td>@d.CustomerName</td>
                    <td class="r" style="color:#c0392b;font-weight:bold;">
                        @(d.Credit.HasValue && d.Credit > 0 ? d.Credit.Value.ToString("N2") : "")
                    </td>
                    <td class="r">
                        @(d.Cash.HasValue && d.Cash > 0 ? d.Cash.Value.ToString("N2") : "")
                    </td>
                </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="8" style="text-align:right; padding-right:10px;">
                        TOTAL (@details.Count jobs)
                    </td>
                    <td class="r" style="color:#c0392b;">
                        @(creditTotal > 0 ? creditTotal.ToString("N2") : "")
                    </td>
                    <td class="r">
                        @(cashTotal > 0 ? cashTotal.ToString("N2") : "")
                    </td>
                </tr>
            </tfoot>
        </table>

        <div class="total-bar">
            TOTAL &nbsp;&nbsp; $ &nbsp;<span>@grandTotal.ToString("N2")</span>
        </div>

        <div class="footer">
            Invoice Ref: <strong>@header.InvoiceNo</strong> &nbsp;|&nbsp;
            Generated: @header.InvoiceDate.ToString("dd MMM yyyy")
        </div>

    </div>

    <script>
        function OpenInvoice() {
            var w = screen.availWidth - 40, h = screen.availHeight - 40;
            window.open('@Url.Content("~/Reports/ViewInvoice")?invoiceId=@header.InvoiceID',
                'invoice_@header.InvoiceID', 'width=' + w + ',height=' + h + ',scrollbars=yes');
        }
    </script>
</body>
</html> *@

@using Transport.Model
@{
    Layout = null;
    var header  = (InvoiceHeaderModel)ViewBag.Header;
    var details = (List<InvoiceDetailModel>)ViewBag.Details;
    decimal grandTotal = details.Sum(d => d.Amount ?? 0);
    string periodLabel = header.DisplayStartDate + " TO " + header.DisplayEndDate;
}
<!DOCTYPE html>
<html>
<head>
    <title>Job Sheet - @header.InvoiceNo</title>
    <meta charset="utf-8" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family: Arial, Helvetica, sans-serif; font-size:10pt; background:#fff; }
        .page { padding:14px 18px; }

        .sheet-title { text-align:center; font-size:11pt; font-weight:bold;
                       margin-bottom:8px; letter-spacing:0.5px; }

        table.jobs { width:100%; border-collapse:collapse; border:1px solid #000; }
        table.jobs th { background:#fff; color:#000; padding:5px 4px; font-size:9pt;
                        font-weight:bold; border:1px solid #000; text-align:left; }
        table.jobs td { padding:4px; border:1px solid #000; font-size:9pt; vertical-align:top; }
        table.jobs td.r { text-align:right; }
        table.jobs td.c { text-align:center; }

        .total-line { text-align:right; font-size:11pt; font-weight:bold;
                      margin-top:6px; padding-right:2px; }

        .no-print { position:fixed; top:10px; right:10px; z-index:999; }
        .no-print button { padding:7px 14px; border:none; border-radius:4px;
                           cursor:pointer; font-size:12px; margin-left:5px; color:#fff; }
        .btn-p { background:#2c3e50; }
        .btn-i { background:#c0392b; }

        @@media print {
            .no-print { display:none; }
            @@page { size: A4 landscape; margin:10mm; }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <button class="btn-p" onclick="window.print()">Print Job Sheet</button>
        <button class="btn-i" onclick="OpenInvoice()">View Invoice</button>
    </div>

    <div class="page">
        <div class="sheet-title">NISSI TRANSPORT (@periodLabel) - JOB SHEET</div>

        <table class="jobs">
            <thead>
                <tr>
                    <th style="width:7%">DATE</th>
                    <th style="width:5%">TIME</th>
                    <th style="width:7%">VEHICLE NO</th>
                    <th style="width:20%">FROM</th>
                    <th style="width:20%">TO</th>
                    <th style="width:8%">JOB GIVEN BY</th>
                    <th style="width:10%">DRIVING BY</th>
                    <th style="width:17%">CUSTOMER NAME</th>
                    <th style="width:6%;text-align:right;">CREDIT</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in details)
                {
                <tr>
                    <td>@d.DisplayJobDate</td>
                    <td class="c">@d.JobTime</td>
                    <td class="c">@d.VehicleName</td>
                    <td>@d.JobFrom</td>
                    <td>@d.JobTo</td>
                    <td class="c">@d.JobVendorName</td>
                    <td>@d.DrivingByName</td>
                    <td>@d.CustomerName</td>
                    <td class="r">@(d.Amount.HasValue && d.Amount > 0 ? d.Amount.Value.ToString("N0") : "")</td>
                </tr>
                }
            </tbody>
        </table>

        <div class="total-line">TOTAL $ @grandTotal.ToString("N2")</div>
    </div>

    <script>
        function OpenInvoice() {
            window.open('@Url.Content("~/Reports/ViewInvoice")?invoiceId=@header.InvoiceID',
                'inv_@header.InvoiceID', 'width=' + screen.availWidth + ',height=' + screen.availHeight + ',scrollbars=yes');
        }
    </script>
</body>
</html>

