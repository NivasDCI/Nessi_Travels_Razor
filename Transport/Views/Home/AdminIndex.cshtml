<script>
    function JobRequests() {
    var ParamData = [
        ]

        $("#txtSessionURL").val("Home/AdminIndex");
        AddBackURLStore(JSON.stringify(ParamData));
        GetMenu('@Url.Action("ListJobRequests", "Job")' + '?HeaderViewID=JOBS&DetailViewID=JOBN037');
    }

    function Jobs() {
    var ParamData = [
        ]

        $("#txtSessionURL").val("Home/AdminIndex");
        AddBackURLStore(JSON.stringify(ParamData));
        GetMenu('@Url.Action("ListJobs", "Job")' + '?HeaderViewID=JOBS&DetailViewID=JOBN037');
    }

    $.ajax({
        type: "GET",
        url: BaseURL + "Reports/Dashboard_FindAll",
        data: { },
        datatype: "Json",
        success: function (data) {

            if (!isNaN(data.Requests)) {
                $('#lblrequests').text(parseInt(data.Requests));
            }
            else {
                $('#lblrequests').text('0');
            }
            if (!isNaN(data.PendingJobs)) {
                $('#lblpendingjobs').text(parseInt(data.PendingJobs));
            }
            else {
                $('#lblpendingjobs').text('0');
            } if (!isNaN(data.OnGoingJobs)) {
                $('#lblongoingjobs').text(parseInt(data.OnGoingJobs));
            }
            else {
                $('#lblongoingjobs').text('0');
            } if (!isNaN(data.CompletedJobs)) {
                $('#lblcompletedjobs').text(parseInt(data.CompletedJobs));
            }
            else {
                $('#lblcompletedjobs').text('0');
            } if (!isNaN(data.TotalCredit)) {
                $('#lblcredit').text('$' + parseFloat(data.TotalCredit).toFixed(2));
            }
            else {
                $('#lblcredit').text('$ 0');
            } if (!isNaN(data.TotalCash)) {
                $('#lblcash').text('$' + parseFloat(data.TotalCash).toFixed(2));
            }
            else {
                $('#lblcash').text('$ 0');
            }

        }
    });

</script>
