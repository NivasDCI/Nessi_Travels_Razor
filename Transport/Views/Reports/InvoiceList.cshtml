@using Transport.Repository.Resource;
@{ Layout = ""; }
<head>
<style>
.s-paid    {background:#27ae60;color:#fff;padding:2px 9px;border-radius:10px;font-size:11px;font-weight:bold;}
.s-partial {background:#f39c12;color:#fff;padding:2px 9px;border-radius:10px;font-size:11px;font-weight:bold;}
.s-unpaid  {background:#e74c3c;color:#fff;padding:2px 9px;border-radius:10px;font-size:11px;font-weight:bold;}
.inv-no    {color:#c0392b;font-weight:bold;}
.inv-amt   {color:#155724;font-weight:bold;}
.bal-amt   {color:#c0392b;font-weight:bold;}
.ab        {border:none;border-radius:3px;padding:3px 9px;font-size:10px;color:#fff;cursor:pointer;margin:1px;}
.ab-doc    {background:#2c3e50;} .ab-doc:hover{background:#1a252f;}
.ab-pay    {background:#27ae60;} .ab-pay:hover{background:#1e8449;}
.ab-del    {background:#e74c3c;} .ab-del:hover{background:#c0392b;}
.modal-hd  {background:#2c3e50;color:#fff;}
.modal-hd .close{color:#fff;}
.pay-row   {background:#f8f9fa;border:1px solid #dee2e6;border-radius:4px;padding:7px 36px 7px 10px;margin-bottom:5px;font-size:12px;position:relative;}
.pay-del   {position:absolute;right:7px;top:6px;background:#e74c3c;color:#fff;border:none;border-radius:3px;padding:1px 7px;font-size:11px;cursor:pointer;}
.prog-wrap {background:#eee;border-radius:6px;height:7px;margin-top:2px;}
.prog-bar  {background:#27ae60;border-radius:6px;height:7px;transition:width .3s;}
.cash-fld,.bank-fld{display:none;}
.dash-card {border-radius:8px;padding:16px 20px;color:#fff;margin-bottom:14px;}
.dash-lbl  {font-size:11px;opacity:.85;text-transform:uppercase;letter-spacing:.5px;}
.dash-val  {font-size:24px;font-weight:900;margin-top:2px;}
.dash-sub  {font-size:11px;opacity:.75;margin-top:2px;}
.sum-prev  {background:#fff3cd;border:1px solid #ffc107;border-radius:6px;padding:10px;margin-bottom:10px;font-size:13px;}
</style>
<script>
var GrdInv, _payInvID=0, _payBalance=0;

// ── Datepickers ──────────────────────────────────────────────────────
$(["#TxtFromDate","#TxtToDate","#txtManualInvDate","#txtManualStartDate",
   "#txtManualEndDate","#txtPayDate","#txtSumFrom","#txtSumTo"].join(",")).each(function(){
    $(this).datepicker({format:Common_Date_Format,autoclose:true,uiLibrary:"bootstrap4",iconsLibrary:"fontawesome",size:"small"});
});

// ── Load all vendor dropdowns at once ────────────────────────────────
function LoadVendors(){
    $.ajax({type:"GET",url:BaseURL+"Common/Load_JobVendors",datatype:"Json",success:function(data){
        // All 4 vendor selects
        $("#ddlVendorFilter,#ddlInvVendor,#ddlSumVendor").each(function(){
            var $s=$(this);
            // Keep only the first option (-- All / -- Select)
            $s.find("option:not(:first)").remove();
            $.each(data,function(i,v){
                if(v.ID>0) $s.append('<option value="'+v.ID+'|'+v.Name+'">'+v.Name+'</option>');
            });
        });
    }});
}
LoadVendors();

// ── Load users for cash receiver ─────────────────────────────────────
$.ajax({type:"GET",url:BaseURL+"Common/Load_SystemUserDetail",datatype:"Json",success:function(data){
    $("#ddlReceivedBy").append('<option value="">-- Select --</option>');
    $.each(data,function(i,v){ if(v.ID>0) $("#ddlReceivedBy").append('<option value="'+v.ID+'|'+v.Name+'">'+v.Name+'</option>'); });
}});

// ── Dashboard cards ──────────────────────────────────────────────────
function LoadDashboard(vendorName){
    var vn = vendorName || "";
    $.ajax({url:BaseURL+"Reports/InvoiceDashboard",type:"GET",
        data:{VendorName:vn},
        dataType:"json",
        success:function(r){
            if(!r.success){ console.error("Dashboard error:",r.message); return; }
            $("#dashInvoiced").text("$"+parseFloat(r.TotalInvoiced||0).toFixed(2));
            $("#dashCollected").text("$"+parseFloat(r.TotalCollected||0).toFixed(2));
            $("#dashPending").text("$"+parseFloat(r.TotalPending||0).toFixed(2));
            var label = vn ? vn : "all vendors";
            $("#dashCount").text(r.TotalInvoices+" invoice"+(r.TotalInvoices!==1?"s":"")+" — "+label);
        },
        error:function(xhr){ console.error("Dashboard AJAX failed",xhr.status,xhr.statusText); }
    });
}
LoadDashboard("");

// ── Grid ─────────────────────────────────────────────────────────────
GrdInv = $("#GrdInv").grid({
    primaryKey:"InvoiceID", uiLibrary:"bootstrap4", responsive:true,
    dataSource: BaseURL+"Reports/Invoice_FindAll",
    columns:[
        {field:"InvoiceNo",         width:120, title:"INVOICE ID",  sortable:false,
         renderer:function(v){return '<span class="inv-no">'+v+'</span>';}},
        {field:"DisplayInvoiceDate",width:90,  title:"DATE",        sortable:false},
        {field:"BillToName",        width:130, title:"BILL TO",     sortable:false},
        {field:"JobVendorName",     width:110, title:"VENDOR",      sortable:false},
        {field:"DisplayStartDate",  width:80,  title:"FROM",        sortable:false},
        {field:"DisplayEndDate",    width:80,  title:"TO",          sortable:false},
        {field:"TotalAmount",       width:90,  title:"INV AMOUNT",  sortable:false, align:"right",
         renderer:function(v){return '<span class="inv-amt">$'+parseFloat(v||0).toFixed(2)+'</span>';}},
        {field:"TotalPaid",         width:80,  title:"PAID",        sortable:false, align:"right",
         renderer:function(v,rec){
             var tot=parseFloat(rec.TotalAmount||0), paid=parseFloat(v||0);
             var pct=tot>0?Math.min(100,(paid/tot)*100):0;
             return '$'+paid.toFixed(2)+'<div class="prog-wrap"><div class="prog-bar" style="width:'+pct+'%"></div></div>';
         }},
        {field:"BalanceAmount",     width:80,  title:"BALANCE",     sortable:false, align:"right",
         renderer:function(v){
             var bal=parseFloat(v||0);
             return bal<=0?'<span style="color:#27ae60;font-weight:bold;">&#10003; Cleared</span>':
                           '<span class="bal-amt">$'+bal.toFixed(2)+'</span>';
         }},
        {field:"PaymentStatus",     width:72,  title:"STATUS",      sortable:false, align:"center",
         renderer:function(v){
             var cls=v==="Paid"?"s-paid":v==="Partial"?"s-partial":"s-unpaid";
             return '<span class="'+cls+'">'+(v||"Unpaid")+'</span>';
         }},
        {field:"InvoiceID",         width:95,  title:"DOCUMENT",    sortable:false, align:"center",
         renderer:function(v,rec){
             // isManual=true means no sheet tab; totalJobs=0 also means no sheet
             return '<button class="ab ab-doc" onclick="OpenDocModal('+v+',\''+rec.InvoiceNo+'\','+
                    (rec.IsManual?'true':'false')+','+parseInt(rec.TotalJobs||0)+')"><i class="fa fa-file-alt"></i> View</button>';
         }},
        {field:"InvoiceID",         width:70,  title:"PAYMENT",     sortable:false, align:"center",
         renderer:function(v,rec){
             return '<button class="ab ab-pay" onclick="OpenPayment('+v+',\''+rec.InvoiceNo+'\','+
                    parseFloat(rec.TotalAmount||0)+','+parseFloat(rec.TotalPaid||0)+','+
                    parseFloat(rec.BalanceAmount||0)+')"><i class="fa fa-money-bill"></i> Pay</button>';
         }},
        {field:"InvoiceID",         width:38,  title:"",            sortable:false, align:"center",
         renderer:function(v,rec){
             return '<button class="ab ab-del" onclick="DelInv('+v+',\''+rec.InvoiceNo+'\')"><i class="fa fa-trash"></i></button>';
         }}
    ],
    pager:{enable:true,limit:20,sizes:[10,20,50,100]}
});
GrdInv.on("dataBound",function(e,records){
    var tot=0,paid=0,bal=0;
    $.each(records,function(){
        tot +=parseFloat(this.TotalAmount||0);
        paid+=parseFloat(this.TotalPaid||0);
        bal +=parseFloat(this.BalanceAmount||0);
    });
    $("#sumTotal").text("$"+tot.toFixed(2));
    $("#sumPaid").text("$"+paid.toFixed(2));
    $("#sumBal").text("$"+bal.toFixed(2));
});

// ── Current vendor helper ────────────────────────────────────────────
function currentVendor(){
    var sel=$("#ddlVendorFilter").val();
    return sel?sel.split("|")[1]:"";
}

// ── Search / Clear ────────────────────────────────────────────────────
function DoSearch(){
    var vendorSel=$("#ddlVendorFilter").val();
    var vendorName=vendorSel?vendorSel.split("|")[1]:"";
    GrdInv.clear();
    GrdInv.reload({
        BillToName:    $("#txtBillTo").val().trim(),
        InvoiceNo:     $("#txtInvNo").val().trim(),
        FromDate:      $("#TxtFromDate").val(),
        ToDate:        $("#TxtToDate").val(),
        PaymentStatus: $("#ddlPayFilter").val(),
        VendorName:    vendorName
    });
    // Refresh cards to reflect the selected vendor
    LoadDashboard(vendorName);
}
function DoClear(){
    $("#txtBillTo,#txtInvNo,#TxtFromDate,#TxtToDate").val("");
    $("#ddlPayFilter,#ddlVendorFilter").val("");
    GrdInv.reload({});
    LoadDashboard("");  // Reset cards to show all vendors
}
document.onkeydown=function(e){if((e?e.which:event.keyCode)===13){DoSearch();return false;}};
$("#btnSearch").click(DoSearch);
$("#btnClear").click(DoClear);

// ── Document Modal: Invoice only for manual, both tabs for auto ───────
var _docInvID=0;
function OpenDocModal(id, invNo, isManual, totalJobs){
    _docInvID=id;
    $("#docModalTitle").text(invNo);
    if(isManual || totalJobs===0){
        // Invoice only - hide sheet tab
        $("#tabSheetBtn").hide();
        ShowDocTab("invoice");
    } else {
        $("#tabSheetBtn").show();
        ShowDocTab("invoice");
    }
    $("#modalDocument").modal("show");
}
function ShowDocTab(tab){
    if(tab==="invoice"){
        $("#tabInvoiceBtn").css({background:"#c0392b",color:"#fff"});
        $("#tabSheetBtn").css({background:"",color:""});
        $("#docFrame").attr("src", BaseURL+"Reports/ViewInvoice?invoiceId="+_docInvID);
    } else {
        $("#tabSheetBtn").css({background:"#2c3e50",color:"#fff"});
        $("#tabInvoiceBtn").css({background:"",color:""});
        $("#docFrame").attr("src", BaseURL+"Reports/ViewReceipt?invoiceId="+_docInvID);
    }
}
function OpenPrint(){ window.open($("#docFrame").attr("src"),"_blank"); }

// ── Payment Modal ─────────────────────────────────────────────────────
function OpenPayment(id,invNo,total,paid,balance){
    _payInvID=id; _payBalance=balance;
    $("#payTitle").text("Payments - "+invNo);
    $("#payInvTotal").text("$"+parseFloat(total).toFixed(2));
    $("#payInvPaid").text("$"+parseFloat(paid).toFixed(2));
    $("#payInvBal").text("$"+parseFloat(balance).toFixed(2));
    ResetPayForm();
    LoadPayHistory(id);
    $("#modalPayment").modal("show");
}
function LoadPayHistory(id){
    $("#payHistory").html('<p class="text-muted" style="font-size:12px;">Loading...</p>');
    $.ajax({url:BaseURL+"Reports/GetInvoicePayments",type:"GET",data:{InvoiceID:id},dataType:"json",
        success:function(r){
            if(!r.records||r.records.length===0){
                $("#payHistory").html('<p class="text-muted" style="font-size:12px;">No payments recorded yet.</p>');
                return;
            }
            var html="";
            $.each(r.records,function(i,p){
                html+='<div class="pay-row"><button class="pay-del" onclick="DelPay('+p.PaymentID+')">&#128465;</button>';
                html+="<strong>"+p.PaymentDate+"</strong> &nbsp;|&nbsp; ";
                html+='<strong style="color:#27ae60;">$'+parseFloat(p.PaidAmount).toFixed(2)+"</strong>";
                html+=" &nbsp;|&nbsp; "+p.PaymentMode;
                if(p.AccountName)    html+=" &rarr; "+p.AccountName;
                if(p.ReceivedByName) html+=" &rarr; "+p.ReceivedByName;
                if(p.Remarks)        html+=' &mdash; <em>'+p.Remarks+"</em>";
                html+="</div>";
            });
            $("#payHistory").html(html);
        }
    });
}
function DelPay(pid){
    if(!confirm("Delete this payment record?")) return;
    $.ajax({url:BaseURL+"Reports/DeletePayment",type:"POST",data:{PaymentID:pid},dataType:"json",
        success:function(r){ if(r.success){ LoadPayHistory(_payInvID); GrdInv.reload(); LoadDashboard(currentVendor()); } }
    });
}
function ResetPayForm(){
    $("#ddlPayMode").val(""); $(".cash-fld,.bank-fld").hide();
    $("#ddlReceivedBy").val(""); $("#txtPayAccount,#txtPayRemarks").val("");
    var d=new Date(), mn=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    function p(n){return n<10?"0"+n:n;}
    $("#txtPayDate").val(p(d.getDate())+"-"+mn[d.getMonth()]+"-"+d.getFullYear());
    $("#txtPayAmt").val(parseFloat(_payBalance||0).toFixed(2));
}
$("#ddlPayMode").change(function(){
    var v=$(this).val(); $(".cash-fld,.bank-fld").hide();
    if(v==="Cash")        $(".cash-fld").show();
    if(v==="BankTransfer") $(".bank-fld").show();
});
$("#btnRecordPay").click(function(){
    var mode=$("#ddlPayMode").val(), amt=parseFloat($("#txtPayAmt").val());
    if(!mode){alert("Please select payment mode.");return;}
    if(isNaN(amt)||amt<=0){alert("Enter a valid amount.");return;}
    if(amt>_payBalance+0.01){alert("Amount exceeds remaining balance of $"+parseFloat(_payBalance).toFixed(2));return;}
    var rcvByID="", rcvByName="";
    if(mode==="Cash"){
        var sel=$("#ddlReceivedBy").val();
        if(!sel){alert("Please select who received the cash.");return;}
        var pts=sel.split("|"); rcvByID=pts[0]; rcvByName=pts[1];
    }
    var $btn=$(this).prop("disabled",true).text("Saving...");
    $.ajax({url:BaseURL+"Reports/AddPayment",type:"POST",
        data:{InvoiceID:_payInvID,PaymentDate:$("#txtPayDate").val(),PaidAmount:amt,
              PaymentMode:mode,AccountName:$("#txtPayAccount").val(),
              ReceivedByUserID:rcvByID,ReceivedByName:rcvByName,Remarks:$("#txtPayRemarks").val()},
        dataType:"json",
        success:function(r){
            $btn.prop("disabled",false).text("Record Payment");
            if(r.success){
                _payBalance=parseFloat(r.balance||0);
                $("#payInvPaid").text("$"+parseFloat(r.totalPaid||0).toFixed(2));
                $("#payInvBal").text("$"+parseFloat(r.balance||0).toFixed(2));
                ResetPayForm(); LoadPayHistory(_payInvID); GrdInv.reload(); LoadDashboard(currentVendor());
            } else { alert("Error: "+r.message); }
        },
        error:function(xhr){
            $btn.prop("disabled",false).text("Record Payment");
            alert("Server error "+xhr.status+". Please do Clean then Rebuild the project.");
        }
    });
});

// ── Create Invoice ─────────────────────────────────────────────────────
$("#btnCreateInvoice").click(function(){
    $("#frmManual")[0].reset();
    var d=new Date(), mn=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    function p(n){return n<10?"0"+n:n;}
    $("#txtManualInvDate").val(p(d.getDate())+"-"+mn[d.getMonth()]+"-"+d.getFullYear());
    $("#txtManualDesc").val("TRANSPORT PROVIDED");
    // Reload vendors in case they changed
    LoadVendors();
    $("#modalCreate").modal("show");
});
// Auto-fill when vendor selected
$("#ddlInvVendor").change(function(){
    var sel=$(this).val();
    if(!sel){return;}
    var vid=sel.split("|")[0];
    $.ajax({url:BaseURL+"Reports/GetVendorInfo",type:"GET",data:{vendorCode:parseInt(vid)},dataType:"json",
        success:function(r){
            if(r.success){
                $("#txtManualBillTo").val(r.name);
                $("#txtManualAddress").val(r.address);
            }
        }
    });
});
$("#btnSaveManual").click(function(){
    var billTo=$("#txtManualBillTo").val().trim();
    var amt=parseFloat($("#txtManualAmount").val());
    if(!billTo){alert("Bill To Name is required.");return;}
    if(isNaN(amt)||amt<=0){alert("A valid Amount is required.");return;}
    var $btn=$(this).prop("disabled",true).text("Saving...");
    $.ajax({
        url:BaseURL+"Reports/CreateManualInvoice",
        type:"POST",
        data:{
            BillToName:    billTo,
            BillToAddress: $("#txtManualAddress").val().trim(),
            InvoiceDate:   $("#txtManualInvDate").val(),
            StartDate:     $("#txtManualStartDate").val(),
            EndDate:       $("#txtManualEndDate").val(),
            TotalAmount:   amt,
            Terms:         $("#ddlManualTerms").val(),
            Description:   $("#txtManualDesc").val().trim()
        },
        dataType:"json",
        success:function(r){
            $btn.prop("disabled",false).text("Save & Generate");
            if(r.success){
                $("#modalCreate").modal("hide");
                GrdInv.reload();
                LoadDashboard(currentVendor());
                // Open invoice view immediately - manual so isManual=true, no sheet
                setTimeout(function(){ OpenDocModal(r.invoiceId, r.invoiceNo, true, 0); }, 500);
            } else {
                alert("Error saving invoice: "+r.message);
            }
        },
        error:function(xhr){
            $btn.prop("disabled",false).text("Save & Generate");
            alert("Server error "+xhr.status+".\nDid you rebuild the project after replacing ReportsController.cs?");
        }
    });
});

// ── Summary ────────────────────────────────────────────────────────────
$("#btnSummary").click(function(){
    LoadVendors(); // ensure populated
    var d=new Date(), mn=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    function p(n){return n<10?"0"+n:n;}
    var first="01-"+mn[d.getMonth()]+"-"+d.getFullYear();
    var last=p(new Date(d.getFullYear(),d.getMonth()+1,0).getDate())+"-"+mn[d.getMonth()]+"-"+d.getFullYear();
    $("#txtSumFrom").val(first); $("#txtSumTo").val(last);
    $("#sumResult").hide();
    $("#modalSummary").modal("show");
});
$("#btnGenSummary").click(function(){
    var vendorSel=$("#ddlSumVendor").val();
    var vendorName=vendorSel?vendorSel.split("|")[1]:"";
    var $btn=$(this).prop("disabled",true).text("Loading...");
    $.ajax({url:BaseURL+"Reports/InvoiceSummary",type:"GET",
        data:{VendorName:vendorName, FromDate:$("#txtSumFrom").val(), ToDate:$("#txtSumTo").val()},
        dataType:"json",
        success:function(r){
            $btn.prop("disabled",false).text("Generate Summary");
            if(!r.success){alert("Error: "+(r.message||"Failed"));return;}
            $("#sumResVendor").text(r.VendorName);
            $("#sumResPeriod").text(r.FromDate+" to "+r.ToDate);
            $("#sumResCount").text(r.InvoiceCount);
            $("#sumResTotalInv").text("$"+parseFloat(r.TotalInvoiced).toFixed(2));
            $("#sumResTotalPaid").text("$"+parseFloat(r.TotalPaid).toFixed(2));
            $("#sumResTotalPend").text("$"+parseFloat(r.TotalPending).toFixed(2));
            if(parseFloat(r.PrevBalance)>0){
                $("#prevBalRow").show();
                $("#sumResPrevBal").text("$"+parseFloat(r.PrevBalance).toFixed(2));
                $("#sumResGrand").text("$"+parseFloat(r.GrandTotal).toFixed(2));
                $("#grandRow").show();
            } else { $("#prevBalRow,#grandRow").hide(); }
            $("#sumResult").show();
        },
        error:function(){ $btn.prop("disabled",false).text("Generate Summary"); alert("Server error."); }
    });
});

// ── Delete Invoice ──────────────────────────────────────────────────────
function DelInv(id,no){
    if(!confirm("Delete invoice "+no+"? This cannot be undone.")) return;
    $.ajax({url:BaseURL+"Reports/DeleteInvoice",type:"POST",data:{invoiceId:id},dataType:"json",
        success:function(r){ if(r.success){ GrdInv.reload(); LoadDashboard(currentVendor()); } else alert("Delete failed."); }
    });
}
</script>
</head>
<body>

<!-- ── Document Modal ─────────────────────────────────────────────────── -->
<div class="modal fade" id="modalDocument" tabindex="-1" role="dialog">
    <div class="modal-dialog" style="max-width:1050px;width:97vw;" role="document">
        <div class="modal-content" style="height:92vh;">
            <div class="modal-header modal-hd" style="padding:8px 15px;align-items:center;">
                <div style="display:flex;align-items:center;gap:6px;">
                    <button type="button" id="tabInvoiceBtn"
                            class="btn btn-sm"
                            style="background:#c0392b;color:#fff;"
                            onclick="ShowDocTab('invoice')">
                        <i class="fa fa-file-invoice"></i> Invoice
                    </button>
                    <button type="button" id="tabSheetBtn"
                            class="btn btn-sm btn-secondary"
                            onclick="ShowDocTab('sheet')">
                        <i class="fa fa-list-alt"></i> Job Sheet
                    </button>
                    <span style="color:#ccc;margin-left:8px;font-size:12px;" id="docModalTitle"></span>
                </div>
                <div style="margin-left:auto;display:flex;gap:6px;align-items:center;">
                    <button type="button" class="btn btn-sm btn-light" onclick="OpenPrint()">
                        <i class="fa fa-download"></i> Open / Print
                    </button>
                    <button type="button" class="close" data-dismiss="modal"
                            style="color:#fff;margin-left:4px;font-size:20px;">&times;</button>
                </div>
            </div>
            <div style="height:calc(92vh - 56px);">
                <iframe id="docFrame" src="" style="width:100%;height:100%;border:none;"></iframe>
            </div>
        </div>
    </div>
</div>

<!-- ── Payment Modal ───────────────────────────────────────────────────── -->
<div class="modal fade" id="modalPayment" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header modal-hd">
                <h5 class="modal-title" id="payTitle"><i class="fa fa-money-bill"></i> Payments</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="row" style="margin-bottom:12px;">
                    <div class="col-sm-4">
                        <div style="text-align:center;background:#f8f9fa;border:1px solid #dee2e6;border-radius:6px;padding:10px;">
                            <div style="font-size:10px;color:#777;text-transform:uppercase;">Invoice Amount</div>
                            <div style="font-size:20px;font-weight:bold;" id="payInvTotal">$0.00</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div style="text-align:center;background:#f8f9fa;border:1px solid #dee2e6;border-radius:6px;padding:10px;">
                            <div style="font-size:10px;color:#777;text-transform:uppercase;">Total Paid</div>
                            <div style="font-size:20px;font-weight:bold;color:#27ae60;" id="payInvPaid">$0.00</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div style="text-align:center;background:#f8f9fa;border:1px solid #dee2e6;border-radius:6px;padding:10px;">
                            <div style="font-size:10px;color:#777;text-transform:uppercase;">Balance Due</div>
                            <div style="font-size:20px;font-weight:bold;color:#c0392b;" id="payInvBal">$0.00</div>
                        </div>
                    </div>
                </div>
                <div style="font-size:11px;font-weight:bold;color:#555;border-bottom:1px solid #ddd;padding-bottom:3px;margin-bottom:8px;">PAYMENT HISTORY</div>
                <div id="payHistory"></div>
                <hr style="margin:10px 0;"/>
                <div style="font-size:11px;font-weight:bold;color:#555;border-bottom:1px solid #ddd;padding-bottom:3px;margin-bottom:10px;">RECORD NEW PAYMENT</div>
                <div class="row">
                    <div class="col-sm-3">
                        <div class="form-group">
                            <label style="font-size:11px;">Date *</label>
                            <input type="text" id="txtPayDate" class="form-control form-control-sm"/>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group">
                            <label style="font-size:11px;">Amount (SGD) *</label>
                            <div class="input-group input-group-sm">
                                <div class="input-group-prepend"><span class="input-group-text">$</span></div>
                                <input type="number" id="txtPayAmt" class="form-control" step="0.01" min="0.01" placeholder="0.00"/>
                            </div>
                            <small class="text-muted" style="font-size:10px;">Partial payments allowed</small>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group">
                            <label style="font-size:11px;">Payment Mode *</label>
                            <select id="ddlPayMode" class="form-control form-control-sm">
                                <option value="">-- Select --</option>
                                <option value="Cash">Cash</option>
                                <option value="BankTransfer">Bank Transfer</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group">
                            <label style="font-size:11px;">Remarks</label>
                            <input type="text" id="txtPayRemarks" class="form-control form-control-sm" placeholder="Optional"/>
                        </div>
                    </div>
                </div>
                <div class="row cash-fld">
                    <div class="col-sm-6">
                        <div class="form-group">
                            <label style="font-size:11px;"><strong>Cash Received By *</strong></label>
                            <select id="ddlReceivedBy" class="form-control form-control-sm"></select>
                        </div>
                    </div>
                </div>
                <div class="row bank-fld">
                    <div class="col-sm-6">
                        <div class="form-group">
                            <label style="font-size:11px;"><strong>Bank Account *</strong></label>
                            <input type="text" id="txtPayAccount" class="form-control form-control-sm" placeholder="Account name or number"/>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default btn-sm" data-dismiss="modal">Close</button>
                <button type="button" id="btnRecordPay" class="btn btn-success btn-sm">
                    <i class="fa fa-save"></i> Record Payment
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Create Invoice Modal ─────────────────────────────────────────────── -->
<div class="modal fade" id="modalCreate" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header modal-hd">
                <h5 class="modal-title"><i class="fa fa-file-invoice"></i> &nbsp;Create Invoice</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="frmManual" onsubmit="return false;">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Select Vendor <small class="text-muted">(auto-fills name &amp; address)</small></label>
                                <select id="ddlInvVendor" class="form-control">
                                    <option value="">-- Select or fill manually below --</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group">
                                <label><strong>Invoice Date *</strong></label>
                                <input type="text" id="txtManualInvDate" class="form-control"/>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group">
                                <label>Terms</label>
                                <select id="ddlManualTerms" class="form-control">
                                    <option value="Credit">Credit</option>
                                    <option value="Cash">Cash</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-5">
                            <div class="form-group">
                                <label><strong>Bill To Name *</strong></label>
                                <input type="text" id="txtManualBillTo" class="form-control" placeholder="e.g. ASIAN CLASSICAL TRAVELS"/>
                            </div>
                        </div>
                        <div class="col-sm-7">
                            <div class="form-group">
                                <label>Bill To Address</label>
                                <textarea id="txtManualAddress" class="form-control" rows="2" placeholder="Full address (auto-filled if vendor selected)"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-3">
                            <div class="form-group">
                                <label>Period From</label>
                                <input type="text" id="txtManualStartDate" class="form-control"/>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group">
                                <label>Period To</label>
                                <input type="text" id="txtManualEndDate" class="form-control"/>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group">
                                <label><strong>Total Amount (SGD) *</strong></label>
                                <input type="number" id="txtManualAmount" class="form-control" placeholder="0.00" step="0.01" min="0.01"/>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group">
                                <label>Description</label>
                                <input type="text" id="txtManualDesc" class="form-control" placeholder="TRANSPORT PROVIDED"/>
                            </div>
                        </div>
                    </div>
                </form>
                <div class="alert alert-info" style="font-size:12px;margin-bottom:0;">
                    <i class="fa fa-info-circle"></i>
                    Invoice ID is auto-generated. No job sheet for manual invoices.
                    The invoice will open for printing immediately after saving.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="button" id="btnSaveManual" class="btn btn-warning">
                    <i class="fa fa-file-invoice"></i> Save &amp; Generate
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Summary Modal ────────────────────────────────────────────────────── -->
<div class="modal fade" id="modalSummary" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header modal-hd">
                <h5 class="modal-title"><i class="fa fa-chart-bar"></i> &nbsp;Invoice Summary</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Vendor</label>
                    <select id="ddlSumVendor" class="form-control">
                        <option value="">All Vendors</option>
                    </select>
                </div>
                <div class="row">
                    <div class="col-sm-6">
                        <div class="form-group">
                            <label>From Date</label>
                            <input type="text" id="txtSumFrom" class="form-control"/>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="form-group">
                            <label>To Date</label>
                            <input type="text" id="txtSumTo" class="form-control"/>
                        </div>
                    </div>
                </div>
                <button type="button" id="btnGenSummary" class="btn btn-primary btn-block">
                    <i class="fa fa-search"></i> Generate Summary
                </button>
                <div id="sumResult" style="display:none;margin-top:14px;">
                    <hr style="margin-top:0;"/>
                    <div style="text-align:center;margin-bottom:10px;">
                        <strong id="sumResVendor"></strong><br/>
                        <small class="text-muted" id="sumResPeriod"></small>
                    </div>
                    <div id="prevBalRow" class="sum-prev" style="display:none;">
                        <i class="fa fa-exclamation-circle text-warning"></i>
                        <strong>Previous Month Balance (carried forward):</strong>
                        <span id="sumResPrevBal" style="color:#c0392b;font-weight:bold;float:right;"></span>
                        <div style="clear:both;"></div>
                        <small class="text-muted">Unpaid invoices from before the selected period</small>
                    </div>
                    <table class="table table-sm" style="font-size:13px;">
                        <tr>
                            <td>Total Invoices</td>
                            <td class="text-right"><strong id="sumResCount"></strong></td>
                        </tr>
                        <tr>
                            <td>Total Invoiced</td>
                            <td class="text-right"><strong class="inv-amt" id="sumResTotalInv"></strong></td>
                        </tr>
                        <tr>
                            <td>Total Paid</td>
                            <td class="text-right"><strong style="color:#27ae60;" id="sumResTotalPaid"></strong></td>
                        </tr>
                        <tr>
                            <td>Total Pending</td>
                            <td class="text-right"><strong class="bal-amt" id="sumResTotalPend"></strong></td>
                        </tr>
                        <tr id="grandRow" style="display:none;">
                            <td><strong>Grand Total Due (incl. previous balance)</strong></td>
                            <td class="text-right"><strong class="bal-amt" style="font-size:16px;" id="sumResGrand"></strong></td>
                        </tr>
                    </table>
                    <button class="btn btn-outline-secondary btn-sm btn-block" onclick="window.print()">
                        <i class="fa fa-print"></i> Print this Summary
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default btn-sm" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- ── Main Page ─────────────────────────────────────────────────────────── -->
<div class="content">
    <div class="container-fluid">

        <!-- Dashboard Cards -->
        <div class="row" style="margin-bottom:4px;">
            <div class="col-sm-4">
                <div class="dash-card" style="background:linear-gradient(135deg,#2c3e50,#3d5166);">
                    <div class="dash-lbl"><i class="fa fa-file-invoice"></i> Total Invoiced</div>
                    <div class="dash-val" id="dashInvoiced">$0.00</div>
                    <div class="dash-sub" id="dashCount">0 invoices</div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="dash-card" style="background:linear-gradient(135deg,#27ae60,#1e8449);">
                    <div class="dash-lbl"><i class="fa fa-check-circle"></i> Total Collected</div>
                    <div class="dash-val" id="dashCollected">$0.00</div>
                    <div class="dash-sub">Amount received</div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="dash-card" style="background:linear-gradient(135deg,#c0392b,#e74c3c);">
                    <div class="dash-lbl"><i class="fa fa-clock"></i> Total Pending</div>
                    <div class="dash-val" id="dashPending">$0.00</div>
                    <div class="dash-sub">Outstanding balance</div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="card card-pd">
                    <div class="card-header">
                        <span style="font-size:18px;" class="m-0"><i class="fas fa-file-invoice"></i></span>
                        <span style="font-size:18px;border-left:1px solid #ccc;padding-left:10px;"> Invoice</span>
                        <div style="float:right;">
                            <button type="button" id="btnCreateInvoice" class="btn btn-warning btn-sm" style="margin-right:6px;">
                                <i class="fa fa-plus-circle"></i> Create New
                            </button>
                            <button type="button" id="btnSummary" class="btn btn-info btn-sm" style="margin-right:10px;">
                                <i class="fa fa-chart-bar"></i> Summary
                            </button>
                            <span style="border-left:1px solid #ccc;padding-left:15px;padding-right:15px;">
                                <a href="#" onclick="showForm()"><i class="fas fa-caret-square-down"></i></a>
                            </span>
                            <span style="border-left:1px solid #ccc;padding-left:15px;padding-right:15px;">
                                <a href="#" onclick="hideForm()"><i class="fas fa-caret-square-up"></i></a>
                            </span>
                        </div>
                    </div>
                    <div class="card-body">
                        <!-- Filters -->
                        <div id="hidden-form">
                            <div class="row">
                                <div class="col-sm-2">
                                    <div class="form-group">
                                        <label><i class="fa fa-hashtag"></i> Invoice ID</label>
                                        <input type="text" id="txtInvNo" class="form-control" placeholder="NTT-INV-00001">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group">
                                        <label><i class="fa fa-user"></i> Bill To Name</label>
                                        <input type="text" id="txtBillTo" class="form-control" placeholder="Company / Customer">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group">
                                        <label><i class="fa fa-truck"></i> Vendor</label>
                                        <select id="ddlVendorFilter" class="form-control">
                                            <option value="">All Vendors</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group">
                                        <label>From Date</label>
                                        <input type="text" id="TxtFromDate" class="form-control">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group">
                                        <label>To Date</label>
                                        <input type="text" id="TxtToDate" class="form-control">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group">
                                        <label>Payment Status</label>
                                        <select id="ddlPayFilter" class="form-control">
                                            <option value="">All</option>
                                            <option value="Paid">Paid</option>
                                            <option value="Partial">Partial</option>
                                            <option value="Unpaid">Unpaid</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row" style="margin-bottom:6px;">
                                <div class="col-sm-12 text-right">
                                    <button type="button" id="btnSearch" class="btn btn-primary btn-sm" style="min-width:90px;">
                                        <i class="fa fa-search"></i> Search
                                    </button>
                                    <button type="button" id="btnClear" class="btn btn-secondary btn-sm" style="min-width:90px;margin-left:6px;">
                                        <i class="fa fa-times"></i> Clear
                                    </button>
                                </div>
                            </div>
                        </div>
                        <!-- Grid -->
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="box-body table-responsive no-padding">
                                    <table id="GrdInv" class="table table-hover"></table>
                                </div>
                            </div>
                        </div>
                        <!-- Bottom totals bar -->
                        <div class="row" style="margin-top:8px;padding:8px 15px;background:#f8f9fa;border-top:2px solid #2c3e50;border-radius:0 0 4px 4px;">
                            <div class="col-sm-4 text-center">
                                <small style="color:#777;">Total Invoiced (current page)</small>
                                <div style="font-size:15px;font-weight:bold;color:#155724;" id="sumTotal">$0.00</div>
                            </div>
                            <div class="col-sm-4 text-center">
                                <small style="color:#777;">Total Paid (current page)</small>
                                <div style="font-size:15px;font-weight:bold;color:#27ae60;" id="sumPaid">$0.00</div>
                            </div>
                            <div class="col-sm-4 text-center">
                                <small style="color:#777;">Total Balance (current page)</small>
                                <div style="font-size:15px;font-weight:bold;color:#c0392b;" id="sumBal">$0.00</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
