@using Transport.Model
@{
    Layout = null;
    var header  = (InvoiceHeaderModel)ViewBag.Header;
    var details = (List<InvoiceDetailModel>)ViewBag.Details;
    decimal creditTotal = details.Sum(d => d.Credit ?? 0);
    decimal cashTotal   = details.Sum(d => d.Cash ?? 0);
    decimal grandTotal  = details.Sum(d => d.Amount ?? 0);
}
<!DOCTYPE html>
<html>
<head>
    <title>Receipt - @header.InvoiceNo</title>
    <meta charset="utf-8" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, Helvetica, sans-serif; font-size: 11px; background: #fff; }

        .page { width: 100%; padding: 15px 20px; }

        /* Header */
        .company-header { display: table; width: 100%; margin-bottom: 8px; }
        .company-logo   { display: table-cell; width: 130px; vertical-align: middle; }
        .company-logo img { width: 120px; }
        .company-info   { display: table-cell; vertical-align: middle; padding-left: 15px; }
        .company-name   { font-size: 20px; font-weight: 900; color: #c0392b; letter-spacing: 1px; }
        .company-sub    { font-size: 11px; color: #333; line-height: 17px; }

        /* Receipt info box */
        .info-box { border: 1px solid #000; border-collapse: collapse; width: 100%; margin-bottom: 6px; }
        .info-box td { padding: 4px 8px; font-size: 11px; border-bottom: 1px solid #ddd; }
        .info-box .lbl { font-weight: bold; width: 130px; background: #f5f5f5; }
        .info-box .val { }

        /* Title bar */
        .receipt-title { background: #2c3e50; color: #fff; text-align: center;
                         font-size: 13px; font-weight: bold; padding: 6px; margin-bottom: 6px; letter-spacing: 2px; }

        /* Jobs table */
        .jobs-table { width: 100%; border-collapse: collapse; margin-bottom: 0; }
        .jobs-table th { background: #2c3e50; color: #fff; padding: 6px 5px; font-size: 10px;
                         text-align: left; border: 1px solid #1a252f; white-space: nowrap; }
        .jobs-table td { padding: 5px; border: 1px solid #ccc; font-size: 10px; vertical-align: top; }
        .jobs-table tr:nth-child(even) td { background: #f9f9f9; }
        .jobs-table .amt { text-align: right; font-weight: bold; }
        .jobs-table tfoot td { background: #ecf0f1; font-weight: bold; border-top: 2px solid #2c3e50; }
        .jobs-table tfoot .total-label { text-align: right; }
        .jobs-table tfoot .total-val   { text-align: right; color: #c0392b; }

        /* Grand total */
        .grand-total-bar { background: #2c3e50; color: #fff; padding: 7px 10px;
                           font-size: 13px; font-weight: bold; text-align: right; margin-top: 0; }
        .grand-total-bar span { font-size: 16px; }

        /* Footer note */
        .footer-note { text-align: center; color: #777; font-size: 10px;
                       padding: 8px; border-top: 1px dashed #ccc; margin-top: 8px; }

        /* Print button */
        .no-print { position: fixed; top: 10px; right: 10px; z-index: 999; }
        .no-print button { padding: 7px 16px; background: #2c3e50; color: #fff;
                           border: none; border-radius: 4px; cursor: pointer; font-size: 12px; margin-left: 6px; }
        .no-print button.inv-btn { background: #c0392b; }

        @@media print {
            .no-print { display: none; }
            body { font-size: 10px; }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <button onclick="window.print()"><i class="fa fa-print"></i> Print Receipt</button>
        <button class="inv-btn" onclick="OpenInvoice()"><i class="fa fa-file-invoice"></i> View Invoice</button>
    </div>

    <div class="page">

        <!-- Company Header -->
        <div class="company-header">
            <div class="company-logo">
                <img src="@Url.Content("~/AppImages/logo_nissi_151.png")" onerror="this.style.display='none'" />
            </div>
            <div class="company-info">
                <div class="company-name">NISSI TOURS AND TRAVELS PTE. LTD</div>
                <div class="company-sub">
                    291 Serangoon Road, Singapore 218107<br/>
                    Tel: +65 6292 0521 &nbsp;|&nbsp; HP: +65 9068 6384 &nbsp;|&nbsp; booking@nissitravels.com
                </div>
            </div>
        </div>

        <div class="receipt-title">JOB SHEET / RECEIPT</div>

        <!-- Invoice & Customer Info -->
        <table class="info-box">
            <tr>
                <td class="lbl">Invoice No</td>
                <td class="val"><strong>@header.InvoiceNo</strong></td>
                <td class="lbl">Date</td>
                <td class="val">@header.InvoiceDate.ToString("dd MMM yyyy")</td>
            </tr>
            <tr>
                <td class="lbl">Period</td>
                <td class="val">@header.DisplayStartDate &nbsp;-&nbsp; @header.DisplayEndDate</td>
                <td class="lbl">Type</td>
                <td class="val">@(header.IsCredit ? "Credit" : "Cash")</td>
            </tr>
            @if (!string.IsNullOrEmpty(header.JobVendorName))
            {
            <tr>
                <td class="lbl">Job Given By</td>
                <td class="val" colspan="3"><strong>@header.JobVendorName</strong></td>
            </tr>
            }
            @if (!string.IsNullOrEmpty(header.CustomerName))
            {
            <tr>
                <td class="lbl">Customer</td>
                <td class="val" colspan="3">@header.CustomerName</td>
            </tr>
            }
            @if (!string.IsNullOrEmpty(header.DrivingByName))
            {
            <tr>
                <td class="lbl">Driver</td>
                <td class="val">@header.DrivingByName</td>
                <td class="lbl">Vehicle</td>
                <td class="val">@header.VehicleName</td>
            </tr>
            }
        </table>

        <!-- Detailed Date-wise Job Table -->
        <table class="jobs-table">
            <thead>
                <tr>
                    <th style="width:4%">#</th>
                    <th style="width:9%">DATE</th>
                    <th style="width:6%">TIME</th>
                    <th style="width:8%">VEHICLE</th>
                    <th style="width:20%">FROM (PICKUP)</th>
                    <th style="width:20%">TO (DROPOFF)</th>
                    <th style="width:13%">CUSTOMER</th>
                    <th style="width:10%">DRIVER</th>
                    <th style="width:5%;text-align:right;">CREDIT</th>
                    <th style="width:5%;text-align:right;">CASH</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = 1; }
                @foreach (var d in details)
                {
                <tr>
                    <td>@idx</td>
                    <td>@d.DisplayJobDate</td>
                    <td>@d.JobTime</td>
                    <td>@d.VehicleName</td>
                    <td>@d.JobFrom</td>
                    <td>@d.JobTo</td>
                    <td>@d.CustomerName</td>
                    <td>@d.DrivingByName</td>
                    <td class="amt" style="color:#c0392b;">
                        @(d.Credit.HasValue && d.Credit > 0 ? d.Credit.Value.ToString("N2") : "")
                    </td>
                    <td class="amt">
                        @(d.Cash.HasValue && d.Cash > 0 ? d.Cash.Value.ToString("N2") : "")
                    </td>
                </tr>
                    idx++;
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="8" class="total-label">Total (@details.Count jobs)</td>
                    <td class="total-val">@(creditTotal > 0 ? creditTotal.ToString("N2") : "")</td>
                    <td class="total-val">@(cashTotal > 0 ? cashTotal.ToString("N2") : "")</td>
                </tr>
            </tfoot>
        </table>

        <div class="grand-total-bar">
            Grand Total &nbsp;&nbsp; SGD &nbsp; <span>@grandTotal.ToString("N2")</span>
        </div>

        <div class="footer-note">
            This is a computer generated job sheet &mdash; Invoice Ref: <strong>@header.InvoiceNo</strong>
        </div>

    </div>

    <script>
        function OpenInvoice() {
            var w = window.outerWidth || 1000;
            var h = window.outerHeight || 700;
            window.open('@Url.Content("~/Reports/ViewInvoice")?invoiceId=@header.InvoiceID',
                'invoice_@header.InvoiceID', 'width=' + w + ',height=' + h + ',scrollbars=yes');
        }
    </script>
</body>
</html>
