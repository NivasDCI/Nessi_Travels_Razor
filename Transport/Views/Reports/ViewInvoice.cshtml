@using Transport.Model
@{
    Layout = null;
    var header = (InvoiceHeaderModel)ViewBag.Header;
    decimal gross = (decimal)ViewBag.GrossAmount;
    string amountWords = (string)ViewBag.AmountInWords;
    string periodShort = header.DisplayShortStartDate + " -" + header.DisplayShortEndDate;
    string billToName  = !string.IsNullOrEmpty(header.BillToName)
                         ? header.BillToName
                         : (!string.IsNullOrEmpty(header.JobVendorName) ? header.JobVendorName : header.CustomerName);
    string billToAddr  = header.BillToAddress ?? "";
}
<!DOCTYPE html>
<html>
<head>
    <title>Invoice - @header.InvoiceNo</title>
    <meta charset="utf-8" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family: Arial, Helvetica, sans-serif; font-size:10pt; background:#fff; color:#000; }
        .page { padding:20px 25px; max-width:800px; margin:0 auto; }

        /* ── Company header ── */
        .co-wrap { display:table; width:100%; margin-bottom:12px; }
        .co-logo { display:table-cell; width:110px; vertical-align:middle; }
        .co-logo img { width:100px; }
        .co-text { display:table-cell; vertical-align:middle; padding-left:10px; }
        .co-name { font-size:20pt; font-weight:900; color:#c0392b; line-height:1.1; }
        .co-sub  { font-size:10pt; line-height:18px; color:#000; }
        .co-sub a { color:#1a0dab; text-decoration:none; }

        /* ── Bill To / Invoice block ── */
        .top-table { width:100%; border-collapse:collapse; border:1px solid #000; margin-bottom:0; }
        .top-table td { padding:8px 10px; vertical-align:top; }
        .bill-cell { width:58%; border-right:1px solid #000; }
        .inv-cell  { width:42%; }

        .inv-label { font-size:13pt; font-weight:bold; text-align:center;
                     border-bottom:1px solid #000; padding-bottom:5px; margin-bottom:5px; }
        .inv-row   { display:table; width:100%; margin-bottom:3px; }
        .inv-key   { display:table-cell; width:40%; font-size:10pt; }
        .inv-val   { display:table-cell; width:60%; font-size:10pt; }
        .inv-sep   { display:table-cell; width:8%; }

        .bill-name { font-size:11pt; font-weight:bold; margin-bottom:4px; }
        .bill-addr { font-size:10pt; line-height:18px; white-space:pre-line; }

        /* ── Items table ── */
        table.items { width:100%; border-collapse:collapse;
                      border:1px solid #000; border-top:none; }
        table.items th { padding:7px 6px; font-size:10pt; font-weight:bold;
                         border:1px solid #000; text-align:center; }
        table.items td { padding:7px 6px; border:1px solid #000; font-size:10pt;
                         vertical-align:top; }
        table.items td.c { text-align:center; }
        table.items td.r { text-align:right; }
        .desc-main { font-weight:bold; }
        .desc-sub  { font-size:9pt; color:#333; margin-top:2px; }

        /* ── Footer totals ── */
        table.footer { width:100%; border-collapse:collapse;
                       border:1px solid #000; border-top:none; }
        table.footer td { padding:7px 8px; border:1px solid #000; font-size:10pt;
                          vertical-align:top; }
        .words-cell { width:55%; }
        .gross-cell { width:25%; font-weight:bold; text-align:right; }
        .gross-val  { width:20%; font-weight:bold; text-align:right; }
        .net-cell   { font-weight:bold; text-align:right; }
        .net-val    { font-weight:bold; text-align:right; }

        /* ── Signature ── */
        .sig-table { width:100%; border-collapse:collapse;
                     border:1px solid #000; border-top:none; }
        .sig-table td { padding:8px 10px; font-size:10pt; }
        .sig-right { text-align:right; }
        .sig-line  { border-top:1px solid #000; width:180px; margin:45px 0 4px auto; }
        .sig-name  { font-size:10pt; font-weight:bold; }

        /* ── Print button ── */
        .no-print { position:fixed; top:10px; right:10px; z-index:999; }
        .no-print button { padding:7px 14px; border:none; border-radius:4px;
                           cursor:pointer; font-size:12px; margin-left:5px; color:#fff; }
        .btn-close { background:#555; }
        .btn-print { background:#c0392b; }

        @@media print {
            .no-print { display:none; }
            @@page { size: A4 portrait; margin:12mm; }
        }
    </style>
</head>
<body>

    <div class="no-print">
        <button class="btn-close" onclick="window.close()">Close</button>
        <button class="btn-print" onclick="window.print()">Print Invoice</button>
    </div>

    <div class="page">

        <!-- Company Header - logo left, name right -->
        <div class="co-wrap">
            <div class="co-logo">
                <img src="@Url.Content("~/AppImages/logo_nissi_151.png")" onerror="this.style.display='none'" />
            </div>
            <div class="co-text">
                <div class="co-name">NISSI TRANSPORT PTE.LTD</div>
                <div class="co-sub">
                    291 SERANGOON ROAD, SINGAPORE - 218107<br/>
                    TEL NO +65 91000521, +65 88660521<br/>
                    Email: <a href="mailto:nissi_transport@yahoo.com">nissi_transport@yahoo.com</a>
                </div>
            </div>
        </div>

        <!-- Bill To (left) + INVOICE box (right) -->
        <table class="top-table">
            <tr>
                <td class="bill-cell">
                    <div class="bill-name">@billToName</div>
                    <div class="bill-addr">@billToAddr</div>
                </td>
                <td class="inv-cell">
                    <div class="inv-label">INVOICE</div>
                    <div class="inv-row">
                        <div class="inv-key">Inv No</div>
                        <div class="inv-sep">:</div>
                        <div class="inv-val"><strong>@header.InvoiceNo</strong></div>
                    </div>
                    <div class="inv-row">
                        <div class="inv-key">Inv Date</div>
                        <div class="inv-sep">:</div>
                        <div class="inv-val">@header.InvoiceDate.ToString("d/M/yyyy")</div>
                    </div>
                    <div class="inv-row">
                        <div class="inv-key">Terms</div>
                        <div class="inv-sep">:</div>
                        <div class="inv-val">@(header.IsCredit ? "Credit" : "Cash")</div>
                    </div>
                </td>
            </tr>
        </table>

        <!-- Items table - single summary row exactly like PDF 2 -->
        <table class="items">
            <thead>
                <tr>
                    <th style="width:6%">S.No</th>
                    <th style="width:48%;text-align:left;">Product Description</th>
                    <th style="width:12%">UOM</th>
                    <th style="width:8%">Qty</th>
                    <th style="width:13%">Rate</th>
                    <th style="width:13%">Amount</th>
                </tr>
            </thead>
            <tbody>
                <tr style="height:180px; vertical-align:top;">
                    <td class="c">1</td>
                    <td>
                        <div class="desc-main">TRANSPORT PROVIDED</div>
                        <div class="desc-sub">Job Sheet attached (@periodShort)</div>
                    </td>
                    <td class="c">TRIP</td>
                    <td class="c">1</td>
                    <td class="r">@gross.ToString("N2")</td>
                    <td class="r">@gross.ToString("N2")</td>
                </tr>
            </tbody>
        </table>

        <!-- Footer totals -->
        <table class="footer">
            <tr>
                <td class="words-cell" rowspan="2">
                    <strong>Amount in words :</strong><br/>
                    @amountWords.<br/><br/>
                    <strong>Payment transfer to :</strong><br/>
                    Paynow: 202604690W<br/>
                    DBS current Account: 0721480042
                </td>
                <td class="gross-cell">Gross Amount</td>
                <td class="gross-val">@gross.ToString("N2")</td>
            </tr>
            <tr>
                <td class="net-cell"><strong>NET Amount</strong></td>
                <td class="net-val"><strong>@gross.ToString("N2")</strong></td>
            </tr>
        </table>

        <!-- Signature -->
        <table class="sig-table">
            <tr>
                <td style="width:60%">
                    for NISSI TRANSPORT PTE. LTD
                </td>
                <td class="sig-right" style="width:40%">
                    <div class="sig-line"></div>
                    <div class="sig-name"></div>
                </td>
            </tr>
            <tr>
                <td colspan="2" style="text-align:center; font-size:9pt; color:#444;">
                    This is computer generated invoice signature not required.
                </td>
            </tr>
        </table>

    </div>
</body>
</html>



