@using Transport.Model
@{
    Layout = null;
    var header  = (InvoiceHeaderModel)ViewBag.Header;
    var details = (List<InvoiceDetailModel>)ViewBag.Details;
    decimal gross = (decimal)ViewBag.GrossAmount;
}
<!DOCTYPE html>
<html>
<head>
    <title>Invoice - @header.InvoiceNo</title>
    <meta charset="utf-8" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, Helvetica, sans-serif; font-size: 12px; background: #fff; color: #000; }

        .page { width: 100%; max-width: 900px; margin: 0 auto; padding: 20px; }

        /* Company header */
        .co-header { display: table; width: 100%; border-bottom: 3px solid #c0392b; padding-bottom: 10px; margin-bottom: 12px; }
        .co-logo   { display: table-cell; width: 130px; vertical-align: middle; }
        .co-logo img { width: 120px; }
        .co-info   { display: table-cell; vertical-align: middle; padding-left: 15px; }
        .co-name   { font-size: 22px; font-weight: 900; color: #c0392b; }
        .co-sub    { font-size: 11px; line-height: 18px; color: #444; }

        /* Invoice title row */
        .inv-title-row { display: table; width: 100%; margin-bottom: 12px; }
        .bill-to       { display: table-cell; width: 60%; vertical-align: top; }
        .bill-to-label { font-size: 10px; color: #777; text-transform: uppercase; margin-bottom: 4px; }
        .bill-to-name  { font-size: 16px; font-weight: bold; color: #2c3e50; }
        .bill-to-sub   { font-size: 11px; color: #555; margin-top: 3px; line-height: 17px; }
        .inv-meta      { display: table-cell; width: 40%; vertical-align: top; }
        .inv-meta table { width: 100%; border-collapse: collapse; }
        .inv-meta table td { padding: 4px 8px; font-size: 11px; border: 1px solid #ddd; }
        .inv-meta table td:first-child { background: #f5f5f5; font-weight: bold; width: 45%; }
        .inv-meta .inv-no-val { font-size: 13px; font-weight: bold; color: #c0392b; }

        /* Items table */
        .items-table { width: 100%; border-collapse: collapse; margin-bottom: 0; }
        .items-table thead tr { background: #2c3e50; color: #fff; }
        .items-table th { padding: 8px 10px; font-size: 11px; text-align: left; border: 1px solid #1a252f; }
        .items-table th.r { text-align: right; }
        .items-table td { padding: 7px 10px; border: 1px solid #ddd; font-size: 11px; vertical-align: top; }
        .items-table tr:nth-child(even) td { background: #fafafa; }
        .items-table td.r { text-align: right; }
        .items-table td.sno { text-align: center; width: 4%; }
        .items-table td.date { width: 10%; white-space: nowrap; }
        .items-table td.time { width: 7%; }
        .items-table td.amt  { text-align: right; width: 10%; font-weight: bold; }

        /* Totals section */
        .totals-section { border: 1px solid #ddd; border-top: none; }
        .totals-row { display: table; width: 100%; }
        .totals-left  { display: table-cell; width: 55%; padding: 12px; vertical-align: top; border-right: 1px solid #ddd; }
        .totals-right { display: table-cell; width: 45%; vertical-align: top; }
        .totals-right table { width: 100%; border-collapse: collapse; }
        .totals-right td { padding: 6px 10px; border-bottom: 1px solid #eee; font-size: 12px; }
        .totals-right td:last-child { text-align: right; font-weight: bold; }
        .totals-right .net-row td { background: #2c3e50; color: #fff; font-size: 14px; font-weight: bold; }
        .totals-right .net-row td:last-child { font-size: 16px; }

        .amount-words { font-size: 11px; color: #555; margin-top: 4px; }
        .payment-info { font-size: 11px; line-height: 18px; color: #444; margin-top: 8px; }
        .payment-info strong { color: #2c3e50; }

        /* Signature */
        .sig-section { border-top: 1px solid #ddd; padding: 16px 10px; display: table; width: 100%; margin-top: 0; }
        .sig-left  { display: table-cell; width: 60%; padding-right: 20px; font-size: 11px; color: #777; }
        .sig-right { display: table-cell; width: 40%; text-align: right; }
        .sig-name  { font-size: 13px; font-weight: bold; color: #2c3e50; }
        .sig-line  { border-top: 1px solid #000; width: 200px; margin: 40px 0 4px auto; }

        /* Print button */
        .no-print { position: fixed; top: 10px; right: 10px; z-index: 999; }
        .no-print button { padding: 7px 16px; background: #c0392b; color: #fff;
                           border: none; border-radius: 4px; cursor: pointer; font-size: 12px; margin-left: 6px; }
        .no-print button.back-btn { background: #2c3e50; }

        @@media print {
            .no-print { display: none; }
            .page { padding: 10px; }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <button class="back-btn" onclick="window.history.back()">&#8592; Receipt</button>
        <button onclick="window.print()">&#128438; Print Invoice</button>
    </div>

    <div class="page">

        <!-- Company Header -->
        <div class="co-header">
            <div class="co-logo">
                <img src="@Url.Content("~/AppImages/logo_nissi_151.png")" onerror="this.style.display='none'" />
            </div>
            <div class="co-info">
                <div class="co-name">NISSI TOURS AND TRAVELS PTE. LTD</div>
                <div class="co-sub">
                    291 Serangoon Road, Singapore 218107<br/>
                    Tel: +65 6292 0521 &nbsp;|&nbsp; HP: +65 9068 6384 &nbsp;|&nbsp; booking@nissitravels.com
                </div>
            </div>
        </div>

        <!-- Bill To + Invoice Meta -->
        <div class="inv-title-row">
            <div class="bill-to">
                <div class="bill-to-label">Bill To</div>
                <div class="bill-to-name">
                    @(string.IsNullOrEmpty(header.JobVendorName) ? header.CustomerName : header.JobVendorName)
                </div>
                <div class="bill-to-sub">
                    @if (!string.IsNullOrEmpty(header.CustomerName) && !string.IsNullOrEmpty(header.JobVendorName))
                    {
                        <span>Attn: @header.CustomerName</span><br/>
                    }
                    @if (!string.IsNullOrEmpty(header.DrivingByName))
                    {
                        <span>Driver: @header.DrivingByName &nbsp;|&nbsp; Vehicle: @header.VehicleName</span><br/>
                    }
                    Period: @header.DisplayStartDate - @header.DisplayEndDate
                </div>
            </div>
            <div class="inv-meta">
                <table>
                    <tr>
                        <td>INVOICE</td>
                        <td class="inv-no-val">@header.InvoiceNo</td>
                    </tr>
                    <tr>
                        <td>Invoice Date</td>
                        <td>@header.InvoiceDate.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <td>Staff</td>
                        <td>@(HttpContext.Current.Session["USER_NAME"] ?? "Admin")</td>
                    </tr>
                    <tr>
                        <td>Terms</td>
                        <td>@(header.IsCredit ? "Credit" : "Cash")</td>
                    </tr>
                    <tr>
                        <td>Total Jobs</td>
                        <td>@details.Count</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- Line Items Table -->
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width:4%;text-align:center;">#</th>
                    <th style="width:10%;">Date</th>
                    <th style="width:7%;">Time</th>
                    <th style="width:22%;">Pickup</th>
                    <th style="width:22%;">Dropoff</th>
                    <th style="width:14%;">Customer</th>
                    <th style="width:11%;">Driver</th>
                    <th class="r" style="width:10%;">Amount (SGD)</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = 1; }
                @foreach (var d in details)
                {
                <tr>
                    <td class="sno">@idx</td>
                    <td class="date">@d.DisplayJobDate</td>
                    <td class="time">@d.JobTime</td>
                    <td>@d.JobFrom</td>
                    <td>@d.JobTo</td>
                    <td>@d.CustomerName</td>
                    <td>@d.DrivingByName</td>
                    <td class="amt">@String.Format("{0:N2}", d.Amount)</td>
                </tr>
                    idx++;
                }
            </tbody>
        </table>

        <!-- Totals Section -->
        <div class="totals-section">
            <div class="totals-row">
                <div class="totals-left">
                    <div><strong>Amount in words:</strong></div>
                    <div class="amount-words">@ViewBag.AmountInWords Dollars Only</div>
                    <div class="payment-info">
                        <strong>Payment Transfer To:</strong><br/>
                        PayNow UEN: <strong>201710306R</strong><br/>
                        DBS Current Account: <strong>107-903506-0</strong>
                    </div>
                </div>
                <div class="totals-right">
                    <table>
                        <tr>
                            <td>Gross Amount</td>
                            <td>SGD @String.Format("{0:N2}", gross)</td>
                        </tr>
                        <tr class="net-row">
                            <td>NET Amount</td>
                            <td>SGD @String.Format("{0:N2}", gross)</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- Signature -->
        <div class="sig-section">
            <div class="sig-left">
                <em>This is a computer generated invoice &mdash; signature not required.</em>
            </div>
            <div class="sig-right">
                <div class="sig-line"></div>
                <div class="sig-name">for NISSI TOURS AND TRAVELS PTE. LTD</div>
            </div>
        </div>

    </div>
</body>
</html>
