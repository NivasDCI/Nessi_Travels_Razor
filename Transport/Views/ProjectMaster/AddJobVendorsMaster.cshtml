@using Transport.Repository.Resource;


@{
    ViewBag.Title = "Add Job Vendors";
    Layout = "";
}

<!DOCTYPE html>

<html>
<head>
    <script>

        ShowCommonBack();

        function titleCase(str) {
            var splitStr = str.toLowerCase().split(' ');
            for (var i = 0; i < splitStr.length; i++) {
                // You do not need to check if i is larger than splitStr length, as your for does that for you
                // Assign it back to the array
                splitStr[i] = splitStr[i].charAt(0).toUpperCase() + splitStr[i].substring(1);
            }
            // Directly return the joined string
            return splitStr.join(' ');

        }
        //Handling Focus on load and Submit On Enter
        EditJobVendors();

        $('#btnJobVendorsSave').click(function (e) {
            if ($(this).hasClass("unclickable")) {
                e.preventDefault();
            } else {
                var _errorMsg = "";

                if ($("#TxtJobVendorName").val() == "") {
                    _errorMsg += '<br />' + "Job Vendor Name is Required";
                }


                if (_errorMsg.length > 0) {
                    ErrorAlert(_errorMsg);
                    return false;
                }

                $.confirm({
                    title: ConfirmAlert_SuccessMessage,
                    content: GetParamValue("JobVendorCode") == 0 ? ConfirmAlert_Message_Content.replace("{0}", ConfirmAlert_SaveMessage_Content) : ConfirmAlert_Message_Content.replace("{0}", ConfirmAlert_UpdateMessage_Content),
                    animation: 'zoom',
                    closeAnimation: 'zoom',
                    buttons: {
                        'confirm': {
                            text: Alert_YesMessage,
                            btnClass: Alert_Button_Style,
                            keys: ['enter'],
                            action: function () {

                                var fileData = new FormData();

                                fileData.append("JobVendorCode", GetParamValue("JobVendorCode"));
                                fileData.append("JobVendorName", titleCase($("#TxtJobVendorName").val()));
                                fileData.append("Address1", titleCase($("#TxtAddress1").val()));
                                fileData.append("Address2", titleCase($("#TxtAddress2").val()));
                                fileData.append("Address3", titleCase($("#TxtAddress3").val()));
                                fileData.append("ContactNo", $("#TxtContactNo").val());
                                fileData.append("Status", $("#JobVendorsStatus").is(":checked"));
                                $.ajax({
                                    url: BaseURL + "ProjectMaster/JobVendorsMaster_Save", type: "POST",
                                    contentType: false, // Not to set any content header
                                    processData: false,
                                    data: fileData
                                }).done(function (result) {
                                    if (result.Result == true) {
                                        SucessAlert(result.Message);
                                        JobVendorsClear();
                                        BackFunction();
                                    }
                                    else if (result.Result == false) {
                                        ErrorAlert(result.Message);
                                    }
                                })
                                    .fail(function () {
                                        ErrorAlert(result.Message);
                                    });
                            }
                        },
                        cancel: {
                            text: Alert_NoMessage,
                            btnClass: Alert_Button_Style
                        }
                    }
                });

            }
        });

        function JobVendorsClear() {
            $('#TxtJobVendorName').val(""); $('#TxtAddress1').val(""); $('#TxtAddress2').val(""); $('#TxtAddress3').val(""); $('#TxtContactNo').val("");
            $('#JobVendorsStatus').prop('checked', true);
        }

        $("#btnJobVendorsReset").click(function (e) {
            if ($(this).hasClass("unclickable")) {
                e.preventDefault();
            } else {

                $(this).addClass("unclickable");
                ResetJobVendors();
            }
        });

        function ResetJobVendors() {
            if (GetParamValue("JobVendorCode") != 0) {
                EditJobVendors();
            }
            else {
                JobVendorsClear();
            }
        }

        function EditJobVendors() {

            if (GetParamValue("JobVendorCode") != 0) {
                $.ajax({
                    type: "GET",
                    url: BaseURL + "ProjectMaster/JobVendorsMaster_Edit",
                    data: { JobVendorCode: GetParamValue("JobVendorCode") },
                    datatype: "Json",
                    success: function (data) {
                        $("#TxtJobVendorName").val(data.JobVendorName);
                        $("#TxtAddress1").val(data.Address1);
                        $("#TxtAddress2").val(data.Address2);
                        $("#TxtAddress3").val(data.Address3);
                        $("#TxtContactNo").val(data.ContactNo);
                        if (data.Status) {
                            $('#JobVendorsStatus').prop('checked', true);
                        }
                        else {
                            $('#JobVendorsStatus').prop('checked', false);
                        }
                    }
                });
            }
            else {
                $('#JobVendorsStatus').prop('checked', true);
            }
        }


    </script>
</head>
<body>
    <!-- Main content -->
    <div class="content">
        <div class="container-fluid">
            <div class="row">

                <!-- /.col-md-12 -->
                <div class="col-lg-12">
                    <div class="card card-pd">
                        <div class="card-header">
                            <span style="font-size: 18px;" class="m-0"><i class="fas fa-users"></i></span>
                            <span style="font-size: 18px; border-left: 1px solid #ccc; padding-left: 10px;"> Job Vendors Master - [Add/Edit] </span>
                        </div>
                        <div class="card-body">

                            <p class="introtext">@SYSPageModel.Common_Hint</p>

                            <div class="row">
                                <div class="col-sm-5">

                                    <div class="form-group required">
                                        <label class="control-label">Company Name</label>
                                        <input type="text" tabindex="1" class="form-control" id="TxtJobVendorName" style="text-transform: capitalize" placeholder="Job Vendors Name">
                                    </div>

                                    <div class="form-group">
                                        <label class="control-label">Contact No</label>
                                        <input type="text" tabindex="2" class="form-control" id="TxtContactNo" placeholder="Contact No">
                                    </div>

                                    <div class="pdt-25">
                                        <div class="row">
                                            <div class="col-sm-6">
                                                <div class="form-group clearfix">
                                                    <div class="icheck-primary">
                                                        @Html.CheckBox("JobVendorsStatus", new { @tabindex = 3 })
                                                        <label for="JobVendorsStatus">
                                                            Status
                                                        </label>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                            </div>
                            <div class="row">
                                <div class="col-sm-5">

                                    <div class="form-group">
                                        <label class="control-label">Address 1</label>
                                        <input type="text" tabindex="4" class="form-control" id="TxtAddress1" style="text-transform: capitalize" placeholder="Address1">
                                    </div>
                                    <div class="form-group">
                                        <label class="control-label">Address 2</label>
                                        <input type="text" tabindex="5" class="form-control" id="TxtAddress2" style="text-transform: capitalize" placeholder="Address2">
                                    </div>
                                    <div class="form-group">
                                        <label class="control-label">Address 3</label>
                                        <input type="text" tabindex="6" class="form-control" id="TxtAddress3" style="text-transform: capitalize" placeholder="Address3">
                                    </div>
                                </div>

                            </div>
                            <div class="row">
                                <div class="col-sm-5">                                   

                                    <div class="pdt-30">
                                        <div class="row">
                                            <div class="col-sm-6">
                                                <button type="button" tabindex="7" id="btnJobVendorsSave" class="btn btn-primary btn-block"><i class="fa fa-save"></i> @Transport.Repository.WEBPAGEBUTTON.SAVE</button>
                                            </div>
                                            <div class="col-sm-6">
                                                <button type="button" tabindex="8" id="btnJobVendorsReset" class="btn btn-secondary btn-block"><i class="fa fa-undo"></i> @Transport.Repository.WEBPAGEBUTTON.RESET</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                    <!-- /.col-md-12 -->
                </div>
                <!-- /.row -->
            </div><!-- /.container-fluid -->
        </div>
        <!-- /.content -->
    </div>

</body>
</html>
